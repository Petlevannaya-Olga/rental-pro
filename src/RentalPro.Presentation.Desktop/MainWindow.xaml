<Window x:Class="RentalPro.Presentation.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:common="clr-namespace:RentalPro.Presentation.Desktop.Common"
        Title="RentalPRO"
        Width="1280"
        Height="760"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7FC">
<Window.Resources>
    <common:SelectedMenuItemConverter x:Key="SelectedMenuItemConverter"/>
    <Style x:Key="MenuIconStyle"
           TargetType="materialDesign:PackIcon">
        <Setter Property="Width" Value="22"/>
        <Setter Property="Height" Value="22"/>
        <Setter Property="Foreground" Value="#D7E7FF"/>
        <Setter Property="Margin" Value="0 0 12 0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="MenuButtonStyle"
       TargetType="Button">
    <Setter Property="Height" Value="46"/>
    <Setter Property="Margin" Value="0 0 0 8"/>
    <Setter Property="Padding" Value="16 0"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="Foreground" Value="#EAF2FF"/>
    <Setter Property="FontSize" Value="15"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="Button">
                <Grid>
                    <Border x:Name="SelectedBackground"
                            Background="#1E73FF"
                            CornerRadius="13"
                            Visibility="Collapsed"/>

                    <Border x:Name="HoverBackground"
                            Background="Transparent"
                            CornerRadius="13"/>

                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="Center"
                                      Margin="{TemplateBinding Padding}"/>
                </Grid>

                <ControlTemplate.Triggers>
                    <DataTrigger Value="True">
                        <DataTrigger.Binding>
                            <MultiBinding Converter="{StaticResource SelectedMenuItemConverter}">
                                <Binding RelativeSource="{RelativeSource TemplatedParent}"
                                         Path="Tag"/>
                                <Binding RelativeSource="{RelativeSource TemplatedParent}"
                                         Path="CommandParameter"/>
                            </MultiBinding>
                        </DataTrigger.Binding>

                        <Setter TargetName="SelectedBackground"
                                Property="Visibility"
                                Value="Visible"/>
                    </DataTrigger>

                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="HoverBackground"
                                Property="Background"
                                Value="#112F5E"/>
                    </Trigger>

                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="HoverBackground"
                                Property="Background"
                                Value="#1E73FF"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>

</Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левое меню -->
        <Border Grid.Column="0"
                Background="#071B39">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="110"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="90"/>
                </Grid.RowDefinitions>

                <!-- Логотип -->
                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Margin="24 24 20 20">

                    <Border Width="52"
                            Height="52"
                            CornerRadius="15"
                            Background="#1E73FF"
                            Margin="0 0 14 0">

                        <materialDesign:PackIcon Kind="Tools"
                                                 Width="28"
                                                 Height="28"
                                                 Foreground="White"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="24"
                                   FontWeight="Black">
                            <Run Text="Rental" Foreground="White"/>
                            <Run Text="PRO" Foreground="#1E73FF"/>
                        </TextBlock>

                        <TextBlock Text="Desktop client"
                                   Foreground="#AFC8EE"
                                   FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <!-- Навигация -->
                <StackPanel Grid.Row="1"
                            Margin="18 10 18 0">

                    <Button Command="{Binding NavigateCommand}"
                            CommandParameter="Дашборд"
                            Tag="{Binding CurrentPageTitle}"
                            Style="{StaticResource MenuButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboardOutline"
                                                     Style="{StaticResource MenuIconStyle}"/>
                            <TextBlock Text="Дашборд"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateCommand}"
                            CommandParameter="Клиенты"
                            Tag="{Binding CurrentPageTitle}"
                            Style="{StaticResource MenuButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountGroupOutline"
                                                     Style="{StaticResource MenuIconStyle}"/>
                            <TextBlock Text="Клиенты"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateCommand}"
                            CommandParameter="Инструменты"
                            Tag="{Binding CurrentPageTitle}"
                            Style="{StaticResource MenuButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Tools"
                                                     Style="{StaticResource MenuIconStyle}"/>
                            <TextBlock Text="Инструменты"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateCommand}"
                            CommandParameter="Заказы"
                            Tag="{Binding CurrentPageTitle}"
                            Style="{StaticResource MenuButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ClipboardTextOutline"
                                                     Style="{StaticResource MenuIconStyle}"/>
                            <TextBlock Text="Заказы"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateCommand}"
                            CommandParameter="Оплаты"
                            Tag="{Binding CurrentPageTitle}"
                            Style="{StaticResource MenuButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CreditCardOutline"
                                                     Style="{StaticResource MenuIconStyle}"/>
                            <TextBlock Text="Оплаты"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateCommand}"
                            CommandParameter="Отчеты"
                            Tag="{Binding CurrentPageTitle}"
                            Style="{StaticResource MenuButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ChartBar"
                                                     Style="{StaticResource MenuIconStyle}"/>
                            <TextBlock Text="Отчеты"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateCommand}"
                            CommandParameter="Справочники"
                            Tag="{Binding CurrentPageTitle}"
                            Style="{StaticResource MenuButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="BookOpenVariant"
                                                     Style="{StaticResource MenuIconStyle}"/>
                            <TextBlock Text="Справочники"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- Нижний блок -->
                <StackPanel Grid.Row="2"
                            Margin="18 0 18 22"
                            VerticalAlignment="Bottom">

                    <Button Command="{Binding NavigateCommand}"
                            CommandParameter="Профиль"
                            Tag="{Binding CurrentPageTitle}"
                            Style="{StaticResource MenuButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountCircleOutline"
                                                     Style="{StaticResource MenuIconStyle}"/>
                            <TextBlock Text="Профиль"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Column="1"
              Background="#F4F7FC">

            <Grid.RowDefinitions>
                <RowDefinition Height="86"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Верхняя панель -->
            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="#E3EAF5"
                    BorderThickness="0 0 0 1">

                <Grid Margin="34 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentPageTitle}"
                                   FontSize="28"
                                   FontWeight="Black"
                                   Foreground="#071B39"/>

                        <TextBlock Text="RentalPRO desktop-клиент"
                                   FontSize="13"
                                   Foreground="#6B7890"
                                   Margin="0 4 0 0"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="#EEF4FF"
                            CornerRadius="18"
                            Padding="16 10"
                            VerticalAlignment="Center">

                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountCircleOutline"
                                                     Width="24"
                                                     Height="24"
                                                     Foreground="#1E73FF"
                                                     Margin="0 0 8 0"/>

                            <TextBlock Text="Пользователь"
                                       Foreground="#071B39"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Контент -->
            <Grid Grid.Row="1"
                  Margin="34">

                <Border Background="White"
                        CornerRadius="24"
                        Padding="36">

                    <Border.Effect>
                        <DropShadowEffect BlurRadius="22"
                                          ShadowDepth="3"
                                          Opacity="0.08"/>
                    </Border.Effect>

                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">

                        <materialDesign:PackIcon Kind="ApplicationCogOutline"
                                                 Width="68"
                                                 Height="68"
                                                 Foreground="#1E73FF"
                                                 HorizontalAlignment="Center"
                                                 Margin="0 0 0 18"/>

                        <TextBlock Text="{Binding CurrentPageTitle}"
                                   FontSize="30"
                                   FontWeight="Black"
                                   Foreground="#071B39"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Раздел будет подключен к API следующим шагом"
                                   FontSize="15"
                                   Foreground="#6B7890"
                                   HorizontalAlignment="Center"
                                   Margin="0 10 0 0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>