<Window x:Class="RentalPro.Presentation.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:common="clr-namespace:RentalPro.Presentation.Desktop.Common"
        xmlns:services="clr-namespace:RentalPro.Presentation.Desktop.Services"
        Title="RentalPRO"
        Width="1280"
        Height="760"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7FC">

    <Window.Resources>
        <common:BoolToGridLengthConverter x:Key="BoolToGridLengthConverter" />
        <common:StringEqualsConverter x:Key="StringEqualsConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="RentalProSnackbarStyle"
               TargetType="materialDesign:Snackbar">

            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#071B39" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="MinWidth" Value="320" />
            <Setter Property="MaxWidth" Value="460" />
            <Setter Property="Padding" Value="18 14" />

            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20"
                                      ShadowDepth="4"
                                      Opacity="0.18" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuTextStyle"
               TargetType="TextBlock">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMenuCollapsed}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuIconStyle"
               TargetType="materialDesign:PackIcon">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Foreground" Value="#D7E7FF" />
            <Setter Property="Margin" Value="0 0 12 0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMenuCollapsed}" Value="True">
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="HorizontalAlignment" Value="Center" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuRadioButtonStyle"
               TargetType="RadioButton">
            <Setter Property="Height" Value="46" />
            <Setter Property="Margin" Value="0 0 0 8" />
            <Setter Property="Padding" Value="16 0" />
            <Setter Property="Foreground" Value="#EAF2FF" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="GroupName" Value="MainMenu" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Background="Transparent"
                                CornerRadius="13">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#112F5E" />
                            </Trigger>

                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#1E73FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMenuCollapsed}" Value="True">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate DataType="{x:Type services:NotificationMessage}">
            <Border Background="White"
                    CornerRadius="14"
                    MinWidth="340"
                    MaxWidth="480">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Цветная полоска -->
                    <Border Grid.Column="0"
                            Background="{Binding AccentColor}"
                            CornerRadius="14 0 0 14" />

                    <!-- Иконка -->
                    <Border Grid.Column="1"
                            Width="42"
                            Height="42"
                            Margin="16 14 12 14"
                            CornerRadius="21"
                            Background="#F4F7FC">

                        <materialDesign:PackIcon Kind="{Binding Icon}"
                                                 Width="24"
                                                 Height="24"
                                                 Foreground="{Binding AccentColor}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                    </Border>

                    <!-- Текст -->
                    <StackPanel Grid.Column="2"
                                Margin="0 12 18 12"
                                VerticalAlignment="Center">

                        <TextBlock Text="{Binding Title}"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="#071B39" />

                        <TextBlock Text="{Binding Text}"
                                   FontSize="13"
                                   Foreground="#52637A"
                                   TextWrapping="Wrap"
                                   Margin="0 3 0 0" />

                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding IsMenuCollapsed, Converter={StaticResource BoolToGridLengthConverter}}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Левое меню -->
        <Border Grid.Column="0"
                Background="#071B39">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="132" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="90" />
                </Grid.RowDefinitions>

                <!-- Верхняя часть меню -->
                <Grid Grid.Row="0"
                      Margin="18 18 18 14">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Кнопка свернуть/развернуть меню -->
                    <Button Command="{Binding ToggleMenuCommand}"
                            Width="42"
                            Height="36"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            HorizontalAlignment="Right"
                            Cursor="Hand">

                        <materialDesign:PackIcon Width="25"
                                                 Height="25"
                                                 Foreground="#D7E7FF"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center">
                            <materialDesign:PackIcon.Style>
                                <Style TargetType="materialDesign:PackIcon">
                                    <Setter Property="Kind" Value="ChevronLeft" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMenuCollapsed}" Value="True">
                                            <Setter Property="Kind" Value="ChevronRight" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialDesign:PackIcon.Style>
                        </materialDesign:PackIcon>
                    </Button>

                    <!-- Логотип -->
                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                Margin="0 14 0 0"
                                HorizontalAlignment="Left">

                        <Border Width="52"
                                Height="52"
                                CornerRadius="15"
                                Background="#1E73FF"
                                Margin="0 0 14 0">

                            <materialDesign:PackIcon Kind="Tools"
                                                     Width="28"
                                                     Height="28"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" />
                        </Border>

                        <StackPanel VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMenuCollapsed}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock FontSize="24"
                                       FontWeight="Black">
                                <Run Text="Rental" Foreground="White" />
                                <Run Text="PRO" Foreground="#1E73FF" />
                            </TextBlock>

                            <TextBlock Text="Desktop client"
                                       Foreground="#AFC8EE"
                                       FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Навигация -->
                <StackPanel Grid.Row="1"
                            Margin="18 10 18 0">

                    <RadioButton
                        IsChecked="{Binding SelectedMenuItem, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Обзор, Mode=TwoWay}"
                        Style="{StaticResource MenuRadioButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboardOutline" Style="{StaticResource MenuIconStyle}" />
                            <TextBlock Text="Обзор" Style="{StaticResource MenuTextStyle}" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton
                        IsChecked="{Binding SelectedMenuItem, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Инструменты, Mode=TwoWay}"
                        Style="{StaticResource MenuRadioButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Tools" Style="{StaticResource MenuIconStyle}" />
                            <TextBlock Text="Инструменты" Style="{StaticResource MenuTextStyle}" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton
                        IsChecked="{Binding SelectedMenuItem, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Клиенты, Mode=TwoWay}"
                        Style="{StaticResource MenuRadioButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountGroupOutline" Style="{StaticResource MenuIconStyle}" />
                            <TextBlock Text="Клиенты" Style="{StaticResource MenuTextStyle}" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton
                        IsChecked="{Binding SelectedMenuItem, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Заказы, Mode=TwoWay}"
                        Style="{StaticResource MenuRadioButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ClipboardTextOutline" Style="{StaticResource MenuIconStyle}" />
                            <TextBlock Text="Заказы" Style="{StaticResource MenuTextStyle}" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton
                        IsChecked="{Binding SelectedMenuItem, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Оплаты, Mode=TwoWay}"
                        Style="{StaticResource MenuRadioButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CreditCardOutline" Style="{StaticResource MenuIconStyle}" />
                            <TextBlock Text="Оплаты" Style="{StaticResource MenuTextStyle}" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton
                        IsChecked="{Binding SelectedMenuItem, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Отчеты, Mode=TwoWay}"
                        Style="{StaticResource MenuRadioButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ChartBar" Style="{StaticResource MenuIconStyle}" />
                            <TextBlock Text="Отчеты" Style="{StaticResource MenuTextStyle}" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton
                        IsChecked="{Binding SelectedMenuItem, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Справочники, Mode=TwoWay}"
                        Style="{StaticResource MenuRadioButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="BookOpenVariant" Style="{StaticResource MenuIconStyle}" />
                            <TextBlock Text="Справочники" Style="{StaticResource MenuTextStyle}" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton
                        IsChecked="{Binding SelectedMenuItem, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Пользователи, Mode=TwoWay}"
                        Style="{StaticResource MenuRadioButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Users" Style="{StaticResource MenuIconStyle}" />
                            <TextBlock Text="Пользователи" Style="{StaticResource MenuTextStyle}" />
                        </StackPanel>
                    </RadioButton>

                </StackPanel>

                <!-- Нижний блок -->
                <StackPanel Grid.Row="2"
                            Margin="18 0 18 22"
                            VerticalAlignment="Bottom">

                    <RadioButton
                        IsChecked="{Binding SelectedMenuItem, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Профиль, Mode=TwoWay}"
                        Style="{StaticResource MenuRadioButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountCircleOutline" Style="{StaticResource MenuIconStyle}" />
                            <TextBlock Text="Профиль" Style="{StaticResource MenuTextStyle}" />
                        </StackPanel>
                    </RadioButton>

                </StackPanel>
            </Grid>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Column="1"
              Background="#F4F7FC">

            <Grid.RowDefinitions>
                <RowDefinition Height="86" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Верхняя панель -->
            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="#E3EAF5"
                    BorderThickness="0 0 0 1">

                <Grid Margin="34 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentPageTitle}"
                                   FontSize="28"
                                   FontWeight="Black"
                                   Foreground="#071B39" />

                        <TextBlock Text="RentalPRO desktop-клиент"
                                   FontSize="13"
                                   Foreground="#6B7890"
                                   Margin="0 4 0 0" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="#EEF4FF"
                            CornerRadius="18"
                            Padding="16 10"
                            VerticalAlignment="Center">

                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountCircleOutline"
                                                     Width="24"
                                                     Height="24"
                                                     Foreground="#1E73FF"
                                                     Margin="0 0 8 0" />

                            <TextBlock Text="Пользователь"
                                       Foreground="#071B39"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Контент -->
            <Grid Grid.Row="1"
                  Margin="34">
                <ContentControl Content="{Binding CurrentView}" />
            </Grid>
        </Grid>

        <Border Grid.Column="1"
                Width="400"
                Height="{Binding Notifications.Notification.Height}"
                Opacity="{Binding Notifications.Notification.Opacity}"
                IsHitTestVisible="{Binding Notifications.Notification.IsOpen}"
                Background="White"
                CornerRadius="16"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0 0 24 24"
                Panel.ZIndex="999">

            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                                  ShadowDepth="4"
                                  Opacity="0.15" />
            </Border.Effect>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Цветная полоска -->

                <Border Grid.Column="0"
                        Background="{Binding Notifications.Notification.AccentColor}"
                        CornerRadius="16 0 0 16" />

                <!-- Иконка -->

                <Border Grid.Column="1"
                        Width="44"
                        Height="44"
                        Margin="16 14 12 14"
                        CornerRadius="22"
                        Background="#F4F7FC">

                    <materialDesign:PackIcon
                        Kind="{Binding Notifications.Notification.Icon}"
                        Width="22"
                        Height="22"
                        Foreground="{Binding Notifications.Notification.AccentColor}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />

                </Border>

                <!-- Текст -->

                <StackPanel Grid.Column="2"
                            Margin="0 12 18 12"
                            VerticalAlignment="Center">

                    <TextBlock Text="{Binding Notifications.Notification.Title}"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="#071B39" />

                    <TextBlock Text="{Binding Notifications.Notification.Message}"
                               FontSize="13"
                               Foreground="#5B6B82"
                               Margin="0 4 0 0"
                               TextWrapping="Wrap" />

                </StackPanel>

            </Grid>

        </Border>
    </Grid>
</Window>