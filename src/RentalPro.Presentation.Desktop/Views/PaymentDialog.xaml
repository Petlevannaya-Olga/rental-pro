<Window x:Class="RentalPro.Presentation.Desktop.Views.PaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Принять оплату"
        Width="760"
        Height="620"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FB">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="PrimaryDialogButtonStyle"
               TargetType="Button">
            <Setter Property="Background" Value="#1E73FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="22 0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Border Margin="20"
            Padding="24"
            Background="White"
            CornerRadius="16">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="*" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Сводка -->
            <Border Grid.Row="2"
                    Background="#F8FAFC"
                    BorderBrush="#D8E2F0"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="20">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Клиент -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Клиент"
                                   FontSize="16"
                                   Foreground="#6B7890"
                                   VerticalAlignment="Center" />

                        <TextBlock Grid.Column="1"
                                   Text="{Binding CustomerName}"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="#071B39"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- Суммы -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Аренда -->
                        <Border Grid.Column="0"
                                Background="White"
                                BorderBrush="#D8E2F0"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16">

                            <StackPanel>
                                <TextBlock Text="Аренда"
                                           FontSize="13"
                                           Foreground="#6B7890" />

                                <TextBlock Text="{Binding RentalAmount, StringFormat={}{0:N0} ₽}"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#071B39"
                                           Margin="0 10 0 0" />

                                <TextBlock Text="{Binding PaidRentalAmount, StringFormat=Оплачено: {0:N0} ₽}"
                                           FontSize="13"
                                           Foreground="#6B7890"
                                           Margin="0 12 0 0" />

                                <TextBlock Text="{Binding RemainingRentalAmount, StringFormat=Осталось: {0:N0} ₽}"
                                           FontSize="13"
                                           Foreground="#6B7890"
                                           Margin="0 6 0 0" />
                            </StackPanel>
                        </Border>

                        <!-- Залог -->
                        <Border Grid.Column="2"
                                Background="White"
                                BorderBrush="#D8E2F0"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16">

                            <StackPanel>
                                <TextBlock Text="Залог"
                                           FontSize="13"
                                           Foreground="#6B7890" />

                                <TextBlock Text="{Binding DepositAmount, StringFormat={}{0:N0} ₽}"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#071B39"
                                           Margin="0 10 0 0" />

                                <TextBlock Text="{Binding PaidDepositAmount, StringFormat=Оплачено: {0:N0} ₽}"
                                           FontSize="13"
                                           Foreground="#6B7890"
                                           Margin="0 12 0 0" />

                                <TextBlock Text="{Binding RemainingDepositAmount, StringFormat=Осталось: {0:N0} ₽}"
                                           FontSize="13"
                                           Foreground="#6B7890"
                                           Margin="0 6 0 0" />
                            </StackPanel>
                        </Border>

                        <!-- Итого -->
                        <Border Grid.Column="4"
                                Background="#EAF3FF"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16">

                            <StackPanel>
                                <TextBlock Text="Итого"
                                           FontSize="13"
                                           Foreground="#6B7890" />

                                <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N0} ₽}"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#071B39"
                                           Margin="0 10 0 0" />

                                <TextBlock Text="{Binding PaidAmount, StringFormat=Оплачено: {0:N0} ₽}"
                                           FontSize="13"
                                           Foreground="#6B7890"
                                           Margin="0 12 0 0" />

                                <TextBlock Text="{Binding RemainingAmount, StringFormat=Осталось: {0:N0} ₽}"
                                           FontSize="13"
                                           Foreground="#6B7890"
                                           Margin="0 6 0 0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Форма -->
            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0"
                              Height="56"
                              ItemsSource="{Binding PaymentTypes}"
                              SelectedValue="{Binding PaymentTypeId, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              materialDesign:HintAssist.Hint="Тип оплаты"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}" />

                    <ComboBox Grid.Column="2"
                              Height="56"
                              ItemsSource="{Binding PaymentMethods}"
                              SelectedValue="{Binding PaymentMethodId, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              materialDesign:HintAssist.Hint="Способ оплаты"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}" />
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Height="56"
                             VerticalAlignment="Center"
                             Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding CanEditAmount}"
                             materialDesign:HintAssist.Hint="Сумма"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                    <DatePicker Grid.Column="2"
                                Height="56"
                                VerticalAlignment="Center"
                                SelectedDate="{Binding PaymentDate, UpdateSourceTrigger=PropertyChanged}"
                                materialDesign:HintAssist.Hint="Дата оплаты"
                                Style="{StaticResource MaterialDesignOutlinedDatePicker}" />
                </Grid>

                <TextBox Grid.Row="4"
                         Height="56"
                         Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Комментарий"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
            </Grid>

            <!-- Низ -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#DC2626"
                           FontSize="13"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">

                    <Button Height="42"
                            Padding="18 0"
                            Click="Cancel_OnClick"
                            Style="{StaticResource MaterialDesignOutlinedButton}">
                        <TextBlock Text="Отмена" />
                    </Button>

                    <Button Margin="12 0 0 0"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryDialogButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CreditCardCheckOutline"
                                                     Width="18"
                                                     Height="18"
                                                     Margin="0 0 8 0"
                                                     Foreground="White" />

                            <TextBlock Text="Принять оплату"
                                       Foreground="White"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>

                </StackPanel>
            </Grid>

        </Grid>
    </Border>
</Window>