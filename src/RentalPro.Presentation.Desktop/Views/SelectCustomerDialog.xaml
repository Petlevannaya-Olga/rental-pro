<Window x:Class="RentalPro.Presentation.Desktop.Views.SelectCustomerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Выбор клиента"
        Width="920"
        Height="620"
        WindowStartupLocation="CenterOwner"
        Background="White">
    <Window.Resources>
        <Style x:Key="PrimaryDialogButtonStyle"
               TargetType="Button">
            <Setter Property="Background" Value="#1E73FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="22 0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#1664E8" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#0F56C9" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root"
                                        Property="Opacity"
                                        Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox Grid.Row="0"
                 Height="48"
                 Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                 materialDesign:HintAssist.Hint="ФИО, телефон, email, паспорт или адрес"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Customers}"
                  SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  RowHeight="58"
                  Style="{StaticResource MaterialDesignDataGrid}">

            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Клиент" Width="2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding FullName}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Address}"
                                           FontSize="12"
                                           Foreground="#6B7890"
                                           Margin="0 3 0 0" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Телефон"
                                    Binding="{Binding PhoneNumber}"
                                    Width="150" />

                <DataGridTextColumn Header="Email"
                                    Binding="{Binding Email}"
                                    Width="220" />

                <DataGridTextColumn Header="Паспорт"
                                    Binding="{Binding Passport}"
                                    Width="160" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <Button Width="36"
                        Height="36"
                        Command="{Binding PreviousPageCommand}"
                        Style="{StaticResource MaterialDesignIconButton}">
                    <materialDesign:PackIcon Kind="ChevronLeft" />
                </Button>

                <TextBlock VerticalAlignment="Center"
                           Margin="12 0"
                           FontWeight="SemiBold">
                    <Run Text="{Binding CurrentPage, Mode=OneWay}" />
                    <Run Text=" из " />
                    <Run Text="{Binding TotalPages, Mode=OneWay}" />
                </TextBlock>

                <Button Width="36"
                        Height="36"
                        Command="{Binding NextPageCommand}"
                        Style="{StaticResource MaterialDesignIconButton}">
                    <materialDesign:PackIcon Kind="ChevronRight" />
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal">

                <Button Height="42"
                        Padding="18 0"
                        Click="Cancel_OnClick"
                        Style="{StaticResource MaterialDesignOutlinedButton}">

                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Close"
                                                 Width="18"
                                                 Height="18"
                                                 Margin="0 0 8 0" />

                        <TextBlock Text="Отмена" />
                    </StackPanel>
                </Button>

                <Button Margin="12 0 0 0"
                        Click="Select_OnClick"
                        Style="{StaticResource PrimaryDialogButtonStyle}">

                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Check"
                                                 Width="18"
                                                 Height="18"
                                                 Margin="0 0 8 0"
                                                 Foreground="White" />

                        <TextBlock Text="Выбрать"
                                   Foreground="White"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Button>

            </StackPanel>
        </Grid>
    </Grid>
</Window>