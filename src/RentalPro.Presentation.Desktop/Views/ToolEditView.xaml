<UserControl x:Class="RentalPro.Presentation.Desktop.Views.ToolEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Border Background="White"
            CornerRadius="16"
            Padding="24"
            Margin="0 0 16 0">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Верх -->
            <StackPanel Grid.Row="0">

                <Button HorizontalAlignment="Left"
                        Command="{Binding BackCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        Cursor="Hand">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent">
                                <ContentPresenter />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <materialDesign:PackIcon Grid.Column="0"
                                                 Kind="ArrowLeft"
                                                 Width="24"
                                                 Height="24"
                                                 Margin="0 0 10 0"
                                                 Foreground="#1E73FF" />

                        <TextBlock Grid.Column="1"
                                   Text="Назад к списку инструментов"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#6B7890" />
                    </Grid>
                </Button>

            </StackPanel>

            <!-- Форма создания / редактирования -->
            <Grid Grid.Row="2"
                  Visibility="{Binding IsEditable, Converter={StaticResource BooleanToVisibilityConverter}}">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Фото -->
                <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="16"
                        BorderBrush="#E5EAF2"
                        BorderThickness="1"
                        VerticalAlignment="Top">

                    <StackPanel>

                        <Grid Height="280">

                            <Image Source="{Binding DisplayPhotoPath}"
                                   Stretch="Uniform" />

                            <materialDesign:PackIcon Kind="ImageOutline"
                                                     Width="48"
                                                     Height="48"
                                                     Foreground="#CBD5E1"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center">

                                <materialDesign:PackIcon.Style>
                                    <Style TargetType="materialDesign:PackIcon">
                                        <Setter Property="Visibility" Value="Collapsed" />

                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DisplayPhotoPath}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding DisplayPhotoPath}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:PackIcon.Style>

                            </materialDesign:PackIcon>

                        </Grid>

                        <Button Height="40"
                                Margin="16 16 16 16"
                                Command="{Binding SelectImageCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}">

                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Upload"
                                                         Width="18"
                                                         Height="18"
                                                         Margin="0 0 8 0" />

                                <TextBlock Text="Выбрать фото" />
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </Border>

                <!-- Поля -->
                <ScrollViewer Grid.Column="2"
                              VerticalScrollBarVisibility="Auto">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0"
                                 Grid.Column="0"
                                 Text="{Binding Tool.Name, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Название"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                        <TextBox Grid.Row="0"
                                 Grid.Column="2"
                                 Text="{Binding Tool.ArticleNumber, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Артикул"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                        <ComboBox Grid.Row="2"
                                  Grid.Column="0"
                                  ItemsSource="{Binding Categories}"
                                  SelectedValue="{Binding Tool.CategoryId, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="Name"
                                  materialDesign:HintAssist.Hint="Категория"
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}" />

                        <ComboBox Grid.Row="2"
                                  Grid.Column="2"
                                  ItemsSource="{Binding Manufacturers}"
                                  SelectedValue="{Binding Tool.ManufacturerId, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="Name"
                                  materialDesign:HintAssist.Hint="Производитель"
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}" />

                        <TextBox Grid.Row="4"
                                 Grid.Column="0"
                                 Text="{Binding Tool.SerialNumber, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Серийный номер"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                        <TextBox Grid.Row="4"
                                 Grid.Column="2"
                                 Text="{Binding Tool.InventoryNumber, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Инвентарный номер"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                        <TextBox Grid.Row="6"
                                 Grid.Column="0"
                                 Text="{Binding Tool.RentalPricePerDay, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Стоимость аренды за день"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                        <TextBox Grid.Row="6"
                                 Grid.Column="2"
                                 Text="{Binding Tool.DepositAmount, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Залог"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                        <TextBox Grid.Row="8"
                                 Grid.Column="0"
                                 Grid.ColumnSpan="3"
                                 Text="{Binding Tool.CurrentCondition, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Текущее состояние"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                        <TextBox Grid.Row="10"
                                 Grid.Column="0"
                                 Grid.ColumnSpan="3"
                                 Height="110"
                                 Text="{Binding Tool.Description, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Top"
                                 materialDesign:HintAssist.Hint="Описание"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- Просмотр -->
            <Grid Grid.Row="2"
                  Visibility="{Binding IsViewMode, Converter={StaticResource BooleanToVisibilityConverter}}">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Только фото -->
                <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="16"
                        BorderBrush="#E5EAF2"
                        BorderThickness="1"
                        VerticalAlignment="Top">

                    <Grid Height="280">

                        <Image Source="{Binding ToolPhotoUrl}"
                               Stretch="Uniform" />

                        <materialDesign:PackIcon Kind="ImageOutline"
                                                 Width="48"
                                                 Height="48"
                                                 Foreground="#CBD5E1"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center">

                            <materialDesign:PackIcon.Style>
                                <Style TargetType="materialDesign:PackIcon">
                                    <Setter Property="Visibility" Value="Collapsed" />

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ToolPhotoUrl}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding ToolPhotoUrl}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialDesign:PackIcon.Style>

                        </materialDesign:PackIcon>

                    </Grid>
                </Border>

                <!-- Данные просмотра -->
                <Grid Grid.Column="2"
                      VerticalAlignment="Top">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Grid.Column="0"
                            Background="#F8FAFC"
                            CornerRadius="12"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Название"
                                       Foreground="#6B7890"
                                       FontSize="12" />
                            <TextBlock Text="{Binding Tool.Name}"
                                       Foreground="#071B39"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0 6 0 0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="2"
                            Background="#F8FAFC"
                            CornerRadius="12"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Артикул"
                                       Foreground="#6B7890"
                                       FontSize="12" />
                            <TextBlock Text="{Binding Tool.ArticleNumber}"
                                       Foreground="#071B39"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0 6 0 0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Grid.Column="0"
                            Background="#F8FAFC"
                            CornerRadius="12"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Категория"
                                       Foreground="#6B7890"
                                       FontSize="12" />
                            <TextBlock Text="{Binding CategoryName}"
                                       Foreground="#071B39"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0 6 0 0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Grid.Column="2"
                            Background="#F8FAFC"
                            CornerRadius="12"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Производитель"
                                       Foreground="#6B7890"
                                       FontSize="12" />
                            <TextBlock Text="{Binding ManufacturerName}"
                                       Foreground="#071B39"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0 6 0 0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="4"
                            Grid.Column="0"
                            Background="#F8FAFC"
                            CornerRadius="12"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Серийный номер"
                                       Foreground="#6B7890"
                                       FontSize="12" />
                            <TextBlock Text="{Binding Tool.SerialNumber}"
                                       Foreground="#071B39"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0 6 0 0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="4"
                            Grid.Column="2"
                            Background="#F8FAFC"
                            CornerRadius="12"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Инвентарный номер"
                                       Foreground="#6B7890"
                                       FontSize="12" />
                            <TextBlock Text="{Binding Tool.InventoryNumber}"
                                       Foreground="#071B39"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0 6 0 0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="6"
                            Grid.Column="0"
                            Background="#F8FAFC"
                            CornerRadius="12"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Аренда за день"
                                       Foreground="#6B7890"
                                       FontSize="12" />
                            <TextBlock Text="{Binding Tool.RentalPricePerDay, StringFormat={}{0:N0} ₽}"
                                       Foreground="#071B39"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0 6 0 0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="6"
                            Grid.Column="2"
                            Background="#F8FAFC"
                            CornerRadius="12"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Залог"
                                       Foreground="#6B7890"
                                       FontSize="12" />
                            <TextBlock Text="{Binding Tool.DepositAmount, StringFormat={}{0:N0} ₽}"
                                       Foreground="#071B39"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0 6 0 0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="8"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Background="#F8FAFC"
                            CornerRadius="12"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Описание"
                                       Foreground="#6B7890"
                                       FontSize="12" />
                            <TextBlock Text="{Binding Tool.Description}"
                                       Foreground="#071B39"
                                       FontSize="15"
                                       Margin="0 6 0 0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                </Grid>
            </Grid>

            <!-- Низ -->
            <Grid Grid.Row="3"
                  Margin="0 20 0 0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#DC2626"
                           VerticalAlignment="Center"
                           FontSize="13" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">

                    <Button Height="40"
                            Padding="18 0"
                            Command="{Binding FillTestDataCommand}"
                            Visibility="{Binding CanShowTestDataButton, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Style="{StaticResource MaterialDesignOutlinedButton}">

                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DatabasePlusOutline"
                                                     Width="18"
                                                     Height="18"
                                                     Margin="0 0 8 0" />
                            <TextBlock Text="Тестовые данные" />
                        </StackPanel>
                    </Button>

                    <Button Height="40"
                            Padding="18 0"
                            Margin="12 0 0 0"
                            Command="{Binding SaveCommand}"
                            Visibility="{Binding IsEditable, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Background="#1E73FF"
                            Foreground="White">

                        <TextBlock Text="{Binding SaveButtonText}" />
                    </Button>

                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>