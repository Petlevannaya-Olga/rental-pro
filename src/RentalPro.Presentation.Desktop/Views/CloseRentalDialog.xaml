<Window x:Class="RentalPro.Presentation.Desktop.Views.CloseRentalDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Закрытие аренды"
        Width="720"
        Height="640"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FB">

    <Window.Resources>
        <Style x:Key="PrimaryDialogButtonStyle"
               TargetType="Button">
            <Setter Property="Background" Value="#1E73FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="22 0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Border Margin="20"
            Padding="22"
            Background="White"
            CornerRadius="16">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="*" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Верх -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Закрытие аренды"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#071B39" />

                    <TextBlock Text="{Binding OrderNumber, StringFormat=Заказ № {0}}"
                               FontSize="13"
                               Foreground="#6B7890"
                               Margin="0 6 0 0" />
                </StackPanel>

                <Button Grid.Column="1"
                        Click="Cancel_OnClick"
                        Style="{StaticResource MaterialDesignIconButton}">
                    <materialDesign:PackIcon Kind="Close"
                                             Width="22"
                                             Height="22"
                                             Foreground="#64748B" />
                </Button>
            </Grid>

            <!-- Основной блок -->
            <Border Grid.Row="2"
                    Background="#F8FAFC"
                    BorderBrush="#D8E2F0"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="18">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Расчеты -->
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Плановая стоимость аренды"
                                       Foreground="#6B7890"
                                       FontSize="14" />

                            <TextBlock Grid.Column="1"
                                       Text="{Binding PlannedRentalAmount, StringFormat={}{0:N2} ₽}"
                                       Foreground="#071B39"
                                       FontWeight="SemiBold"
                                       FontSize="15" />
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Фактическая стоимость аренды"
                                       Foreground="#6B7890"
                                       FontSize="14" />

                            <TextBlock Grid.Column="1"
                                       Text="{Binding ActualRentalAmount, StringFormat={}{0:N2} ₽}"
                                       Foreground="#071B39"
                                       FontWeight="SemiBold"
                                       FontSize="15" />
                        </Grid>

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Оплачено по аренде"
                                       Foreground="#6B7890"
                                       FontSize="14" />

                            <TextBlock Grid.Column="1"
                                       Text="{Binding PaidRentalAmount, StringFormat={}{0:N2} ₽}"
                                       Foreground="#071B39"
                                       FontWeight="SemiBold"
                                       FontSize="15" />
                        </Grid>

                        <Border Grid.Row="6"
                                Height="1"
                                Background="#CBD5E1"
                                Margin="0 2" />

                        <Grid Grid.Row="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding FinalTotalTitle}"
                                       Foreground="#071B39"
                                       FontSize="15"
                                       FontWeight="SemiBold" />

                            <TextBlock Grid.Column="1"
                                       Text="{Binding FinalTotalAmount, StringFormat={}{0:N2} ₽}"
                                       Foreground="#071B39"
                                       FontWeight="Bold"
                                       FontSize="18" />
                        </Grid>
                    </Grid>

                    <!-- Залог -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Залог к возврату"
                                   Foreground="#6B7890"
                                   FontSize="14" />

                        <TextBlock Grid.Column="1"
                                   Text="{Binding DepositRefundAmount, StringFormat={}{0:N2} ₽}"
                                   Foreground="#071B39"
                                   FontWeight="SemiBold"
                                   FontSize="15" />
                    </Grid>

                    <!-- Форма -->
                    <Grid Grid.Row="4"
                          Margin="0 14 0 0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                      Height="56"
                                      ItemsSource="{Binding PaymentMethods}"
                                      SelectedValue="{Binding PaymentMethodId, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Name"
                                      materialDesign:HintAssist.Hint="Способ оплаты / возврата"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}" />

                            <DatePicker Grid.Column="2"
                                        Height="56"
                                        SelectedDate="{Binding PaymentDate, UpdateSourceTrigger=PropertyChanged}"
                                        materialDesign:HintAssist.Hint="Дата закрытия аренды"
                                        Style="{StaticResource MaterialDesignOutlinedDatePicker}" />
                        </Grid>

                        <TextBox Grid.Row="2"
                                 Height="56"
                                 Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Комментарий"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                    </Grid>
                </Grid>
            </Border>

            <!-- Низ -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#DC2626"
                           FontSize="13"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">

                    <Button Height="42"
                            Padding="18 0"
                            Click="Cancel_OnClick"
                            Style="{StaticResource MaterialDesignOutlinedButton}">
                        <TextBlock Text="Отмена" />
                    </Button>

                    <Button Margin="12 0 0 0"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryDialogButtonStyle}">

                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CheckCircleOutline"
                                                     Width="18"
                                                     Height="18"
                                                     Margin="0 0 8 0"
                                                     Foreground="White" />

                            <TextBlock Text="Закрыть аренду"
                                       Foreground="White"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>