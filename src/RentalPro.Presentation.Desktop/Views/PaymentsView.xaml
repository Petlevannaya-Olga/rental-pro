<UserControl x:Class="RentalPro.Presentation.Desktop.Views.PaymentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="PrimaryCardButton"
               TargetType="Button">

            <Setter Property="Background" Value="#1E73FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="72" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="12" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#1664E8" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#0F56C9" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root"
                                        Property="Opacity"
                                        Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">

            <Setter Property="Background" Value="#1E73FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="18 0" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="12" />

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1664E8" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>

                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0F56C9" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="2"
                                      Opacity="0.08" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource CardStyle}">
            <Setter Property="Height" Value="72" />
            <Setter Property="Margin" Value="0 0 12 12" />
            <Setter Property="Padding" Value="16 12" />
        </Style>

        <Style x:Key="StatTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7890" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="8 0 0 0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#071B39" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="DashboardDataGridStyle"
               TargetType="DataGrid"
               BasedOn="{StaticResource MaterialDesignDataGrid}">

            <Setter Property="Background" Value="Transparent" />
            <Setter Property="RowBackground" Value="White" />
            <Setter Property="AlternatingRowBackground" Value="White" />

            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF2F7" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />

            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserSortColumns" Value="True" />
            <Setter Property="IsReadOnly" Value="True" />

            <Setter Property="MinRowHeight" Value="58" />

            <Setter Property="FontSize" Value="13" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />

            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />

            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell"
                           BasedOn="{StaticResource MaterialDesignDataGridCell}">
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                    </Style>
                </Setter.Value>
            </Setter>

            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader"
                           BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CenteredColumnHeaderStyle"
               TargetType="DataGridColumnHeader"
               BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">

            <Setter Property="HorizontalContentAlignment"
                    Value="Center" />

            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="ActionsPopupBoxStyle"
               TargetType="materialDesign:PopupBox">

            <Setter Property="Foreground" Value="#1E73FF" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="ActionsMenuButtonStyle"
               TargetType="Button">

            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="18 0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#F8FAFC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionsDangerButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ActionsMenuButtonStyle}">
            <Setter Property="Foreground" Value="#DC2626" />
        </Style>

        <Style x:Key="DataGridRowHoverStyle"
               TargetType="DataGridRow">

            <Setter Property="Cursor"
                    Value="Hand" />

            <Style.Triggers>

                <Trigger Property="IsMouseOver"
                         Value="True">

                    <Setter Property="Background"
                            Value="#F8FAFC" />

                </Trigger>

            </Style.Triggers>

        </Style>
        
        <Style x:Key="CenteredCellTextStyle"
               TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="TextAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <UniformGrid Grid.Row="0"
                     Columns="5"
                     Margin="0 0 0 8">

            <Border Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border"
                           BasedOn="{StaticResource StatCardStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAllStatsSelected}"
                                         Value="True">
                                <Setter Property="Background"
                                        Value="#F3F8FF" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding SelectStatsFilterCommand}"
                                  CommandParameter="all" />
                </Border.InputBindings>

                <StackPanel>
                    <DockPanel Margin="0 0 0 4">
                        <materialDesign:PackIcon Kind="CreditCardOutline"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="#1E73FF" />

                        <TextBlock Text="Всего оплат"
                                   Style="{StaticResource StatTitleStyle}" />
                    </DockPanel>

                    <TextBlock Text="{Binding TotalCount}"
                               Style="{StaticResource StatValueStyle}" />
                </StackPanel>
            </Border>

            <Border Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border"
                           BasedOn="{StaticResource StatCardStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRentalStatsSelected}"
                                         Value="True">
                                <Setter Property="Background"
                                        Value="#F3F8FF" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding SelectStatsFilterCommand}"
                                  CommandParameter="rental" />
                </Border.InputBindings>

                <StackPanel>
                    <DockPanel Margin="0 0 0 4">
                        <materialDesign:PackIcon Kind="CalendarCheckOutline"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="#16A34A" />

                        <TextBlock Text="Аренда"
                                   Style="{StaticResource StatTitleStyle}" />
                    </DockPanel>

                    <TextBlock Text="{Binding RentalCount}"
                               Style="{StaticResource StatValueStyle}" />
                </StackPanel>
            </Border>

            <Border Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border"
                           BasedOn="{StaticResource StatCardStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDepositStatsSelected}"
                                         Value="True">
                                <Setter Property="Background"
                                        Value="#F3F8FF" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding SelectStatsFilterCommand}"
                                  CommandParameter="deposit" />
                </Border.InputBindings>

                <StackPanel>
                    <DockPanel Margin="0 0 0 4">
                        <materialDesign:PackIcon Kind="ShieldCheckOutline"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="#F97316" />

                        <TextBlock Text="Залог"
                                   Style="{StaticResource StatTitleStyle}" />
                    </DockPanel>

                    <TextBlock Text="{Binding DepositCount}"
                               Style="{StaticResource StatValueStyle}" />
                </StackPanel>
            </Border>

            <Border Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border"
                           BasedOn="{StaticResource StatCardStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRefundStatsSelected}"
                                         Value="True">
                                <Setter Property="Background"
                                        Value="#F3F8FF" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding SelectStatsFilterCommand}"
                                  CommandParameter="refund" />
                </Border.InputBindings>

                <StackPanel>
                    <DockPanel Margin="0 0 0 4">
                        <materialDesign:PackIcon Kind="Refresh"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="#0891B2" />

                        <TextBlock Text="Возврат залога"
                                   Style="{StaticResource StatTitleStyle}" />
                    </DockPanel>

                    <TextBlock Text="{Binding DepositRefundCount}"
                               Style="{StaticResource StatValueStyle}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <DockPanel Margin="0 0 0 4">
                        <materialDesign:PackIcon Kind="WalletOutline"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="#7C3AED" />

                        <TextBlock Text="Сумма оплат"
                                   Style="{StaticResource StatTitleStyle}" />
                    </DockPanel>

                    <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N2} ₽}"
                               Style="{StaticResource StatValueStyle}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}"
                Margin="0 8 16 0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="Transparent"
                        Padding="0"
                        Margin="12 0 0 16">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*" />
                            <ColumnDefinition Width="18" />

                            <ColumnDefinition Width="190" />
                            <ColumnDefinition Width="18" />

                            <ColumnDefinition Width="210" />
                            <ColumnDefinition Width="18" />

                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="18" />

                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="14" />

                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Height="48"
                                 Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Номер заказа, клиент, комментарий"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                        <ComboBox Grid.Column="2"
                                  Height="48"
                                  ItemsSource="{Binding PaymentTypes}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding PaymentTypeId, UpdateSourceTrigger=PropertyChanged}"
                                  materialDesign:HintAssist.Hint="Тип оплаты"
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}" />

                        <ComboBox Grid.Column="4"
                                  Height="48"
                                  ItemsSource="{Binding PaymentMethods}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding PaymentMethodId, UpdateSourceTrigger=PropertyChanged}"
                                  materialDesign:HintAssist.Hint="Способ оплаты"
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}" />

                        <DatePicker Grid.Column="6"
                                    Height="48"
                                    SelectedDate="{Binding DateFrom, UpdateSourceTrigger=PropertyChanged}"
                                    materialDesign:HintAssist.Hint="Дата с"
                                    Style="{StaticResource MaterialDesignOutlinedDatePicker}" />

                        <DatePicker Grid.Column="8"
                                    Height="48"
                                    SelectedDate="{Binding DateTo, UpdateSourceTrigger=PropertyChanged}"
                                    materialDesign:HintAssist.Hint="Дата по"
                                    Style="{StaticResource MaterialDesignOutlinedDatePicker}" />

                        <Button Grid.Column="10"
                                Width="42"
                                Height="42"
                                VerticalAlignment="Bottom"
                                Margin="0 0 0 2"
                                Command="{Binding ResetFiltersCommand}"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="Сбросить фильтры">

                            <materialDesign:PackIcon Kind="Refresh"
                                                     Width="22"
                                                     Height="22"
                                                     Foreground="#1E73FF" />
                        </Button>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Payments}"
                          Style="{StaticResource DashboardDataGridStyle}"
                          CanUserSortColumns="True"
                          Sorting="PaymentsDataGrid_OnSorting"
                          IsReadOnly="True"
                          materialDesign:DataGridAssist.ApplyMaterialDesignColumnStyles="True">

                    <DataGrid.Columns>

                        <DataGridTemplateColumn Header="Заказ"
                                                Width="160"
                                                SortMemberPath="ordernumber">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center"
                                                Margin="4 6">

                                        <TextBlock Text="{Binding OrderNumber}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Foreground="#071B39"
                                                   TextTrimming="CharacterEllipsis" />

                                        <TextBlock Text="{Binding OrderDate, StringFormat={}{0:dd.MM.yyyy}}"
                                                   FontSize="12"
                                                   Foreground="#6B7890"
                                                   Margin="0 4 0 0" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Клиент"
                                                Width="2.2*"
                                                MinWidth="220"
                                                SortMemberPath="customer">

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding CustomerFullName}"
                                               VerticalAlignment="Center"
                                               Foreground="#071B39"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Тип оплаты"
                                                Width="170"
                                                SortMemberPath="paymenttype">

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10"
                                            Padding="10 4"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">

                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background"
                                                        Value="#EEF2F7" />

                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PaymentTypeName}"
                                                                 Value="Аренда">
                                                        <Setter Property="Background"
                                                                Value="#DCFCE7" />
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding PaymentTypeName}"
                                                                 Value="Залог">
                                                        <Setter Property="Background"
                                                                Value="#FEF3C7" />
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding PaymentTypeName}"
                                                                 Value="Возврат залога">
                                                        <Setter Property="Background"
                                                                Value="#CFFAFE" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <TextBlock Text="{Binding PaymentTypeName}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#071B39" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Способ"
                                            Binding="{Binding PaymentMethodName}"
                                            Width="170"
                                            ElementStyle="{StaticResource CenteredCellTextStyle}"
                                            SortMemberPath="paymentmethod" />

                        <DataGridTextColumn Header="Дата"
                                            Binding="{Binding PaymentDate, StringFormat={}{0:dd.MM.yyyy HH:mm}}"
                                            Width="170"
                                            ElementStyle="{StaticResource CenteredCellTextStyle}"
                                            SortMemberPath="paymentdate" />

                        <DataGridTemplateColumn Header="Сумма"
                                                Width="140"
                                                SortMemberPath="amount">

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Amount, StringFormat={}{0:N2} ₽}"
                                               FontWeight="SemiBold"
                                               Foreground="#071B39"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="2"
                      Margin="12 16 0 0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Height="40"
                            Padding="16 0"
                            Command="{Binding ExportCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}">

                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileExcelOutline"
                                                     Width="18"
                                                     Height="18"
                                                     Margin="0 0 8 0" />

                            <TextBlock Text="Экспорт" />
                        </StackPanel>
                    </Button>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <Button Width="36"
                                Height="36"
                                Command="{Binding PreviousPageCommand}"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="Предыдущая страница">

                            <materialDesign:PackIcon Kind="ChevronLeft"
                                                     Width="20"
                                                     Height="20" />
                        </Button>

                        <TextBlock VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#6B7890"
                                   Margin="12 0">

                            <Run Text="{Binding CurrentPage, Mode=OneWay}" />
                            <Run Text=" из " />
                            <Run Text="{Binding TotalPages, Mode=OneWay}" />
                        </TextBlock>

                        <Button Width="36"
                                Height="36"
                                Command="{Binding NextPageCommand}"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="Следующая страница">

                            <materialDesign:PackIcon Kind="ChevronRight"
                                                     Width="20"
                                                     Height="20" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>