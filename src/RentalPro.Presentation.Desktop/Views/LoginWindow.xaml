<Window x:Class="RentalPro.Presentation.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:common="clr-namespace:RentalPro.Presentation.Desktop.Common"
        Title="RentalPRO"
        Width="1180"
        Height="660"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F4F7FC">

    <Window.Resources>

        <Style x:Key="LoginInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="16 0"/>
            <Setter Property="BorderBrush" Value="#D4DDEA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#071B39"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginPasswordStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="16 0"/>
            <Setter Property="BorderBrush" Value="#D4DDEA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#071B39"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Background" Value="#1E73FF"/>
            <Setter Property="BorderBrush" Value="#1E73FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="440"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая синяя плашка -->
        <Border Grid.Column="0"
                Background="#071B39">

            <Grid>

                <!-- Точки -->
                <UniformGrid Rows="7"
                             Columns="7"
                             Width="170"
                             Height="150"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top"
                             Margin="36 34 0 0"
                             Opacity="0.75">

                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>

                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>

                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>

                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>

                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>

                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>

                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>
                    <Ellipse Width="3" Height="3" Fill="#1E73FF"/>

                </UniformGrid>

                <!-- Основной блок слева -->
                <StackPanel Margin="58 0 36 0"
                            VerticalAlignment="Center">

                    <StackPanel Orientation="Horizontal"
                                Margin="0 0 0 42">

                        <Border Width="64"
                                Height="64"
                                CornerRadius="18"
                                Background="#1E73FF"
                                Margin="0 0 20 0">

                            <materialDesign:PackIcon Kind="Tools"
                                                     Width="34"
                                                     Height="34"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel VerticalAlignment="Center">

                            <TextBlock FontSize="32"
                                       FontWeight="Black">
                                <Run Text="Rental" Foreground="White"/>
                                <Run Text="PRO" Foreground="#1E73FF"/>
                            </TextBlock>

                            <TextBlock Text="Система управления&#10;прокатом инструментов"
                                       Foreground="#AFC8EE"
                                       FontSize="15"
                                       LineHeight="21"
                                       Margin="0 6 0 0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel>

                        <Grid Margin="0 0 0 22">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <materialDesign:PackIcon Kind="AccountGroupOutline"
                                                     Width="25"
                                                     Height="25"
                                                     Foreground="#E6F0FF"/>

                            <TextBlock Grid.Column="1"
                                       Text="Клиенты и контрагенты"
                                       FontSize="17"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0 0 0 22">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <materialDesign:PackIcon Kind="Tools"
                                                     Width="25"
                                                     Height="25"
                                                     Foreground="#E6F0FF"/>

                            <TextBlock Grid.Column="1"
                                       Text="Инструменты и оборудование"
                                       FontSize="17"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0 0 0 22">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <materialDesign:PackIcon Kind="ClipboardTextOutline"
                                                     Width="25"
                                                     Height="25"
                                                     Foreground="#E6F0FF"/>

                            <TextBlock Grid.Column="1"
                                       Text="Заказы и бронирования"
                                       FontSize="17"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0 0 0 22">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <materialDesign:PackIcon Kind="CreditCardOutline"
                                                     Width="25"
                                                     Height="25"
                                                     Foreground="#E6F0FF"/>

                            <TextBlock Grid.Column="1"
                                       Text="Оплаты и возвраты"
                                       FontSize="17"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0 0 0 22">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <materialDesign:PackIcon Kind="ChartBar"
                                                     Width="25"
                                                     Height="25"
                                                     Foreground="#E6F0FF"/>

                            <TextBlock Grid.Column="1"
                                       Text="Отчеты и аналитика"
                                       FontSize="17"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <materialDesign:PackIcon Kind="FileDocumentOutline"
                                                     Width="25"
                                                     Height="25"
                                                     Foreground="#E6F0FF"/>

                            <TextBlock Grid.Column="1"
                                       Text="Документы"
                                       FontSize="17"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </Grid>

                    </StackPanel>
                </StackPanel>

                <!-- Большой шестиугольник -->
                <Path Stroke="#1E73FF"
                      StrokeThickness="1.6"
                      Opacity="0.45"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Margin="0 0 42 70"
                      Data="M 64,0 L 128,37 L 128,111 L 64,148 L 0,111 L 0,37 Z"/>

                <!-- Маленький шестиугольник -->
                <Path Fill="#0D3D89"
                      Opacity="0.9"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Margin="0 0 162 52"
                      Data="M 24,0 L 48,14 L 48,42 L 24,56 L 0,42 L 0,14 Z"/>

            </Grid>
        </Border>

        <!-- Правая часть -->
        <Grid Grid.Column="1"
              Background="#F4F7FC">

            <Border Width="520"
                    Background="White"
                    CornerRadius="24"
                    Padding="40 32"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="30"
                                      ShadowDepth="4"
                                      Opacity="0.13"/>
                </Border.Effect>

                <StackPanel>

                    <TextBlock Text="Вход в систему"
                               FontSize="28"
                               FontWeight="Black"
                               Foreground="#071B39"
                               HorizontalAlignment="Center"
                               Margin="0 0 0 8"/>

                    <TextBlock Text="Введите свои учетные данные для входа"
                               FontSize="15"
                               Foreground="#6B7890"
                               HorizontalAlignment="Center"
                               Margin="0 0 0 30"/>

                    <TextBlock Text="Логин"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#071B39"
                               Margin="0 0 0 8"/>

                    <TextBox Style="{StaticResource LoginInputStyle}"
                             Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0 0 0 20"/>

                    <TextBlock Text="Пароль"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#071B39"
                               Margin="0 0 0 8"/>

                    <Border BorderBrush="#D4DDEA"
                            BorderThickness="1"
                            CornerRadius="10"
                            Background="White"
                            Height="46"
                            Margin="0 0 0 20">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="46"/>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="46"/>
                            </Grid.ColumnDefinitions>

                            <materialDesign:PackIcon Grid.Column="0"
                                                     Kind="LockOutline"
                                                     Width="20"
                                                     Height="20"
                                                     Foreground="#8A97AA"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>

                            <PasswordBox Grid.Column="1"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="15"
                                         VerticalContentAlignment="Center"
                                         common:PasswordBoxAssistant.BindPassword="True"
                                         common:PasswordBoxAssistant.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <materialDesign:PackIcon Grid.Column="2"
                                                     Kind="EyeOutline"
                                                     Width="20"
                                                     Height="20"
                                                     Foreground="#8A97AA"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>

                        </Grid>
                    </Border>

                    <Grid Margin="0 0 0 24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Content="Запомнить меня"
                                  FontSize="14"
                                  Foreground="#071B39"
                                  IsChecked="{Binding RememberMe}"/>

                        <TextBlock Grid.Column="1"
                                   Text="Забыли пароль?"
                                   Foreground="#1E73FF"
                                   FontSize="14"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Cursor="Hand"/>
                    </Grid>

                    <Button Style="{StaticResource LoginButtonStyle}"
                            Command="{Binding LoginCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Login"
                                                     Width="20"
                                                     Height="20"
                                                     Margin="0 0 8 0"/>
                            <TextBlock Text="Войти"/>
                        </StackPanel>
                    </Button>
                    
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#DC2626"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Margin="0 12 0 0"/>

                    <Grid Margin="0 28 0 20">
                        <Separator VerticalAlignment="Center"
                                   Background="#D8E0ED"/>
                        <TextBlock Text="или"
                                   Background="White"
                                   Padding="16 0"
                                   Foreground="#A0ABBD"
                                   FontSize="13"
                                   HorizontalAlignment="Center"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">

                        <materialDesign:PackIcon Kind="ShieldCheckOutline"
                                                 Width="19"
                                                 Height="19"
                                                 Foreground="#6B7890"
                                                 Margin="0 0 8 0"/>

                        <TextBlock FontSize="13"
                                   Foreground="#6B7890">
                            <Run Text="Нет учетной записи? Обратитесь к "/>
                            <Run Text="администратору системы."
                                 Foreground="#1E73FF"/>
                        </TextBlock>
                    </StackPanel>

                </StackPanel>
            </Border>

            <TextBlock Text="© 2026 RentalPRO. Все права защищены."
                       Foreground="#6B7890"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0 0 0 24"/>
        </Grid>
    </Grid>
</Window>