<UserControl x:Class="RentalPro.Presentation.Desktop.Views.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    <UserControl.Resources>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="2"
                                      Opacity="0.08" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource CardStyle}">
            <Setter Property="Margin" Value="0 0 16 16" />
        </Style>

        <Style x:Key="StatTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7890" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="8 0 0 0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#071B39" />
            <Setter Property="FontSize" Value="30" />
            <Setter Property="FontWeight" Value="Black" />
        </Style>

        <Style x:Key="DashboardDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="RowHeight" Value="48" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#071B39" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
        </Style>

        <Style x:Key="PrimaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignRaisedButton}">

            <Setter Property="Background" Value="#071B39" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="18 10" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">

            <Setter Property="Background" Value="#EEF4FF" />
            <Setter Property="Foreground" Value="#1E73FF" />
            <Setter Property="Padding" Value="18 10" />
        </Style>

        <Style x:Key="TertiaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">

            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#6B7890" />
            <Setter Property="Padding" Value="18 10" />
        </Style>

    </UserControl.Resources>
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel>

                <UniformGrid Columns="5"
                             Margin="0 0 0 8">

                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <DockPanel Margin="0 0 0 14">
                                <materialDesign:PackIcon Kind="AccountGroupOutline"
                                                         Width="22"
                                                         Height="22"
                                                         Foreground="#1E73FF" />
                                <TextBlock Text="Всего клиентов"
                                           Style="{StaticResource StatTitleStyle}" />
                            </DockPanel>

                            <TextBlock Text="{Binding TotalCustomers}"
                                       Style="{StaticResource StatValueStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <DockPanel Margin="0 0 0 14">
                                <materialDesign:PackIcon Kind="ReceiptTextOutline"
                                                         Width="22"
                                                         Height="22"
                                                         Foreground="#F97316" />
                                <TextBlock Text="С заказами"
                                           Style="{StaticResource StatTitleStyle}" />
                            </DockPanel>

                            <TextBlock Text="{Binding WithOrdersCount}"
                                       Style="{StaticResource StatValueStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <DockPanel Margin="0 0 0 14">
                                <materialDesign:PackIcon Kind="StarOutline"
                                                         Width="22"
                                                         Height="22"
                                                         Foreground="#7C3AED" />
                                <TextBlock Text="Постоянные"
                                           Style="{StaticResource StatTitleStyle}" />
                            </DockPanel>

                            <TextBlock Text="{Binding RegularCustomersCount}"
                                       Style="{StaticResource StatValueStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <DockPanel Margin="0 0 0 14">
                                <materialDesign:PackIcon Kind="Tools"
                                                         Width="22"
                                                         Height="22"
                                                         Foreground="#16A34A" />
                                <TextBlock Text="Активная аренда"
                                           Style="{StaticResource StatTitleStyle}" />
                            </DockPanel>

                            <TextBlock Text="{Binding WithActiveOrdersCount}"
                                       Style="{StaticResource StatValueStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCardStyle}"
                            Background="#1E73FF">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="Plus"
                                                     Width="28"
                                                     Height="28"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center" />
                            <TextBlock Text="Добавить клиента"
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0 10 0 0" />
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <Border Style="{StaticResource CardStyle}"
                        Margin="0 8 16 0">

                    <StackPanel>

                        <Border Background="Transparent"
                                Padding="0"
                                Margin="0 0 0 22">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                                         Height="48"
                                         materialDesign:HintAssist.Hint="Поиск"
                                         materialDesign:HintAssist.HelperText="ФИО, телефон, email или адрес"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                                <ComboBox Grid.Column="2"
                                          Height="48"
                                          SelectedValue="{Binding OrdersFilter, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          materialDesign:HintAssist.Hint="Заказы"
                                          Style="{StaticResource MaterialDesignFloatingHintComboBox}">
                                    <ComboBoxItem Content="Все" Tag="{x:Null}" />
                                    <ComboBoxItem Content="С заказами" Tag="withOrders" />
                                    <ComboBoxItem Content="Без заказов" Tag="withoutOrders" />
                                </ComboBox>

                                <ComboBox Grid.Column="4"
                                          Height="48"
                                          SelectedValue="{Binding RegularFilter, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          materialDesign:HintAssist.Hint="Постоянные"
                                          Style="{StaticResource MaterialDesignFloatingHintComboBox}">
                                    <ComboBoxItem Content="Все" Tag="{x:Null}" />
                                    <ComboBoxItem Content="Постоянные" Tag="regular" />
                                    <ComboBoxItem Content="Не постоянные" Tag="notRegular" />
                                </ComboBox>

                                <ComboBox Grid.Column="6"
                                          Height="48"
                                          SelectedValue="{Binding ActiveOrdersFilter, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          materialDesign:HintAssist.Hint="Активная аренда"
                                          Style="{StaticResource MaterialDesignFloatingHintComboBox}">
                                    <ComboBoxItem Content="Все" Tag="{x:Null}" />
                                    <ComboBoxItem Content="С активной арендой" Tag="withActiveOrders" />
                                    <ComboBoxItem Content="Без активной аренды" Tag="withoutActiveOrders" />
                                </ComboBox>

                                <Button Grid.Column="8"
                                        Width="42"
                                        Height="42"
                                        VerticalAlignment="Bottom"
                                        Margin="0 0 0 2"
                                        Command="{Binding ResetFiltersCommand}"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="Сбросить фильтры">

                                    <materialDesign:PackIcon Kind="Refresh"
                                                             Width="22"
                                                             Height="22"
                                                             Foreground="#1E73FF" />
                                </Button>
                            </Grid>
                        </Border>

                        <DataGrid ItemsSource="{Binding Customers}"
                                  Style="{StaticResource DashboardDataGridStyle}"
                                  MinHeight="280">

                            <DataGrid.Columns>

                                <DataGridTemplateColumn Header="Клиент" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding FullName}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#071B39"
                                                           TextTrimming="CharacterEllipsis" />

                                                <TextBlock Text="{Binding Address}"
                                                           FontSize="12"
                                                           Foreground="#6B7890"
                                                           Margin="0 3 0 0"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Телефон" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding PhoneNumber}"
                                                       VerticalAlignment="Center" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Email" Width="190">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Email}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Паспорт" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Passport}"
                                                       VerticalAlignment="Center" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Заказов" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding OrdersCount}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Активных" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="8"
                                                    Padding="8 2"
                                                    Height="24"
                                                    HorizontalAlignment="Center"
                                                    Background="#ECFDF5">
                                                <TextBlock Text="{Binding ActiveOrdersCount}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="#15803D" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right"
                                    Margin="24 0 0 0">

                            <Button Width="36"
                                    Height="36"
                                    Command="{Binding PreviousPageCommand}"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    ToolTip="Предыдущая страница">

                                <materialDesign:PackIcon Kind="ChevronLeft"
                                                         Width="20"
                                                         Height="20"/>
                            </Button>

                            <TextBlock VerticalAlignment="Center"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#6B7890"
                                       Margin="12 0">
                                <Run Text="{Binding CurrentPage, Mode=OneWay}"/>
                                <Run Text=" из "/>
                                <Run Text="{Binding TotalPages, Mode=OneWay}"/>
                            </TextBlock>

                            <Button Width="36"
                                    Height="36"
                                    Command="{Binding NextPageCommand}"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    ToolTip="Следующая страница">

                                <materialDesign:PackIcon Kind="ChevronRight"
                                                         Width="20"
                                                         Height="20"/>
                            </Button>

                        </StackPanel>

                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#DC2626"
                           FontSize="14"
                           Margin="0 14 16 0" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>