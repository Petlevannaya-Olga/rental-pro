<UserControl x:Class="RentalPro.Presentation.Desktop.Views.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="PrimaryCardButton"
               TargetType="Button">

            <Setter Property="Background" Value="#1E73FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="72" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="12" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#1664E8" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#0F56C9" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root"
                                        Property="Opacity"
                                        Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">

            <Setter Property="Background" Value="#1E73FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="18 0" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="12" />

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1664E8" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>

                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0F56C9" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="2"
                                      Opacity="0.08" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource CardStyle}">
            <Setter Property="Height" Value="72" />
            <Setter Property="Margin" Value="0 0 12 12" />
            <Setter Property="Padding" Value="16 12" />
        </Style>

        <Style x:Key="StatTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7890" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="8 0 0 0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#071B39" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="DashboardDataGridStyle"
               TargetType="DataGrid"
               BasedOn="{StaticResource MaterialDesignDataGrid}">

            <Setter Property="Background" Value="Transparent" />
            <Setter Property="RowBackground" Value="White" />
            <Setter Property="AlternatingRowBackground" Value="White" />

            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF2F7" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />

            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserSortColumns" Value="True" />
            <Setter Property="IsReadOnly" Value="True" />

            <Setter Property="MinRowHeight" Value="58" />

            <Setter Property="FontSize" Value="13" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />

            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />

            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell"
                           BasedOn="{StaticResource MaterialDesignDataGridCell}">
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                    </Style>
                </Setter.Value>
            </Setter>

            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader"
                           BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CenteredColumnHeaderStyle"
               TargetType="DataGridColumnHeader"
               BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">

            <Setter Property="HorizontalContentAlignment"
                    Value="Center" />

            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="ActionsPopupBoxStyle"
               TargetType="materialDesign:PopupBox">

            <Setter Property="Foreground" Value="#1E73FF" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="ActionsMenuButtonStyle"
               TargetType="Button">

            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="18 0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#F8FAFC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionsDangerButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ActionsMenuButtonStyle}">
            <Setter Property="Foreground" Value="#DC2626" />
        </Style>

        <Style x:Key="DataGridRowHoverStyle"
               TargetType="DataGridRow">

            <Setter Property="Cursor"
                    Value="Hand" />

            <Style.Triggers>

                <Trigger Property="IsMouseOver"
                         Value="True">

                    <Setter Property="Background"
                            Value="#F8FAFC" />

                </Trigger>

            </Style.Triggers>

        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Верхние карточки -->
        <UniformGrid Grid.Row="0"
                     Columns="5"
                     Margin="0 0 0 8">

            <!-- Всего клиентов -->
            <Border Cursor="Hand">

                <Border.Style>
                    <Style TargetType="Border"
                           BasedOn="{StaticResource StatCardStyle}">

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAllStatsSelected}"
                                         Value="True">
                                <Setter Property="Background"
                                        Value="#F3F8FF" />
                            </DataTrigger>
                        </Style.Triggers>

                    </Style>
                </Border.Style>

                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding SelectStatsFilterCommand}"
                                  CommandParameter="all" />
                </Border.InputBindings>

                <StackPanel>
                    <DockPanel Margin="0 0 0 4">
                        <materialDesign:PackIcon Kind="AccountGroupOutline"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="#1E73FF" />

                        <TextBlock Text="Всего клиентов"
                                   Style="{StaticResource StatTitleStyle}" />
                    </DockPanel>

                    <TextBlock Text="{Binding TotalCustomers}"
                               Style="{StaticResource StatValueStyle}" />
                </StackPanel>
            </Border>

            <!-- С заказами -->
            <Border Cursor="Hand">

                <Border.Style>
                    <Style TargetType="Border"
                           BasedOn="{StaticResource StatCardStyle}">

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsWithOrdersStatsSelected}"
                                         Value="True">
                                <Setter Property="Background"
                                        Value="#F3F8FF" />
                            </DataTrigger>
                        </Style.Triggers>

                    </Style>
                </Border.Style>

                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding SelectStatsFilterCommand}"
                                  CommandParameter="withOrders" />
                </Border.InputBindings>

                <StackPanel>
                    <DockPanel Margin="0 0 0 4">
                        <materialDesign:PackIcon Kind="ReceiptTextOutline"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="#F97316" />

                        <TextBlock Text="С заказами"
                                   Style="{StaticResource StatTitleStyle}" />
                    </DockPanel>

                    <TextBlock Text="{Binding WithOrdersCount}"
                               Style="{StaticResource StatValueStyle}" />
                </StackPanel>
            </Border>

            <!-- Постоянные -->
            <Border Cursor="Hand">

                <Border.Style>
                    <Style TargetType="Border"
                           BasedOn="{StaticResource StatCardStyle}">

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRegularStatsSelected}"
                                         Value="True">
                                <Setter Property="Background"
                                        Value="#F3F8FF" />
                            </DataTrigger>
                        </Style.Triggers>

                    </Style>
                </Border.Style>

                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding SelectStatsFilterCommand}"
                                  CommandParameter="regular" />
                </Border.InputBindings>

                <StackPanel>
                    <DockPanel Margin="0 0 0 4">
                        <materialDesign:PackIcon Kind="StarOutline"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="#7C3AED" />

                        <TextBlock Text="Постоянные"
                                   Style="{StaticResource StatTitleStyle}" />
                    </DockPanel>

                    <TextBlock Text="{Binding RegularCustomersCount}"
                               Style="{StaticResource StatValueStyle}" />
                </StackPanel>
            </Border>

            <!-- Активная аренда -->
            <Border Cursor="Hand">

                <Border.Style>
                    <Style TargetType="Border"
                           BasedOn="{StaticResource StatCardStyle}">

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActiveStatsSelected}"
                                         Value="True">
                                <Setter Property="Background"
                                        Value="#F3F8FF" />
                            </DataTrigger>
                        </Style.Triggers>

                    </Style>
                </Border.Style>

                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding SelectStatsFilterCommand}"
                                  CommandParameter="active" />
                </Border.InputBindings>

                <StackPanel>
                    <DockPanel Margin="0 0 0 4">
                        <materialDesign:PackIcon Kind="Tools"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="#16A34A" />

                        <TextBlock Text="Активная аренда"
                                   Style="{StaticResource StatTitleStyle}" />
                    </DockPanel>

                    <TextBlock Text="{Binding WithActiveOrdersCount}"
                               Style="{StaticResource StatValueStyle}" />
                </StackPanel>
            </Border>

            <!-- Добавить клиента -->
            <Button Command="{Binding OpenCreateCustomerCommand}"
                    Style="{StaticResource PrimaryCardButton}"
                    Margin="0 0 12 12">

                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <materialDesign:PackIcon Kind="Plus"
                                             Width="28"
                                             Height="28"
                                             Foreground="White"
                                             HorizontalAlignment="Center" />

                    <TextBlock Text="Добавить клиента"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0 8 0 0" />
                </StackPanel>
            </Button>

        </UniformGrid>

        <!-- Основная карточка -->
        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}"
                Margin="0 8 16 0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Фильтры -->
                <Border Grid.Row="0"
                        Background="Transparent"
                        Padding="0"
                        Margin="12 0 0 16">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                                 Height="48"
                                 materialDesign:HintAssist.Hint="Поиск по ФИО, телефону, email или адресу"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                        <ComboBox Grid.Column="2"
                                  Height="48"
                                  SelectedValue="{Binding OrdersFilter, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Tag"
                                  materialDesign:HintAssist.Hint="Заказы"
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}">

                            <ComboBoxItem Content="Все" Tag="{x:Null}" />
                            <ComboBoxItem Content="С заказами" Tag="withOrders" />
                            <ComboBoxItem Content="Без заказов" Tag="withoutOrders" />
                        </ComboBox>

                        <ComboBox Grid.Column="4"
                                  Height="48"
                                  SelectedValue="{Binding RegularFilter, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Tag"
                                  materialDesign:HintAssist.Hint="Постоянные"
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}">

                            <ComboBoxItem Content="Все" Tag="{x:Null}" />
                            <ComboBoxItem Content="Постоянные" Tag="regular" />
                            <ComboBoxItem Content="Не постоянные" Tag="notRegular" />
                        </ComboBox>

                        <ComboBox Grid.Column="6"
                                  Height="48"
                                  SelectedValue="{Binding ActiveOrdersFilter, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Tag"
                                  materialDesign:HintAssist.Hint="Активная аренда"
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}">

                            <ComboBoxItem Content="Все" Tag="{x:Null}" />
                            <ComboBoxItem Content="С активной арендой" Tag="withActiveOrders" />
                            <ComboBoxItem Content="Без активной аренды" Tag="withoutActiveOrders" />
                        </ComboBox>

                        <Button Grid.Column="8"
                                Width="42"
                                Height="42"
                                VerticalAlignment="Bottom"
                                Margin="0 0 0 2"
                                Command="{Binding ResetFiltersCommand}"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="Сбросить фильтры">

                            <materialDesign:PackIcon Kind="Refresh"
                                                     Width="22"
                                                     Height="22"
                                                     Foreground="#1E73FF" />
                        </Button>
                    </Grid>
                </Border>

                <!-- Таблица -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Customers}"
                          SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
                          Style="{StaticResource DashboardDataGridStyle}"
                          CanUserSortColumns="True"
                          RowStyle="{StaticResource DataGridRowHoverStyle}"
                          materialDesign:DataGridAssist.ApplyMaterialDesignColumnStyles="True">

                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick"
                                      Command="{Binding OpenCustomerDetailsCommand}"
                                      CommandParameter="{Binding SelectedCustomer}" />
                    </DataGrid.InputBindings>

                    <DataGrid.Columns>

                        <DataGridTemplateColumn Header="Клиент"
                                                Width="3*"
                                                MinWidth="320"
                                                SortMemberPath="FullName">

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center"
                                                Margin="4 6">

                                        <TextBlock Text="{Binding FullName}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Foreground="#071B39"
                                                   TextTrimming="CharacterEllipsis" />

                                        <TextBlock Text="{Binding Address}"
                                                   FontSize="12"
                                                   Foreground="#6B7890"
                                                   Margin="0 4 0 0"
                                                   TextWrapping="Wrap"
                                                   HorizontalAlignment="Stretch"
                                                   TextAlignment="Left" />

                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Контакты"
                                                Width="2*"
                                                MinWidth="210"
                                                SortMemberPath="PhoneNumber">

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center"
                                                Margin="4 0">

                                        <TextBlock Text="{Binding PhoneNumber}"
                                                   FontSize="13"
                                                   Foreground="#071B39"
                                                   TextTrimming="CharacterEllipsis" />

                                        <TextBlock Text="{Binding Email}"
                                                   FontSize="12"
                                                   Foreground="#6B7890"
                                                   Margin="0 4 0 0"
                                                   TextTrimming="CharacterEllipsis" />

                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Паспорт"
                                                Width="150"
                                                SortMemberPath="Passport">

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid VerticalAlignment="Stretch">
                                        <TextBlock Text="{Binding Passport}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Всего"
                                                Width="90"
                                                SortMemberPath="OrdersCount">

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <TextBlock Text="{Binding OrdersCount}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               FontSize="14" />

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Активных"
                                                Width="100"
                                                SortMemberPath="ActiveOrdersCount">

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <TextBlock Text="{Binding ActiveOrdersCount}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Foreground="#16A34A"
                                               FontSize="14" />

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="56"
                                                MinWidth="56"
                                                CanUserSort="False">

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <Grid HorizontalAlignment="Center"
                                          VerticalAlignment="Center">

                                        <materialDesign:PopupBox
                                            BorderThickness="0"
                                            Background="Transparent"
                                            PlacementMode="BottomAndAlignRightEdges"
                                            StaysOpen="False">

                                            <materialDesign:PopupBox.ToggleContent>
                                                <materialDesign:PackIcon Kind="DotsVertical"
                                                                         Width="22"
                                                                         Height="22"
                                                                         Foreground="#64748B" />
                                            </materialDesign:PopupBox.ToggleContent>

                                            <Border Width="220"
                                                    Background="White"
                                                    BorderThickness="0"
                                                    CornerRadius="14"
                                                    ClipToBounds="True">

                                                <Grid>

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="1" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <!-- Верхние действия -->
                                                    <StackPanel Grid.Row="0"
                                                                Margin="0 8">

                                                        <Button
                                                            Command="{Binding DataContext.OpenEditCustomerCommand,
                                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource ActionsMenuButtonStyle}">

                                                            <Grid Margin="18 0 16 0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="28" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>

                                                                <materialDesign:PackIcon Grid.Column="0"
                                                                        Kind="PencilOutline"
                                                                        Width="19"
                                                                        Height="19"
                                                                        Foreground="#64748B"
                                                                        VerticalAlignment="Center" />

                                                                <TextBlock Grid.Column="1"
                                                                           Text="Редактировать"
                                                                           FontSize="14"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#334155"
                                                                           VerticalAlignment="Center" />
                                                            </Grid>
                                                        </Button>

                                                        <Button
                                                            Command="{Binding DataContext.OpenOrdersHistoryCommand,
                                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource ActionsMenuButtonStyle}">

                                                            <Grid Margin="18 0 16 0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="28" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>

                                                                <materialDesign:PackIcon Grid.Column="0"
                                                                        Kind="History"
                                                                        Width="19"
                                                                        Height="19"
                                                                        Foreground="#64748B"
                                                                        VerticalAlignment="Center" />

                                                                <TextBlock Grid.Column="1"
                                                                           Text="История заказов"
                                                                           FontSize="14"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#334155"
                                                                           VerticalAlignment="Center" />
                                                            </Grid>
                                                        </Button>

                                                    </StackPanel>

                                                    <!-- Разделитель -->
                                                    <Border Grid.Row="1"
                                                            Height="1"
                                                            Background="#E5EAF2"
                                                            Margin="0" />

                                                    <!-- Удаление -->
                                                    <StackPanel Grid.Row="2"
                                                                Margin="0 8">

                                                        <Button
                                                            Command="{Binding DataContext.DeleteCustomerCommand,
                                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource ActionsDangerButtonStyle}">

                                                            <Grid Margin="18 0 16 0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="28" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>

                                                                <materialDesign:PackIcon Grid.Column="0"
                                                                        Kind="DeleteOutline"
                                                                        Width="19"
                                                                        Height="19"
                                                                        Foreground="#94A3B8"
                                                                        VerticalAlignment="Center" />

                                                                <TextBlock Grid.Column="1"
                                                                           Text="Удалить"
                                                                           FontSize="14"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#DC2626"
                                                                           VerticalAlignment="Center" />
                                                            </Grid>
                                                        </Button>

                                                    </StackPanel>

                                                </Grid>
                                            </Border>

                                        </materialDesign:PopupBox>

                                    </Grid>

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>

                <!-- Экспорт и пагинация -->
                <Grid Grid.Row="2"
                      Margin="12 16 0 0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Левая группа кнопок -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal">

                        <Button Height="40"
                                Padding="16 0"
                                Command="{Binding ExportCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}">

                            <StackPanel Orientation="Horizontal">

                                <materialDesign:PackIcon Kind="FileExcelOutline"
                                                         Width="18"
                                                         Height="18"
                                                         Margin="0 0 8 0" />

                                <TextBlock Text="Экспорт" />

                            </StackPanel>
                        </Button>

                        <Button Height="40"
                                Padding="16 0"
                                Margin="12 0 12 0"
                                Command="{Binding GenerateTestCustomersCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}">

                            <StackPanel Orientation="Horizontal">

                                <materialDesign:PackIcon Kind="DatabasePlusOutline"
                                                         Width="18"
                                                         Height="18"
                                                         Margin="0 0 8 0" />

                                <TextBlock Text="Тестовые данные" />

                            </StackPanel>

                        </Button>

                    </StackPanel>

                    <!-- Пагинация -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <Button Width="36"
                                Height="36"
                                Command="{Binding PreviousPageCommand}"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="Предыдущая страница">

                            <materialDesign:PackIcon Kind="ChevronLeft"
                                                     Width="20"
                                                     Height="20" />
                        </Button>

                        <TextBlock VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#6B7890"
                                   Margin="12 0">

                            <Run Text="{Binding CurrentPage, Mode=OneWay}" />
                            <Run Text=" из " />
                            <Run Text="{Binding TotalPages, Mode=OneWay}" />

                        </TextBlock>

                        <Button Width="36"
                                Height="36"
                                Command="{Binding NextPageCommand}"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="Следующая страница">

                            <materialDesign:PackIcon Kind="ChevronRight"
                                                     Width="20"
                                                     Height="20" />
                        </Button>

                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>