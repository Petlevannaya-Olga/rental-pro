<UserControl x:Class="RentalPro.Presentation.Desktop.Views.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    <UserControl.Resources>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="2"
                                      Opacity="0.08" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource CardStyle}">
            <Setter Property="Height" Value="80" />
            <Setter Property="Margin" Value="0 0 12 12" />
        </Style>

        <Style x:Key="StatTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7890" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="8 0 0 0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#071B39" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="DashboardDataGridStyle"
               TargetType="DataGrid"
               BasedOn="{StaticResource MaterialDesignDataGrid}">

            <Setter Property="Background" Value="Transparent" />
            <Setter Property="RowBackground" Value="White" />
            <Setter Property="AlternatingRowBackground" Value="White" />

            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF2F7" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />

            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserSortColumns" Value="True" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="RowHeight" Value="58" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
        </Style>

    </UserControl.Resources>
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel>

                <UniformGrid Columns="5"
                             Margin="0 0 0 8">

                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <DockPanel Margin="0 0 0 4">
                                <materialDesign:PackIcon Kind="AccountGroupOutline"
                                                         Width="22"
                                                         Height="22"
                                                         Foreground="#1E73FF" />
                                <TextBlock Text="Всего клиентов"
                                           Style="{StaticResource StatTitleStyle}" />
                            </DockPanel>

                            <TextBlock Text="{Binding TotalCustomers}"
                                       Style="{StaticResource StatValueStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <DockPanel Margin="0 0 0 4">
                                <materialDesign:PackIcon Kind="ReceiptTextOutline"
                                                         Width="22"
                                                         Height="22"
                                                         Foreground="#F97316" />
                                <TextBlock Text="С заказами"
                                           Style="{StaticResource StatTitleStyle}" />
                            </DockPanel>

                            <TextBlock Text="{Binding WithOrdersCount}"
                                       Style="{StaticResource StatValueStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <DockPanel Margin="0 0 0 4">
                                <materialDesign:PackIcon Kind="StarOutline"
                                                         Width="22"
                                                         Height="22"
                                                         Foreground="#7C3AED" />
                                <TextBlock Text="Постоянные"
                                           Style="{StaticResource StatTitleStyle}" />
                            </DockPanel>

                            <TextBlock Text="{Binding RegularCustomersCount}"
                                       Style="{StaticResource StatValueStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <DockPanel Margin="0 0 0 4">
                                <materialDesign:PackIcon Kind="Tools"
                                                         Width="22"
                                                         Height="22"
                                                         Foreground="#16A34A" />
                                <TextBlock Text="Активная аренда"
                                           Style="{StaticResource StatTitleStyle}" />
                            </DockPanel>

                            <TextBlock Text="{Binding WithActiveOrdersCount}"
                                       Style="{StaticResource StatValueStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCardStyle}"
                            Background="#1E73FF">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="Plus"
                                                     Width="28"
                                                     Height="28"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center" />
                            <TextBlock Text="Добавить клиента"
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0 10 0 0" />
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <Border Style="{StaticResource CardStyle}"
                        Margin="0 8 16 0">

                    <StackPanel>

                        <Border Background="Transparent"
                                Padding="0"
                                Margin="0 0 0 22">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                                         Height="48"
                                         materialDesign:HintAssist.Hint="Поиск по ФИО, телефону, email или адресу"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                                <ComboBox Grid.Column="2"
                                          Height="48"
                                          SelectedValue="{Binding OrdersFilter, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          materialDesign:HintAssist.Hint="Заказы"
                                          Style="{StaticResource MaterialDesignFloatingHintComboBox}">
                                    <ComboBoxItem Content="Все" Tag="{x:Null}" />
                                    <ComboBoxItem Content="С заказами" Tag="withOrders" />
                                    <ComboBoxItem Content="Без заказов" Tag="withoutOrders" />
                                </ComboBox>

                                <ComboBox Grid.Column="4"
                                          Height="48"
                                          SelectedValue="{Binding RegularFilter, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          materialDesign:HintAssist.Hint="Постоянные"
                                          Style="{StaticResource MaterialDesignFloatingHintComboBox}">
                                    <ComboBoxItem Content="Все" Tag="{x:Null}" />
                                    <ComboBoxItem Content="Постоянные" Tag="regular" />
                                    <ComboBoxItem Content="Не постоянные" Tag="notRegular" />
                                </ComboBox>

                                <ComboBox Grid.Column="6"
                                          Height="48"
                                          SelectedValue="{Binding ActiveOrdersFilter, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          materialDesign:HintAssist.Hint="Активная аренда"
                                          Style="{StaticResource MaterialDesignFloatingHintComboBox}">
                                    <ComboBoxItem Content="Все" Tag="{x:Null}" />
                                    <ComboBoxItem Content="С активной арендой" Tag="withActiveOrders" />
                                    <ComboBoxItem Content="Без активной аренды" Tag="withoutActiveOrders" />
                                </ComboBox>

                                <Button Grid.Column="8"
                                        Width="42"
                                        Height="42"
                                        VerticalAlignment="Bottom"
                                        Margin="0 0 0 2"
                                        Command="{Binding ResetFiltersCommand}"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="Сбросить фильтры">

                                    <materialDesign:PackIcon Kind="Refresh"
                                                             Width="22"
                                                             Height="22"
                                                             Foreground="#1E73FF" />
                                </Button>
                            </Grid>
                        </Border>

                        <DataGrid ItemsSource="{Binding Customers}"
                                  Style="{StaticResource DashboardDataGridStyle}"
                                  MinHeight="280"
                                  CanUserSortColumns="True"
                                  materialDesign:DataGridAssist.ApplyMaterialDesignColumnStyles="True">

                            <DataGrid.Columns>

                                <DataGridTemplateColumn Header="Клиент"
                                                        Width="3*"
                                                        MinWidth="360"
                                                        SortMemberPath="FullName">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center"
                                                        Margin="4 0">
                                                <TextBlock Text="{Binding FullName}"
                                                           FontWeight="SemiBold"
                                                           FontSize="14"
                                                           Foreground="#071B39"
                                                           TextTrimming="CharacterEllipsis" />

                                                <TextBlock Text="{Binding Address}"
                                                           FontSize="12"
                                                           Foreground="#6B7890"
                                                           Margin="0 4 0 0"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Телефон"
                                                    Binding="{Binding PhoneNumber}"
                                                    Width="170"
                                                    SortMemberPath="PhoneNumber" />

                                <DataGridTextColumn Header="Email"
                                                    Binding="{Binding Email}"
                                                    Width="220"
                                                    SortMemberPath="Email" />

                                <DataGridTextColumn Header="Паспорт"
                                                    Binding="{Binding Passport}"
                                                    Width="150"
                                                    SortMemberPath="Passport" />

                                <DataGridTextColumn Header="Заказов"
                                                    Binding="{Binding OrdersCount}"
                                                    Width="105"
                                                    SortMemberPath="OrdersCount" />

                                <DataGridTemplateColumn Header="Активных"
                                                        Width="120"
                                                        SortMemberPath="ActiveOrdersCount">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10"
                                                    Padding="10 2"
                                                    Height="28"
                                                    MinWidth="38"
                                                    HorizontalAlignment="Center"
                                                    Background="#DCFCE7">
                                                <TextBlock Text="{Binding ActiveOrdersCount}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="#15803D"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Width="76"
                                                        MinWidth="76"
                                                        CanUserSort="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Width="40"
                                                    Height="40"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Style="{StaticResource MaterialDesignIconButton}"
                                                    ToolTip="Действия">
                                                <materialDesign:PackIcon Kind="DotsVertical"
                                                                         Width="22"
                                                                         Height="22"
                                                                         Foreground="#1E73FF" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>

                        <Grid Margin="0 20 0 0">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Экспорт -->
                            <Button Grid.Column="0"
                                    Height="40"
                                    Padding="16 0"
                                    Command="{Binding ExportCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}">

                                <StackPanel Orientation="Horizontal">

                                    <materialDesign:PackIcon Kind="FileExcelOutline"
                                                             Width="18"
                                                             Height="18"
                                                             Margin="0 0 8 0" />

                                    <TextBlock Text="Экспорт" />
                                </StackPanel>
                            </Button>

                            <!-- Пагинация -->
                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">

                                <Button Width="36"
                                        Height="36"
                                        Command="{Binding PreviousPageCommand}"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="Предыдущая страница">

                                    <materialDesign:PackIcon Kind="ChevronLeft"
                                                             Width="20"
                                                             Height="20" />
                                </Button>

                                <TextBlock VerticalAlignment="Center"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#6B7890"
                                           Margin="12 0">

                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#6B7890"
                                               Margin="12 0">

                                        <Run Text="{Binding CurrentPage, Mode=OneWay}" />
                                        <Run Text=" из " />
                                        <Run Text="{Binding TotalPages, Mode=OneWay}" />

                                    </TextBlock>

                                </TextBlock>

                                <Button Width="36"
                                        Height="36"
                                        Command="{Binding NextPageCommand}"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="Следующая страница">

                                    <materialDesign:PackIcon Kind="ChevronRight"
                                                             Width="20"
                                                             Height="20" />
                                </Button>

                            </StackPanel>

                        </Grid>

                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#DC2626"
                           FontSize="14"
                           Margin="0 14 16 0" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>