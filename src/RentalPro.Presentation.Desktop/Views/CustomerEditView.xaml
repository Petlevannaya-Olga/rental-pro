<UserControl x:Class="RentalPro.Presentation.Desktop.Views.CustomerEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F7F9FC">

    <UserControl.Resources>

        <Style x:Key="FormCardStyle"
               TargetType="Border">

            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="24" />

            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10"
                                      ShadowDepth="1"
                                      Opacity="0.05" />
                </Setter.Value>
            </Setter>

        </Style>

        <Style x:Key="PrimaryActionButtonStyle"
               TargetType="Button">

            <Setter Property="Background" Value="#1E73FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="24 0" />

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#1664E8" />
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">

                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#0F56C9" />
                            </Trigger>

                            <Trigger Property="IsEnabled"
                                     Value="False">

                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#AFC9FF" />

                                <Setter Property="Foreground"
                                        Value="White" />
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

    </UserControl.Resources>

    <Grid Margin="20 0 20 20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Назад -->
        <Button Grid.Row="0"
                HorizontalAlignment="Left"
                Command="{Binding BackCommand}"
                Background="Transparent"
                BorderThickness="0"
                Padding="0"
                Margin="0 0 0 16"
                Cursor="Hand">

            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="Transparent">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Button.Template>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <materialDesign:PackIcon Grid.Column="0"
                                         Kind="ArrowLeft"
                                         Width="24"
                                         Height="24"
                                         Margin="0 0 10 0"
                                         VerticalAlignment="Center"
                                         Foreground="#1E73FF" />

                <TextBlock Grid.Column="1"
                           Text="Назад к списку клиентов"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#6B7890" />

            </Grid>

        </Button>

        <!-- Скроллится только форма -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Данные клиента -->
                <Border Grid.Row="0"
                        Style="{StaticResource FormCardStyle}"
                        Margin="0 0 12 0">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal">

                            <materialDesign:PackIcon Kind="AccountOutline"
                                                     Width="24"
                                                     Height="24"
                                                     Foreground="#1E73FF"
                                                     Margin="0 0 12 0" />

                            <TextBlock Text="Данные клиента"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#17233A" />

                        </StackPanel>

                        <Grid Grid.Row="2">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0"
                                     Grid.Column="0"
                                     Text="{Binding Customer.LastName, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Фамилия"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="0"
                                     Grid.Column="2"
                                     Text="{Binding Customer.FirstName, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Имя"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="0"
                                     Grid.Column="4"
                                     Text="{Binding Customer.MiddleName, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Отчество"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="2"
                                     Grid.Column="0"
                                     Text="{Binding Customer.PhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Телефон"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="2"
                                     Grid.Column="2"
                                     Text="{Binding Customer.Email, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Email"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="4"
                                     Grid.Column="0"
                                     Text="{Binding Customer.PassportSeries, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Серия паспорта"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="4"
                                     Grid.Column="2"
                                     Text="{Binding Customer.PassportNumber, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Номер паспорта"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                        </Grid>

                    </Grid>

                </Border>

                <!-- Адрес -->
                <Border Grid.Row="2"
                        Style="{StaticResource FormCardStyle}"
                        Margin="0 0 12 0">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal">

                            <materialDesign:PackIcon Kind="MapMarkerOutline"
                                                     Width="24"
                                                     Height="24"
                                                     Foreground="#1E73FF"
                                                     Margin="0 0 12 0" />

                            <TextBlock Text="Адрес"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#17233A" />

                        </StackPanel>

                        <Grid Grid.Row="2">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0"
                                     Grid.Column="0"
                                     Text="{Binding Customer.PostalCode, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Индекс"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="0"
                                     Grid.Column="2"
                                     Text="{Binding Customer.Region, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Регион"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="0"
                                     Grid.Column="4"
                                     Text="{Binding Customer.City, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Город"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="2"
                                     Grid.Column="0"
                                     Text="{Binding Customer.Street, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Улица"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="2"
                                     Grid.Column="2"
                                     Text="{Binding Customer.House, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Дом"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="2"
                                     Grid.Column="4"
                                     Text="{Binding Customer.Building, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Корпус"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="4"
                                     Grid.Column="0"
                                     Text="{Binding Customer.Apartment, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Квартира/офис"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                        </Grid>

                    </Grid>

                </Border>

            </Grid>

        </ScrollViewer>

        <!-- Нижняя панель -->
        <Grid Grid.Row="2"
              Margin="0 22 0 0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="28" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding ErrorMessage}"
                       Foreground="#DC2626"
                       FontSize="13"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       TextWrapping="Wrap" />

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button Content="Отмена"
                        Height="40"
                        Padding="20 0"
                        Command="{Binding BackCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" />

                <Button Height="40"
                        Padding="16 0"
                        Margin="12 0 12 0"
                        Command="{Binding FillTestDataCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}">

                    <StackPanel Orientation="Horizontal">

                        <materialDesign:PackIcon Kind="DatabasePlusOutline"
                                                 Width="18"
                                                 Height="18"
                                                 Margin="0 0 8 0" />

                        <TextBlock Text="Тестовые данные" />

                    </StackPanel>

                </Button>

                <Button Height="40"
                        MinWidth="180"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Padding="24 0"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryActionButtonStyle}">

                    <StackPanel Orientation="Horizontal">

                        <materialDesign:PackIcon Kind="Check"
                                                 Width="20"
                                                 Height="20"
                                                 Margin="0 0 8 0" />

                        <TextBlock Text="{Binding SaveButtonText}" />

                    </StackPanel>

                </Button>

            </StackPanel>

        </Grid>

    </Grid>

</UserControl>