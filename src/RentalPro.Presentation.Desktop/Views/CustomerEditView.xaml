<UserControl x:Class="RentalPro.Presentation.Desktop.Views.CustomerEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F7F9FC">

    <UserControl.Resources>

        <Style x:Key="FormCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFD" />
            <Setter Property="BorderBrush" Value="#DDE6F2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="22" />
        </Style>

        <Style x:Key="PrimaryActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Background" Value="#1E73FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Padding" Value="22 0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="12" />
        </Style>

    </UserControl.Resources>

    <Grid Margin="20 12 20 20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Назад -->
        <Button Grid.Row="0"
                HorizontalAlignment="Left"
                Command="{Binding BackCommand}"
                Style="{StaticResource MaterialDesignFlatButton}"
                Padding="0"
                Margin="0 0 0 16">

            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="ArrowLeft"
                                         Width="24"
                                         Height="24"
                                         Margin="0 0 8 0"
                                         Foreground="#1E73FF" />

                <TextBlock Text="Назад к списку клиентов"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#6B7890" />
            </StackPanel>
        </Button>

        <!-- Скроллится только форма -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Данные клиента -->
                <Border Grid.Row="0"
                        Style="{StaticResource FormCardStyle}">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="1" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    Margin="0 0 0 16">

                            <materialDesign:PackIcon Kind="AccountOutline"
                                                     Width="24"
                                                     Height="24"
                                                     Foreground="#1E73FF"
                                                     Margin="0 0 12 0" />

                            <TextBlock Text="Данные клиента"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#17233A" />
                        </StackPanel>

                        <Border Grid.Row="1"
                                Height="1"
                                Background="#DDE6F2" />

                        <Grid Grid.Row="3">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0"
                                     Grid.Column="0"
                                     Text="{Binding Customer.LastName, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Фамилия"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="0"
                                     Grid.Column="2"
                                     Text="{Binding Customer.FirstName, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Имя"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="0"
                                     Grid.Column="4"
                                     Text="{Binding Customer.MiddleName, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Отчество"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="2"
                                     Grid.Column="0"
                                     Text="{Binding Customer.PhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Телефон"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="2"
                                     Grid.Column="2"
                                     Text="{Binding Customer.Email, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Email"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="4"
                                     Grid.Column="0"
                                     Text="{Binding Customer.PassportSeries, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Серия паспорта"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="4"
                                     Grid.Column="2"
                                     Text="{Binding Customer.PassportNumber, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Номер паспорта"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                        </Grid>
                    </Grid>
                </Border>

                <!-- Адрес -->
                <Border Grid.Row="2"
                        Style="{StaticResource FormCardStyle}">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="1" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    Margin="0 0 0 16">

                            <materialDesign:PackIcon Kind="MapMarkerOutline"
                                                     Width="24"
                                                     Height="24"
                                                     Foreground="#1E73FF"
                                                     Margin="0 0 12 0" />

                            <TextBlock Text="Адрес"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#17233A" />
                        </StackPanel>

                        <Border Grid.Row="1"
                                Height="1"
                                Background="#DDE6F2" />

                        <Grid Grid.Row="3">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0"
                                     Grid.Column="0"
                                     Text="{Binding Customer.PostalCode, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Индекс"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="0"
                                     Grid.Column="2"
                                     Text="{Binding Customer.Region, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Регион"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="0"
                                     Grid.Column="4"
                                     Text="{Binding Customer.City, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Город"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="2"
                                     Grid.Column="0"
                                     Text="{Binding Customer.Street, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Улица"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="2"
                                     Grid.Column="2"
                                     Text="{Binding Customer.House, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Дом"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="2"
                                     Grid.Column="4"
                                     Text="{Binding Customer.Building, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Корпус"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                            <TextBox Grid.Row="4"
                                     Grid.Column="0"
                                     Grid.ColumnSpan="1"
                                     Text="{Binding Customer.Apartment, UpdateSourceTrigger=PropertyChanged}"
                                     Height="48"
                                     materialDesign:HintAssist.Hint="Квартира/офис"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                        </Grid>
                    </Grid>
                </Border>

            </Grid>
        </ScrollViewer>

        <!-- Нижняя панель -->
        <Grid Grid.Row="2"
              Margin="0 22 0 0">

            <Grid.RowDefinitions>
                <RowDefinition Height="1" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#DDE6F2" />

            <TextBlock Grid.Row="2"
                       Text="{Binding ErrorMessage}"
                       Foreground="#DC2626"
                       FontSize="13"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       TextWrapping="Wrap" />

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button Content="Отмена"
                        Height="48"
                        Padding="20 0"
                        Margin="0 0 12 0"
                        Command="{Binding BackCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" />

                <Button Height="48"
                        Padding="20 0"
                        Margin="0 0 12 0"
                        Command="{Binding FillTestDataCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}">

                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="MagicWand"
                                                 Width="20"
                                                 Height="20"
                                                 Margin="0 0 8 0" />

                        <TextBlock Text="Заполнить тестовыми данными" />
                    </StackPanel>
                </Button>

                <Button Height="48"
                        Padding="24 0"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryActionButtonStyle}">

                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Check"
                                                 Width="20"
                                                 Height="20"
                                                 Margin="0 0 8 0"
                                                 Foreground="White" />

                        <TextBlock Text="{Binding SaveButtonText}" />
                    </StackPanel>
                </Button>

            </StackPanel>
        </Grid>

    </Grid>
</UserControl>