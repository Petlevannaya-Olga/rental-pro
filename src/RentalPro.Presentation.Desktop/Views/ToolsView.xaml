<UserControl x:Class="RentalPro.Presentation.Desktop.Views.ToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <UserControl.Resources>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="2"
                                      Opacity="0.08" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource CardStyle}">
            <Setter Property="Height" Value="72" />
            <Setter Property="Margin" Value="0 0 12 12" />
            <Setter Property="Padding" Value="16 12" />
        </Style>

        <Style x:Key="StatTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7890" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="8 0 0 0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#071B39" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="ToolsDataGridStyle"
               TargetType="DataGrid"
               BasedOn="{StaticResource MaterialDesignDataGrid}">

            <Setter Property="Background" Value="Transparent" />
            <Setter Property="RowBackground" Value="White" />
            <Setter Property="AlternatingRowBackground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF2F7" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserSortColumns" Value="True" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="MinRowHeight" Value="64" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="ActionsMenuButtonStyle"
               TargetType="Button">

            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="18 0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#F8FAFC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionsDangerButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ActionsMenuButtonStyle}">
            <Setter Property="Foreground" Value="#DC2626" />
        </Style>

        <Style x:Key="CenteredCellTextStyle"
               TargetType="TextBlock">
            <Setter Property="HorizontalAlignment"
                    Value="Left" />
            <Setter Property="TextAlignment"
                    Value="Center" />
            <Setter Property="VerticalAlignment"
                    Value="Center" />
        </Style>

        <Style x:Key="PrimaryCardButton"
               TargetType="Button">

            <Setter Property="Background" Value="#1E73FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="72" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="12" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#1664E8" />

                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">

                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#0F56C9" />

                            </Trigger>

                            <Trigger Property="IsEnabled"
                                     Value="False">

                                <Setter TargetName="Root"
                                        Property="Opacity"
                                        Value="0.55" />

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Карточки -->
        <UniformGrid Grid.Row="0"
                     Columns="5"
                     Margin="0 0 0 8">

            <!-- Всего -->
            <Border Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource StatCardStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAllStatsSelected}" Value="True">
                                <Setter Property="Background" Value="#EAF3FF" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding SelectStatsFilterCommand}"
                                  CommandParameter="all" />
                </Border.InputBindings>

                <StackPanel>
                    <DockPanel Margin="0 0 0 4">
                        <materialDesign:PackIcon Kind="Tools"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="#1E73FF" />
                        <TextBlock Text="Всего инструментов"
                                   Style="{StaticResource StatTitleStyle}" />
                    </DockPanel>

                    <TextBlock Text="{Binding TotalTools}"
                               Style="{StaticResource StatValueStyle}" />
                </StackPanel>
            </Border>

            <!-- Доступно -->
            <Border Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource StatCardStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAvailableStatsSelected}" Value="True">
                                <Setter Property="Background" Value="#EAF3FF" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding SelectStatsFilterCommand}"
                                  CommandParameter="available" />
                </Border.InputBindings>

                <StackPanel>
                    <DockPanel Margin="0 0 0 4">
                        <materialDesign:PackIcon Kind="CheckCircleOutline"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="#16A34A" />
                        <TextBlock Text="Доступно"
                                   Style="{StaticResource StatTitleStyle}" />
                    </DockPanel>

                    <TextBlock Text="{Binding AvailableCount}"
                               Style="{StaticResource StatValueStyle}" />
                </StackPanel>
            </Border>

            <!-- В аренде -->
            <Border Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource StatCardStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRentedStatsSelected}" Value="True">
                                <Setter Property="Background" Value="#EAF3FF" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding SelectStatsFilterCommand}"
                                  CommandParameter="rented" />
                </Border.InputBindings>

                <StackPanel>
                    <DockPanel Margin="0 0 0 4">
                        <materialDesign:PackIcon Kind="SwapHorizontal"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="#F97316" />
                        <TextBlock Text="В аренде"
                                   Style="{StaticResource StatTitleStyle}" />
                    </DockPanel>

                    <TextBlock Text="{Binding RentedCount}"
                               Style="{StaticResource StatValueStyle}" />
                </StackPanel>
            </Border>

            <!-- На ремонте -->
            <Border Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource StatCardStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRepairStatsSelected}" Value="True">
                                <Setter Property="Background" Value="#EAF3FF" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding SelectStatsFilterCommand}"
                                  CommandParameter="repair" />
                </Border.InputBindings>

                <StackPanel>
                    <DockPanel Margin="0 0 0 4">
                        <materialDesign:PackIcon Kind="WrenchOutline"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="#DC2626" />
                        <TextBlock Text="На ремонте"
                                   Style="{StaticResource StatTitleStyle}" />
                    </DockPanel>

                    <TextBlock Text="{Binding RepairCount}"
                               Style="{StaticResource StatValueStyle}" />
                </StackPanel>
            </Border>

            <!-- Добавить -->
            <Button Command="{Binding OpenCreateToolCommand}"
                    Style="{StaticResource PrimaryCardButton}"
                    Margin="0 0 12 12">

                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Plus"
                                             Width="28"
                                             Height="28"
                                             Foreground="White"
                                             HorizontalAlignment="Center" />

                    <TextBlock Text="Добавить инструмент"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0 8 0 0" />
                </StackPanel>
            </Button>

        </UniformGrid>

        <!-- Основная карточка -->
        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}"
                Margin="0 8 16 0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Фильтры -->
                <Grid Grid.Row="0"
                      Margin="12 0 0 16">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                             Height="48"
                             materialDesign:HintAssist.Hint="Название, инвентарный или серийный номер"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                    <ComboBox Grid.Column="2"
                              Height="48"
                              ItemsSource="{Binding Categories}"
                              SelectedValue="{Binding CategoryId, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              materialDesign:HintAssist.Hint="Категория"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}" />

                    <ComboBox Grid.Column="4"
                              Height="48"
                              ItemsSource="{Binding Statuses}"
                              SelectedValue="{Binding StatusId, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              materialDesign:HintAssist.Hint="Статус"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}" />

                    <ComboBox Grid.Column="6"
                              Height="48"
                              ItemsSource="{Binding Manufacturers}"
                              SelectedValue="{Binding ManufacturerId, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              materialDesign:HintAssist.Hint="Производитель"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}" />

                    <Button Grid.Column="8"
                            Width="42"
                            Height="42"
                            VerticalAlignment="Bottom"
                            Margin="0 0 0 2"
                            Command="{Binding ResetFiltersCommand}"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="Сбросить фильтры">

                        <materialDesign:PackIcon Kind="Refresh"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="#1E73FF" />
                    </Button>
                </Grid>

                <!-- Таблица -->
                <DataGrid Grid.Row="1"
                          Sorting="ToolsDataGrid_OnSorting"
                          ItemsSource="{Binding Tools}"
                          SelectedItem="{Binding SelectedTool, Mode=TwoWay}"
                          Style="{StaticResource ToolsDataGridStyle}">
                    
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick"
                                      Command="{Binding OpenViewToolCommand}"
                                      CommandParameter="{Binding SelectedTool}" />
                    </DataGrid.InputBindings>

                    <DataGrid.Columns>

                        <DataGridTemplateColumn Width="80"
                                                CanUserSort="False">

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <Border Width="56"
                                            Height="56"
                                            CornerRadius="10"
                                            Background="#F8FAFC"
                                            BorderBrush="#E5EAF2"
                                            BorderThickness="1"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">

                                        <Grid>

                                            <Image Source="{Binding FullPhotoUrl}"
                                                   Stretch="UniformToFill" />

                                            <materialDesign:PackIcon Kind="ImageOutline"
                                                                     Width="48"
                                                                     Height="48"
                                                                     Foreground="#CBD5E1"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center">
                                                <materialDesign:PackIcon.Style>
                                                    <Style TargetType="materialDesign:PackIcon">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed" />

                                                        <Style.Triggers>

                                                            <DataTrigger Binding="{Binding FullPhotoUrl}"
                                                                         Value="">
                                                                <Setter Property="Visibility"
                                                                        Value="Visible" />
                                                            </DataTrigger>

                                                            <DataTrigger Binding="{Binding FullPhotoUrl}"
                                                                         Value="{x:Null}">
                                                                <Setter Property="Visibility"
                                                                        Value="Visible" />
                                                            </DataTrigger>

                                                        </Style.Triggers>
                                                    </Style>
                                                </materialDesign:PackIcon.Style>
                                            </materialDesign:PackIcon>
                                        </Grid>

                                    </Border>

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Инструмент"
                                                Width="2.8*"
                                                SortMemberPath="Name">

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <StackPanel VerticalAlignment="Center"
                                                Margin="4 4">

                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Foreground="#071B39"
                                                   TextTrimming="CharacterEllipsis" />

                                        <TextBlock Text="{Binding InventoryNumber}"
                                                   FontSize="12"
                                                   Foreground="#6B7890"
                                                   Margin="0 3 0 0"
                                                   TextTrimming="CharacterEllipsis" />

                                        <TextBlock Text="{Binding SerialNumber}"
                                                   FontSize="12"
                                                   Foreground="#94A3B8"
                                                   Margin="0 2 0 0"
                                                   TextTrimming="CharacterEllipsis" />

                                    </StackPanel>

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Категория"
                                            Binding="{Binding CategoryName}"
                                            ElementStyle="{StaticResource CenteredCellTextStyle}"
                                            Width="1.4*" />

                        <DataGridTextColumn Header="Производитель"
                                            Binding="{Binding ManufacturerName}"
                                            ElementStyle="{StaticResource CenteredCellTextStyle}"
                                            Width="1.4*" />

                        <DataGridTextColumn Header="Аренда/день"
                                            Binding="{Binding RentalPricePerDay, StringFormat={}{0:N0} ₽}"
                                            ElementStyle="{StaticResource CenteredCellTextStyle}"
                                            Width="130" />

                        <DataGridTextColumn Header="Залог"
                                            Binding="{Binding DepositAmount, StringFormat={}{0:N0} ₽}"
                                            ElementStyle="{StaticResource CenteredCellTextStyle}"
                                            Width="120" />

                        <DataGridTemplateColumn Header="Статус"
                                                Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="14"
                                            Padding="12 6"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">

                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F1F5F9" />

                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusName}" Value="Доступен">
                                                        <Setter Property="Background" Value="#DCFCE7" />
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding StatusName}" Value="В аренде">
                                                        <Setter Property="Background" Value="#DBEAFE" />
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding StatusName}" Value="На ремонте">
                                                        <Setter Property="Background" Value="#FEE2E2" />
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding StatusName}" Value="Забронирован">
                                                        <Setter Property="Background" Value="#FEF3C7" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <TextBlock Text="{Binding StatusName}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13">

                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#64748B" />

                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusName}" Value="Доступен">
                                                            <Setter Property="Foreground" Value="#16A34A" />
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding StatusName}" Value="В аренде">
                                                            <Setter Property="Foreground" Value="#2563EB" />
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding StatusName}" Value="На ремонте">
                                                            <Setter Property="Foreground" Value="#DC2626" />
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding StatusName}"
                                                                     Value="Забронирован">
                                                            <Setter Property="Foreground" Value="#D97706" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="56"
                                                MinWidth="56"
                                                CanUserSort="False">

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <Grid HorizontalAlignment="Center"
                                          VerticalAlignment="Center">

                                        <materialDesign:PopupBox
                                            BorderThickness="0"
                                            Background="Transparent"
                                            PlacementMode="BottomAndAlignRightEdges"
                                            StaysOpen="False">

                                            <materialDesign:PopupBox.ToggleContent>
                                                <materialDesign:PackIcon Kind="DotsVertical"
                                                                         Width="22"
                                                                         Height="22"
                                                                         Foreground="#64748B" />
                                            </materialDesign:PopupBox.ToggleContent>

                                            <Border Width="240"
                                                    Background="White"
                                                    CornerRadius="14">

                                                <Grid>

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="1" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <!-- Основные действия -->
                                                    <StackPanel Grid.Row="0"
                                                                Margin="0 8">

                                                        <Button
                                                            Command="{Binding DataContext.OpenViewToolCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource ActionsMenuButtonStyle}">

                                                            <Grid Margin="18 0 16 0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="28" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>

                                                                <materialDesign:PackIcon Grid.Column="0"
                                                                        Kind="EyeOutline"
                                                                        Width="19"
                                                                        Height="19"
                                                                        Foreground="#64748B" />

                                                                <TextBlock Grid.Column="1"
                                                                           Text="Просмотр"
                                                                           FontSize="14"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#334155" />
                                                            </Grid>
                                                        </Button>

                                                        <Button
                                                            Command="{Binding DataContext.OpenEditToolCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource ActionsMenuButtonStyle}">

                                                            <Grid Margin="18 0 16 0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="28" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>

                                                                <materialDesign:PackIcon Grid.Column="0"
                                                                        Kind="PencilOutline"
                                                                        Width="19"
                                                                        Height="19"
                                                                        Foreground="#64748B" />

                                                                <TextBlock Grid.Column="1"
                                                                           Text="Редактировать"
                                                                           FontSize="14"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#334155" />
                                                            </Grid>
                                                        </Button>

                                                        <Button
                                                            Command="{Binding DataContext.OpenRentalHistoryCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource ActionsMenuButtonStyle}">

                                                            <Grid Margin="18 0 16 0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="28" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>

                                                                <materialDesign:PackIcon Grid.Column="0"
                                                                        Kind="History"
                                                                        Width="19"
                                                                        Height="19"
                                                                        Foreground="#64748B" />

                                                                <TextBlock Grid.Column="1"
                                                                           Text="История аренды"
                                                                           FontSize="14"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#334155" />
                                                            </Grid>
                                                        </Button>

                                                    </StackPanel>

                                                    <Border Grid.Row="1"
                                                            Height="1"
                                                            Background="#E5EAF2" />

                                                    <!-- Нижние действия -->
                                                    <StackPanel Grid.Row="2"
                                                                Margin="0 8">

                                                        <Button
                                                            Command="{Binding DataContext.MoveToRepairCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource ActionsMenuButtonStyle}">

                                                            <Grid Margin="18 0 16 0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="28" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>

                                                                <materialDesign:PackIcon Grid.Column="0"
                                                                        Kind="WrenchOutline"
                                                                        Width="19"
                                                                        Height="19"
                                                                        Foreground="#64748B" />

                                                                <TextBlock Grid.Column="1"
                                                                           Text="Перевести в ремонт"
                                                                           FontSize="14"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#334155" />
                                                            </Grid>
                                                        </Button>

                                                        <Button
                                                            Command="{Binding DataContext.DeleteToolCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource ActionsDangerButtonStyle}">

                                                            <Grid Margin="18 0 16 0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="28" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>

                                                                <materialDesign:PackIcon Grid.Column="0"
                                                                        Kind="DeleteOutline"
                                                                        Width="19"
                                                                        Height="19"
                                                                        Foreground="#94A3B8" />

                                                                <TextBlock Grid.Column="1"
                                                                           Text="Удалить"
                                                                           FontSize="14"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#DC2626" />
                                                            </Grid>
                                                        </Button>

                                                    </StackPanel>

                                                </Grid>

                                            </Border>

                                        </materialDesign:PopupBox>

                                    </Grid>

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>

                <!-- Низ -->
                <Grid Grid.Row="2"
                      Margin="12 16 0 0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal">

                        <Button Height="40"
                                Padding="16 0"
                                Command="{Binding ExportCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileExcelOutline"
                                                         Width="18"
                                                         Height="18"
                                                         Margin="0 0 8 0" />
                                <TextBlock Text="Экспорт" />
                            </StackPanel>
                        </Button>

                        <Button Height="40"
                                Padding="16 0"
                                Margin="12 0 12 0"
                                Command="{Binding GenerateTestToolsCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="DatabasePlusOutline"
                                                         Width="18"
                                                         Height="18"
                                                         Margin="0 0 8 0" />
                                <TextBlock Text="Тестовые данные" />
                            </StackPanel>
                        </Button>

                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <Button Width="36"
                                Height="36"
                                Command="{Binding PreviousPageCommand}"
                                Style="{StaticResource MaterialDesignIconButton}">
                            <materialDesign:PackIcon Kind="ChevronLeft"
                                                     Width="20"
                                                     Height="20" />
                        </Button>

                        <TextBlock VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#6B7890"
                                   Margin="12 0">
                            <Run Text="{Binding CurrentPage, Mode=OneWay}" />
                            <Run Text=" из " />
                            <Run Text="{Binding TotalPages, Mode=OneWay}" />
                        </TextBlock>

                        <Button Width="36"
                                Height="36"
                                Command="{Binding NextPageCommand}"
                                Style="{StaticResource MaterialDesignIconButton}">
                            <materialDesign:PackIcon Kind="ChevronRight"
                                                     Width="20"
                                                     Height="20" />
                        </Button>

                    </StackPanel>

                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>