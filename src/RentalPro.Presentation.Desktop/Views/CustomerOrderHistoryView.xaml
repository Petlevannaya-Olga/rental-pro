<UserControl x:Class="RentalPro.Presentation.Desktop.Views.CustomerOrderHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <Border Background="White"
            CornerRadius="16"
            Padding="24"
            Margin="0 0 16 0">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Шапка -->
            <StackPanel Grid.Row="0">

                <Button HorizontalAlignment="Left"
                        Command="{Binding BackCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        Cursor="Hand">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent">
                                <ContentPresenter />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <materialDesign:PackIcon Grid.Column="0"
                                                 Kind="ArrowLeft"
                                                 Width="24"
                                                 Height="24"
                                                 Margin="0 0 10 0"
                                                 VerticalAlignment="Center"
                                                 Foreground="#1E73FF" />

                        <TextBlock Grid.Column="1"
                                   Text="Назад к списку клиентов"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#6B7890" />
                    </Grid>
                </Button>

                <TextBlock Text="{Binding CustomerFullName}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#071B39"
                           Margin="0 24 0 0" />

            </StackPanel>

            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding Orders}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#EEF2F7"
                      BorderThickness="0"
                      RowHeight="64"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="White"
                      Style="{StaticResource MaterialDesignDataGrid}">

                <DataGrid.Columns>

                    <DataGridTemplateColumn Header="Заказ" Width="2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Number}"
                                               FontWeight="SemiBold"
                                               Foreground="#071B39" />
                                    <TextBlock Text="{Binding OrderDate, StringFormat={}{0:dd.MM.yyyy}}"
                                               FontSize="12"
                                               Foreground="#6B7890"
                                               Margin="0 4 0 0" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Инстр." Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ToolsCount}"
                                           VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Выдача" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StartDate, StringFormat={}{0:dd.MM.yyyy}}"
                                           VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Статус" Width="240">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="14"
                                        Padding="12 6"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">

                                    <Border.Style>
                                        <Style TargetType="Border">

                                            <Setter Property="Background"
                                                    Value="#FFF1DC" />

                                            <Style.Triggers>

                                                <DataTrigger Binding="{Binding StatusName}"
                                                             Value="Завершен">
                                                    <Setter Property="Background"
                                                            Value="#DCFCE7" />
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding StatusName}"
                                                             Value="Выполняется">
                                                    <Setter Property="Background"
                                                            Value="#DBEAFE" />
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding StatusName}"
                                                             Value="Готов к выдаче">
                                                    <Setter Property="Background"
                                                            Value="#E0E7FF" />
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding StatusName}"
                                                             Value="Подтвержден">
                                                    <Setter Property="Background"
                                                            Value="#FEF3C7" />
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding StatusName}"
                                                             Value="Отменен">
                                                    <Setter Property="Background"
                                                            Value="#F1F5F9" />
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding StatusName}"
                                                             Value="Ожидает закрытия аренды">
                                                    <Setter Property="Background"
                                                            Value="#FFF1DC" />
                                                </DataTrigger>

                                            </Style.Triggers>

                                        </Style>
                                    </Border.Style>

                                    <TextBlock Text="{Binding StatusName}"
                                               FontWeight="SemiBold"
                                               FontSize="13">

                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">

                                                <Setter Property="Foreground"
                                                        Value="#F97316" />

                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding StatusName}"
                                                                 Value="Завершен">
                                                        <Setter Property="Foreground"
                                                                Value="#16A34A" />
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding StatusName}"
                                                                 Value="Выполняется">
                                                        <Setter Property="Foreground"
                                                                Value="#2563EB" />
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding StatusName}"
                                                                 Value="Готов к выдаче">
                                                        <Setter Property="Foreground"
                                                                Value="#4F46E5" />
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding StatusName}"
                                                                 Value="Подтвержден">
                                                        <Setter Property="Foreground"
                                                                Value="#D97706" />
                                                    </DataTrigger>

                                                   <DataTrigger Binding="{Binding StatusName}"
                                                                 Value="Отменен">
                                                        <Setter Property="Foreground"
                                                                Value="#64748B" />
                                                    </DataTrigger>

                                                </Style.Triggers>

                                            </Style>
                                        </TextBlock.Style>

                                    </TextBlock>

                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Аренда" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding RentalAmount, StringFormat={}{0:N0} ₽}"
                                           VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Залог" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DepositAmount, StringFormat={}{0:N0} ₽}"
                                           VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>