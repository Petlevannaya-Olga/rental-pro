<UserControl x:Class="RentalPro.Presentation.Desktop.Views.CustomerOrderHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <Border Background="White"
            CornerRadius="16"
            Padding="24"
            Margin="0 0 16 0">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="История заказов"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#071B39" />

                    <TextBlock Text="{Binding CustomerFullName}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#6B7890"
                               Margin="0 8 0 0" />
                </StackPanel>

                <Button Grid.Column="1"
                        Command="{Binding BackCommand}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="Назад">

                    <materialDesign:PackIcon Kind="Close"
                                             Width="24"
                                             Height="24"
                                             Foreground="#64748B" />
                </Button>
            </Grid>

            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding Orders}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#EEF2F7"
                      BorderThickness="0"
                      RowHeight="64"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="White"
                      Style="{StaticResource MaterialDesignDataGrid}">

                <DataGrid.Columns>

                    <DataGridTemplateColumn Header="Заказ"
                                            Width="2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Number}"
                                               FontWeight="SemiBold"
                                               Foreground="#071B39" />

                                    <TextBlock Text="{Binding OrderDate, StringFormat={}{0:dd.MM.yyyy}}"
                                               FontSize="12"
                                               Foreground="#6B7890"
                                               Margin="0 4 0 0" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Инстр."
                                        Binding="{Binding ToolsCount}"
                                        Width="90" />

                    <DataGridTextColumn Header="Выдача"
                                        Binding="{Binding StartDate, StringFormat={}{0:dd.MM.yyyy}}"
                                        Width="140" />

                    <DataGridTemplateColumn Header="Статус"
                                            Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#FFF1DC"
                                        CornerRadius="14"
                                        Padding="12 6"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding StatusName}"
                                               Foreground="#F97316"
                                               FontWeight="SemiBold"
                                               FontSize="13" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Аренда"
                                        Binding="{Binding RentalAmount, StringFormat={}{0:N0} ₽}"
                                        Width="140" />

                    <DataGridTextColumn Header="Залог"
                                        Binding="{Binding DepositAmount, StringFormat={}{0:N0} ₽}"
                                        Width="140" />

                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>