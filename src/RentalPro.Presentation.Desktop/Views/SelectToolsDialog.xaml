<Window x:Class="RentalPro.Presentation.Desktop.Views.SelectToolsDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RentalPro.Presentation.Desktop.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="PrimaryDialogButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1E73FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="22 0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1664E8" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0F56C9" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Выбор инструментов"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#071B39" />

                <TextBlock Text="Выберите один или несколько инструментов для заказа"
                           FontSize="13"
                           Foreground="#6B7890"
                           Margin="0 8 0 0" />
            </StackPanel>

            <Button Grid.Column="1"
                    Click="Cancel_OnClick"
                    Style="{StaticResource MaterialDesignIconButton}">
                <materialDesign:PackIcon Kind="Close"
                                         Width="22"
                                         Height="22"
                                         Foreground="#64748B" />
            </Button>
        </Grid>

        <!-- Баннер -->
        <Border Grid.Row="2"
                Background="#EAF3FF"
                BorderBrush="#BFDBFE"
                BorderThickness="1"
                CornerRadius="12"
                Padding="14 10">

            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="CheckCircle"
                                         Width="20"
                                         Height="20"
                                         Foreground="#1E73FF"
                                         Margin="0 0 10 0" />

                <TextBlock Text="{Binding SelectedToolsCount, StringFormat=Выбрано инструментов: {0}}"
                           Foreground="#1E40AF"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Поиск -->
        <TextBox Grid.Row="4"
                 Height="46"
                 Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                 materialDesign:HintAssist.Hint="Название, инвентарный или серийный номер"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />

        <!-- Таблица -->
        <DataGrid Grid.Row="6"
                  ItemsSource="{Binding Tools}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  RowHeight="72"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#EEF2F7"
                  BorderThickness="0"
                  Style="{StaticResource MaterialDesignDataGrid}">

            <DataGrid.Columns>

                <DataGridTemplateColumn Width="44">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Command="{Binding DataContext.ToggleToolCommand,
                                                        RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                      CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Инструмент" Width="2.2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           Foreground="#071B39" />
                                <TextBlock Text="{Binding InventoryNumber, StringFormat=Инв. № {0}}"
                                           FontSize="12"
                                           Foreground="#6B7890"
                                           Margin="0 4 0 0" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Категория"
                                    Binding="{Binding CategoryName}"
                                    Width="1.3*" />

                <DataGridTextColumn Header="Производитель"
                                    Binding="{Binding ManufacturerName}"
                                    Width="1.3*" />

                <DataGridTextColumn Header="Серийный номер"
                                    Binding="{Binding SerialNumber}"
                                    Width="1.3*" />

                <DataGridTextColumn Header="Аренда/день"
                                    Binding="{Binding RentalPricePerDay, StringFormat={}{0:N0} ₽}"
                                    Width="120" />

                <DataGridTextColumn Header="Залог"
                                    Binding="{Binding DepositAmount, StringFormat={}{0:N0} ₽}"
                                    Width="120" />

                <DataGridTemplateColumn Header="Статус" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="#DCFCE7"
                                    CornerRadius="14"
                                    Padding="12 6"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="{Binding StatusName}"
                                           Foreground="#15803D"
                                           FontWeight="SemiBold" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Низ -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center"
                       Foreground="#6B7890">
                <Run Text="Показано " />
                <Run Text="{Binding CurrentPage, Mode=OneWay}" />
                <Run Text=" из " />
                <Run Text="{Binding TotalPages, Mode=OneWay}" />
            </TextBlock>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal">

                <Button Width="36"
                        Height="36"
                        Command="{Binding PreviousPageCommand}"
                        Style="{StaticResource MaterialDesignIconButton}">
                    <materialDesign:PackIcon Kind="ChevronLeft" />
                </Button>

                <Button Width="36"
                        Height="36"
                        Margin="6 0 0 0"
                        Command="{Binding NextPageCommand}"
                        Style="{StaticResource MaterialDesignIconButton}">
                    <materialDesign:PackIcon Kind="ChevronRight" />
                </Button>

                <Button Height="42"
                        Padding="18 0"
                        Margin="24 0 0 0"
                        Click="Cancel_OnClick"
                        Style="{StaticResource MaterialDesignOutlinedButton}">
                    <TextBlock Text="Отмена" />
                </Button>

                <Button Margin="12 0 0 0"
                        Click="Select_OnClick"
                        Style="{StaticResource PrimaryDialogButtonStyle}">

                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Check"
                                                 Width="18"
                                                 Height="18"
                                                 Margin="0 0 8 0"
                                                 Foreground="White" />

                        <TextBlock Text="Выбрать инструменты"
                                   Foreground="White"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Button>

            </StackPanel>
        </Grid>

    </Grid>
</Window>