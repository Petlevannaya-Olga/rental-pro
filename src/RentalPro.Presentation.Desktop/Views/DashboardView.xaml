<UserControl x:Class="RentalPro.Presentation.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:controls="clr-namespace:RentalPro.Presentation.Desktop.Controls"
             Background="Transparent">

    <UserControl.Resources>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.08" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource CardStyle}">
            <Setter Property="Margin" Value="0 0 16 16" />
        </Style>

        <Style x:Key="StatTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7890" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="6 0 0 0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#071B39" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="MoneyValueStyle" TargetType="TextBlock" BasedOn="{StaticResource StatValueStyle}">
            <Setter Property="FontSize" Value="18" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="16 0" />
            <Setter Property="Background" Value="#EEF4FF" />
            <Setter Property="Foreground" Value="#1E73FF" />
            <Setter Property="BorderBrush" Value="#EEF4FF" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="DashboardDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="RowHeight" Value="44" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#071B39" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F7FAFF" />
            <Setter Property="Foreground" Value="#6B7890" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="12 0" />
            <Setter Property="BorderBrush" Value="#E7EDF7" />
            <Setter Property="BorderThickness" Value="0 0 0 1" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#EEF2F8" />
            <Setter Property="BorderThickness" Value="0 0 0 1" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F7FAFF" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EEF4FF" />
                    <Setter Property="Foreground" Value="#071B39" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8 2" />
            <Setter Property="Height" Value="24" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="#EEF4FF" />

            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusName}" Value="Подтвержден">
                    <Setter Property="Background" Value="#EEF4FF" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusName}" Value="Готов к выдаче">
                    <Setter Property="Background" Value="#ECFDF5" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusName}" Value="Выполняется">
                    <Setter Property="Background" Value="#ECFDF5" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusName}" Value="Просрочен">
                    <Setter Property="Background" Value="#FEF2F2" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusName}" Value="Ожидает закрытия аренды">
                    <Setter Property="Background" Value="#FFF7ED" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusName}" Value="Завершен">
                    <Setter Property="Background" Value="#F3F4F6" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusName}" Value="Отменен">
                    <Setter Property="Background" Value="#FEE2E2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Foreground" Value="#1E73FF" />

            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusName}" Value="Готов к выдаче">
                    <Setter Property="Foreground" Value="#15803D" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusName}" Value="Выполняется">
                    <Setter Property="Foreground" Value="#15803D" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusName}" Value="Просрочен">
                    <Setter Property="Foreground" Value="#DC2626" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusName}" Value="Ожидает закрытия аренды">
                    <Setter Property="Foreground" Value="#C2410C" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusName}" Value="Завершен">
                    <Setter Property="Foreground" Value="#4B5563" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusName}" Value="Отменен">
                    <Setter Property="Foreground" Value="#B91C1C" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ReturnItemStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0 0 0 10" />
        </Style>

        <Style x:Key="ChartProgressStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="8" />
            <Setter Property="Background" Value="#EEF2F8" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

    </UserControl.Resources>

    <Grid>

        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <StackPanel>

                    <!-- Карточки статистики -->
                    <UniformGrid Columns="5" Margin="0 0 0 8">

                        <Border Style="{StaticResource StatCardStyle}">
                            <StackPanel>
                                <DockPanel Margin="0 0 0 4">
                                    <materialDesign:PackIcon Kind="Tools" Width="22" Height="22" Foreground="#1E73FF" />
                                    <TextBlock Text="Инструменты" Style="{StaticResource StatTitleStyle}" />
                                </DockPanel>
                                <TextBlock Text="{Binding Dashboard.Stats.TotalTools}"
                                           Style="{StaticResource StatValueStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatCardStyle}">
                            <StackPanel>
                                <DockPanel Margin="0 0 0 4">
                                    <materialDesign:PackIcon Kind="CalendarCheck" Width="22" Height="22"
                                                             Foreground="#16A34A" />
                                    <TextBlock Text="В аренде" Style="{StaticResource StatTitleStyle}" />
                                </DockPanel>
                                <TextBlock Text="{Binding Dashboard.Stats.RentedTools}"
                                           Style="{StaticResource StatValueStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatCardStyle}">
                            <StackPanel>
                                <DockPanel Margin="0 0 0 4">
                                    <materialDesign:PackIcon Kind="BookmarkCheck" Width="22" Height="22"
                                                             Foreground="#F59E0B" />
                                    <TextBlock Text="Бронь" Style="{StaticResource StatTitleStyle}" />
                                </DockPanel>
                                <TextBlock Text="{Binding Dashboard.Stats.BookedTools}"
                                           Style="{StaticResource StatValueStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatCardStyle}">
                            <StackPanel>
                                <DockPanel Margin="0 0 0 4">
                                    <materialDesign:PackIcon Kind="Wrench" Width="22" Height="22" Foreground="#F97316" />
                                    <TextBlock Text="Ремонт" Style="{StaticResource StatTitleStyle}" />
                                </DockPanel>
                                <TextBlock Text="{Binding Dashboard.Stats.ToolsInRepair}"
                                           Style="{StaticResource StatValueStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatCardStyle}">
                            <StackPanel>
                                <DockPanel Margin="0 0 0 4">
                                    <materialDesign:PackIcon Kind="AccountGroupOutline" Width="22" Height="22"
                                                             Foreground="#7C3AED" />
                                    <TextBlock Text="Клиенты" Style="{StaticResource StatTitleStyle}" />
                                </DockPanel>
                                <TextBlock Text="{Binding Dashboard.Stats.TotalCustomers}"
                                           Style="{StaticResource StatValueStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatCardStyle}">
                            <StackPanel>
                                <DockPanel Margin="0 0 0 4">
                                    <materialDesign:PackIcon Kind="ClipboardTextOutline" Width="22" Height="22"
                                                             Foreground="#1E73FF" />
                                    <TextBlock Text="Активные" Style="{StaticResource StatTitleStyle}" />
                                </DockPanel>
                                <TextBlock Text="{Binding Dashboard.Stats.ActiveOrders}"
                                           Style="{StaticResource StatValueStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatCardStyle}">
                            <StackPanel>
                                <DockPanel Margin="0 0 0 4">
                                    <materialDesign:PackIcon Kind="PlusBox" Width="22" Height="22" Foreground="#16A34A" />
                                    <TextBlock Text="Новые" Style="{StaticResource StatTitleStyle}" />
                                </DockPanel>
                                <TextBlock Text="{Binding Dashboard.Stats.NewOrdersThisMonth}"
                                           Style="{StaticResource StatValueStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatCardStyle}">
                            <StackPanel>
                                <DockPanel Margin="0 0 0 4">
                                    <materialDesign:PackIcon Kind="Alert" Width="22" Height="22" Foreground="#F97316" />
                                    <TextBlock Text="Просрочено" Style="{StaticResource StatTitleStyle}" />
                                </DockPanel>
                                <TextBlock Text="{Binding Dashboard.Stats.OverdueReturnsCount}"
                                           Style="{StaticResource StatValueStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatCardStyle}">
                            <StackPanel>
                                <DockPanel Margin="0 0 0 4">
                                    <materialDesign:PackIcon Kind="ShieldLock" Width="22" Height="22"
                                                             Foreground="#7C3AED" />
                                    <TextBlock Text="Залоги" Style="{StaticResource StatTitleStyle}" />
                                </DockPanel>
                                <TextBlock Text="{Binding Dashboard.Stats.DepositsReceived, StringFormat={}{0:N0} ₽}"
                                           Style="{StaticResource MoneyValueStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatCardStyle}">
                            <StackPanel>
                                <DockPanel Margin="0 0 0 4">
                                    <materialDesign:PackIcon Kind="Wallet" Width="22" Height="22" Foreground="#0891B2" />
                                    <TextBlock Text="Выручка" Style="{StaticResource StatTitleStyle}" />
                                </DockPanel>
                                <TextBlock Text="{Binding Dashboard.Stats.MonthlyRevenue, StringFormat={}{0:N0} ₽}"
                                           Style="{StaticResource MoneyValueStyle}" />
                            </StackPanel>
                        </Border>

                    </UniformGrid>

                    <!-- Статусы инструментов + ближайшие возвраты -->
                    <Grid Margin="0 8 16 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.8*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="1.2*" />
                        </Grid.ColumnDefinitions>

                        <!-- Диаграмма статусов -->
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                            <StackPanel>

                                <TextBlock Text="Статусы инструментов"
                                           FontSize="20"
                                           FontWeight="Black"
                                           Foreground="#071B39"
                                           Margin="0 0 0 18" />

                                <Grid Margin="0 0 0 20"
                                      Width="132"
                                      Height="132"
                                      HorizontalAlignment="Center">

                                    <controls:DonutChart Width="132"
                                                         Height="132"
                                                         Available="{Binding Dashboard.ToolStatuses.Available}"
                                                         Rented="{Binding Dashboard.ToolStatuses.Rented}"
                                                         Booked="{Binding Dashboard.ToolStatuses.Booked}"
                                                         InRepair="{Binding Dashboard.ToolStatuses.InRepair}" />

                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Dashboard.Stats.TotalTools}"
                                                   FontSize="26"
                                                   FontWeight="Black"
                                                   Foreground="#071B39"
                                                   HorizontalAlignment="Center" />

                                        <TextBlock Text="Всего"
                                                   FontSize="12"
                                                   Foreground="#6B7890"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Grid>

                                <StackPanel>

                                    <Grid Margin="0 0 0 12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition />
                                            <ColumnDefinition Width="38" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Доступно" FontSize="13" Foreground="#6B7890" />
                                        <ProgressBar Grid.Column="1"
                                                     Value="{Binding Dashboard.ToolStatuses.Available}"
                                                     Maximum="{Binding Dashboard.Stats.TotalTools}"
                                                     Foreground="#16A34A"
                                                     Style="{StaticResource ChartProgressStyle}" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Dashboard.ToolStatuses.Available}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#071B39"
                                                   HorizontalAlignment="Right" />
                                    </Grid>

                                    <Grid Margin="0 0 0 12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition />
                                            <ColumnDefinition Width="38" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="В аренде" FontSize="13" Foreground="#6B7890" />
                                        <ProgressBar Grid.Column="1"
                                                     Value="{Binding Dashboard.ToolStatuses.Rented}"
                                                     Maximum="{Binding Dashboard.Stats.TotalTools}"
                                                     Foreground="#1E73FF"
                                                     Style="{StaticResource ChartProgressStyle}" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Dashboard.ToolStatuses.Rented}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#071B39"
                                                   HorizontalAlignment="Right" />
                                    </Grid>

                                    <Grid Margin="0 0 0 12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition />
                                            <ColumnDefinition Width="38" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Бронь" FontSize="13" Foreground="#6B7890" />
                                        <ProgressBar Grid.Column="1"
                                                     Value="{Binding Dashboard.ToolStatuses.Booked}"
                                                     Maximum="{Binding Dashboard.Stats.TotalTools}"
                                                     Foreground="#F59E0B"
                                                     Style="{StaticResource ChartProgressStyle}" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Dashboard.ToolStatuses.Booked}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#071B39"
                                                   HorizontalAlignment="Right" />
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition />
                                            <ColumnDefinition Width="38" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Ремонт" FontSize="13" Foreground="#6B7890" />
                                        <ProgressBar Grid.Column="1"
                                                     Value="{Binding Dashboard.ToolStatuses.InRepair}"
                                                     Maximum="{Binding Dashboard.Stats.TotalTools}"
                                                     Foreground="#F97316"
                                                     Style="{StaticResource ChartProgressStyle}" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Dashboard.ToolStatuses.InRepair}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#071B39"
                                                   HorizontalAlignment="Right" />
                                    </Grid>

                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Ближайшие возвраты -->
                        <!-- Ближайшие возвраты -->
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Ближайшие возвраты"
                                           FontSize="20"
                                           FontWeight="Black"
                                           Foreground="#071B39"
                                           Margin="0 0 0 18" />

                                <ItemsControl ItemsSource="{Binding Returns}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>

                                            <Border>
                                                <Border.Style>
                                                    <Style TargetType="Border"
                                                           BasedOn="{StaticResource ReturnItemStyle}">
                                                        <Setter Property="Background" Value="#F7FAFF" />

                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                                <Setter Property="Background" Value="#FEF2F2" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="{Binding CustomerFullName}"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#071B39"
                                                                   TextTrimming="CharacterEllipsis" />

                                                        <TextBlock Text="{Binding ToolsNames}"
                                                                   FontSize="12"
                                                                   Foreground="#6B7890"
                                                                   Margin="0 4 0 0"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>

                                                    <Border Grid.Column="1"
                                                            CornerRadius="10"
                                                            Padding="10 4"
                                                            VerticalAlignment="Center"
                                                            Margin="12 0 0 0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#EEF4FF" />

                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsOverdue}"
                                                                            Value="True">
                                                                        <Setter Property="Background" Value="#FEE2E2" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>

                                                        <TextBlock Text="{Binding DateText}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#1E73FF" />

                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsOverdue}"
                                                                                Value="True">
                                                                            <Setter Property="Foreground"
                                                                                    Value="#DC2626" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Последние заказы -->
                    <Border Style="{StaticResource CardStyle}" Margin="0 18 16 0">
                        <StackPanel>

                            <Grid Margin="0 0 0 18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Последние заказы"
                                           FontSize="20"
                                           FontWeight="Black"
                                           Foreground="#071B39" />

                                <Button Grid.Column="1"
                                        Content="Все заказы"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </Grid>

                            <DataGrid ItemsSource="{Binding Dashboard.RecentOrders}"
                                      Style="{StaticResource DashboardDataGridStyle}"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MinHeight="230">

                                <DataGrid.Columns>

                                    <DataGridTemplateColumn Header="№ заказа" Width="155">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Number}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Клиент" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding CustomerFullName}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Инстр." Width="70">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ToolsCount}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Выдача" Width="105">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StartDate, StringFormat={}{0:dd.MM.yyyy}}"
                                                           VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Статус" Width="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource StatusBadgeStyle}">
                                                    <TextBlock Text="{Binding StatusName}"
                                                               Style="{StaticResource StatusBadgeTextStyle}" />
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Аренда" Width="105">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding TotalCost, StringFormat={}{0:N0} ₽}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Залог" Width="105">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DepositTotal, StringFormat={}{0:N0} ₽}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                </DataGrid.Columns>
                            </DataGrid>

                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <TextBlock Text="Загрузка дашборда..."
                   FontSize="18"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="#DC2626"
                   FontSize="15"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0 0 0 20" />
    </Grid>
</UserControl>