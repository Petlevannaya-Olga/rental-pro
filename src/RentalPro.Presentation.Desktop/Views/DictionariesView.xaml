<UserControl x:Class="RentalPro.Presentation.Desktop.Views.DictionariesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="2"
                                      Opacity="0.08" />
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <UniformGrid Columns="4"
                     Rows="2"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Top">

            <!-- Категории инструментов -->
            <Border Height="280"
                    Margin="0 0 20 20"
                    Padding="20"
                    Cursor="Hand"
                    Style="{StaticResource CardStyle}">

                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding OpenDictionaryCommand}"
                                  CommandParameter="toolCategories" />
                </Border.InputBindings>

                <StackPanel>
                    <Border Width="64"
                            Height="64"
                            CornerRadius="14"
                            Background="#DBEAFE"
                            HorizontalAlignment="Left">

                        <materialDesign:PackIcon Kind="ViewGridOutline"
                                                 Width="28"
                                                 Height="28"
                                                 Foreground="#1E73FF"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Text="Категории инструментов"
                               Margin="0 24 0 0"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#071B39"
                               TextWrapping="Wrap" />

                    <TextBlock Text="Категории и группы инструментов"
                               Margin="0 8 0 0"
                               FontSize="13"
                               Foreground="#6B7890"
                               TextWrapping="Wrap" />

                    <Grid Margin="0 28 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding ToolCategoriesCount}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#071B39" />

                            <TextBlock Text="записей"
                                       FontSize="13"
                                       Foreground="#6B7890"
                                       Margin="0 2 0 0" />
                        </StackPanel>

                        <materialDesign:PackIcon Grid.Column="1"
                                                 Kind="ArrowRight"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="#9AA7BD"
                                                 VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Статусы инструментов -->
            <Border Height="280"
                    Margin="0 0 20 20"
                    Padding="20"
                    Cursor="Hand"
                    Style="{StaticResource CardStyle}">

                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding OpenDictionaryCommand}"
                                  CommandParameter="toolStatuses" />
                </Border.InputBindings>

                <StackPanel>
                    <Border Width="64"
                            Height="64"
                            CornerRadius="14"
                            Background="#DCFCE7"
                            HorizontalAlignment="Left">

                        <materialDesign:PackIcon Kind="Tools"
                                                 Width="30"
                                                 Height="30"
                                                 Foreground="#16A34A"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Text="Статусы инструментов"
                               Margin="0 24 0 0"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#071B39"
                               TextWrapping="Wrap" />

                    <TextBlock Text="Статусы доступности инструментов"
                               Margin="0 8 0 0"
                               FontSize="13"
                               Foreground="#6B7890"
                               TextWrapping="Wrap" />

                    <Grid Margin="0 28 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding ToolStatusesCount}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#071B39" />

                            <TextBlock Text="записей"
                                       FontSize="13"
                                       Foreground="#6B7890"
                                       Margin="0 2 0 0" />
                        </StackPanel>

                        <materialDesign:PackIcon Grid.Column="1"
                                                 Kind="ArrowRight"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="#9AA7BD"
                                                 VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Статусы заказов -->
            <Border Height="280"
                    Margin="0 0 20 20"
                    Padding="20"
                    Cursor="Hand"
                    Style="{StaticResource CardStyle}">

                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding OpenDictionaryCommand}"
                                  CommandParameter="orderStatuses" />
                </Border.InputBindings>

                <StackPanel>
                    <Border Width="64"
                            Height="64"
                            CornerRadius="14"
                            Background="#FFEDD5"
                            HorizontalAlignment="Left">

                        <materialDesign:PackIcon Kind="ClipboardListOutline"
                                                 Width="30"
                                                 Height="30"
                                                 Foreground="#F97316"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Text="Статусы заказов"
                               Margin="0 24 0 0"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#071B39"
                               TextWrapping="Wrap" />

                    <TextBlock Text="Статусы выполнения заказов"
                               Margin="0 8 0 0"
                               FontSize="13"
                               Foreground="#6B7890"
                               TextWrapping="Wrap" />

                    <Grid Margin="0 28 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding OrderStatusesCount}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#071B39" />

                            <TextBlock Text="записей"
                                       FontSize="13"
                                       Foreground="#6B7890"
                                       Margin="0 2 0 0" />
                        </StackPanel>

                        <materialDesign:PackIcon Grid.Column="1"
                                                 Kind="ArrowRight"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="#9AA7BD"
                                                 VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Способы оплаты -->
            <Border Height="280"
                    Margin="0 0 20 20"
                    Padding="20"
                    Cursor="Hand"
                    Style="{StaticResource CardStyle}">

                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding OpenDictionaryCommand}"
                                  CommandParameter="paymentMethods" />
                </Border.InputBindings>

                <StackPanel>
                    <Border Width="64"
                            Height="64"
                            CornerRadius="14"
                            Background="#CFFAFE"
                            HorizontalAlignment="Left">

                        <materialDesign:PackIcon Kind="CreditCardOutline"
                                                 Width="30"
                                                 Height="30"
                                                 Foreground="#0891B2"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Text="Способы оплаты"
                               Margin="0 24 0 0"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#071B39"
                               TextWrapping="Wrap" />

                    <TextBlock Text="Доступные способы оплаты"
                               Margin="0 8 0 0"
                               FontSize="13"
                               Foreground="#6B7890"
                               TextWrapping="Wrap" />

                    <Grid Margin="0 28 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding PaymentMethodsCount}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#071B39" />

                            <TextBlock Text="записи"
                                       FontSize="13"
                                       Foreground="#6B7890"
                                       Margin="0 2 0 0" />
                        </StackPanel>

                        <materialDesign:PackIcon Grid.Column="1"
                                                 Kind="ArrowRight"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="#9AA7BD"
                                                 VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Типы оплат -->
            <Border Height="280"
                    Margin="0 0 20 20"
                    Padding="20"
                    Cursor="Hand"
                    Style="{StaticResource CardStyle}">

                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding OpenDictionaryCommand}"
                                  CommandParameter="paymentTypes" />
                </Border.InputBindings>

                <StackPanel>
                    <Border Width="64"
                            Height="64"
                            CornerRadius="14"
                            Background="#DCFCE7"
                            HorizontalAlignment="Left">

                        <materialDesign:PackIcon Kind="PercentOutline"
                                                 Width="30"
                                                 Height="30"
                                                 Foreground="#16A34A"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Text="Типы оплат"
                               Margin="0 24 0 0"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#071B39"
                               TextWrapping="Wrap" />

                    <TextBlock Text="Типы оплат и наценок"
                               Margin="0 8 0 0"
                               FontSize="13"
                               Foreground="#6B7890"
                               TextWrapping="Wrap" />

                    <Grid Margin="0 28 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding PaymentTypesCount}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#071B39" />

                            <TextBlock Text="записи"
                                       FontSize="13"
                                       Foreground="#6B7890"
                                       Margin="0 2 0 0" />
                        </StackPanel>

                        <materialDesign:PackIcon Grid.Column="1"
                                                 Kind="ArrowRight"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="#9AA7BD"
                                                 VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Роли пользователей -->
            <Border Height="280"
                    Margin="0 0 20 20"
                    Padding="20"
                    Cursor="Hand"
                    Style="{StaticResource CardStyle}">

                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding OpenDictionaryCommand}"
                                  CommandParameter="roles" />
                </Border.InputBindings>

                <StackPanel>
                    <Border Width="64"
                            Height="64"
                            CornerRadius="14"
                            Background="#EDE9FE"
                            HorizontalAlignment="Left">

                        <materialDesign:PackIcon Kind="AccountOutline"
                                                 Width="30"
                                                 Height="30"
                                                 Foreground="#7C3AED"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Text="Роли пользователей"
                               Margin="0 24 0 0"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#071B39"
                               TextWrapping="Wrap" />

                    <TextBlock Text="Роли и права доступа"
                               Margin="0 8 0 0"
                               FontSize="13"
                               Foreground="#6B7890"
                               TextWrapping="Wrap" />

                    <Grid Margin="0 28 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding RolesCount}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#071B39" />

                            <TextBlock Text="записи"
                                       FontSize="13"
                                       Foreground="#6B7890"
                                       Margin="0 2 0 0" />
                        </StackPanel>

                        <materialDesign:PackIcon Grid.Column="1"
                                                 Kind="ArrowRight"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="#9AA7BD"
                                                 VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Производители -->
            <Border Height="280"
                    Margin="0 0 20 20"
                    Padding="20"
                    Cursor="Hand"
                    Style="{StaticResource CardStyle}">

                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding OpenDictionaryCommand}"
                                  CommandParameter="manufacturers" />
                </Border.InputBindings>

                <StackPanel>
                    <Border Width="64"
                            Height="64"
                            CornerRadius="14"
                            Background="#FEF3C7"
                            HorizontalAlignment="Left">

                        <materialDesign:PackIcon Kind="OfficeBuildingOutline"
                                                 Width="30"
                                                 Height="30"
                                                 Foreground="#D97706"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Text="Производители"
                               Margin="0 24 0 0"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#071B39"
                               TextWrapping="Wrap" />

                    <TextBlock Text="Производители инструментов"
                               Margin="0 8 0 0"
                               FontSize="13"
                               Foreground="#6B7890"
                               TextWrapping="Wrap" />

                    <Grid Margin="0 28 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding ManufacturersCount}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#071B39" />

                            <TextBlock Text="записей"
                                       FontSize="13"
                                       Foreground="#6B7890"
                                       Margin="0 2 0 0" />
                        </StackPanel>

                        <materialDesign:PackIcon Grid.Column="1"
                                                 Kind="ArrowRight"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="#9AA7BD"
                                                 VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

        </UniformGrid>
    </ScrollViewer>
</UserControl>