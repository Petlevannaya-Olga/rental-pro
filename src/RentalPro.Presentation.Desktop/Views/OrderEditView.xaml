<UserControl x:Class="RentalPro.Presentation.Desktop.Views.OrderEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="BorderBrush" Value="#D8E2F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="SummaryCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BorderBrush" Value="#D8E2F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7890" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="StrongTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#071B39" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="PrimaryActionButtonStyle"
               TargetType="Button">

            <Setter Property="Background" Value="#1E73FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="40" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="24 0" />

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#1664E8" />
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">

                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#0F56C9" />
                            </Trigger>

                            <Trigger Property="IsEnabled"
                                     Value="False">

                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#AFC9FF" />

                                <Setter Property="Foreground"
                                        Value="White" />
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

        <Style x:Key="CenteredCellTextStyle"
               TargetType="TextBlock">
            <Setter Property="VerticalAlignment"
                    Value="Center" />
        </Style>
    </UserControl.Resources>

    <Border Background="White"
            CornerRadius="16"
            Padding="24"
            Margin="0 0 16 0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="22" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Верх -->
            <Button Grid.Row="0"
                    HorizontalAlignment="Left"
                    Command="{Binding BackCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Cursor="Hand">

                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Button.Template>

                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ArrowLeft"
                                             Width="22"
                                             Height="22"
                                             Foreground="#1E73FF"
                                             Margin="0 0 8 0" />

                    <TextBlock Text="Назад к списку заказов"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#5B6F92"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- Создание -->
            <Grid Grid.Row="2"
                  Visibility="{Binding IsCreateMode, Converter={StaticResource BooleanToVisibilityConverter}}">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Клиент -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Клиент -->
                    <Border Grid.Column="0"
                            Style="{StaticResource PanelCardStyle}">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Width="54"
                                    Height="54"
                                    CornerRadius="14"
                                    Background="#EAF3FF"
                                    VerticalAlignment="Center">

                                <materialDesign:PackIcon Kind="AccountOutline"
                                                         Width="25"
                                                         Height="25"
                                                         Foreground="#1E73FF"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Margin="18 0"
                                        VerticalAlignment="Center">

                                <TextBlock Text="Клиент"
                                           Style="{StaticResource MutedTextStyle}" />

                                <TextBlock Foreground="#071B39"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0 4 0 0"
                                           TextWrapping="Wrap">

                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"
                                                    Value="{Binding Order.CustomerName}" />

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Order.CustomerName}"
                                                             Value="">
                                                    <Setter Property="Text"
                                                            Value="Клиент не выбран" />
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding Order.CustomerName}"
                                                             Value="{x:Null}">
                                                    <Setter Property="Text"
                                                            Value="Клиент не выбран" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>

                                </TextBlock>

                            </StackPanel>

                            <Button Grid.Column="2"
                                    Height="40"
                                    Padding="16 0"
                                    Command="{Binding SelectCustomerCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}">

                                <StackPanel Orientation="Horizontal">

                                    <materialDesign:PackIcon Kind="AccountSearchOutline"
                                                             Width="18"
                                                             Height="18"
                                                             Margin="0 0 8 0"
                                                             Foreground="#1E73FF" />

                                    <TextBlock Text="Изменить"
                                               FontWeight="SemiBold" />

                                </StackPanel>

                            </Button>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource PanelCardStyle}">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Width="54"
                                    Height="54"
                                    CornerRadius="14"
                                    Background="#DCFCE7">

                                <materialDesign:PackIcon Kind="Tools"
                                                         Width="25"
                                                         Height="25"
                                                         Foreground="#16A34A"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Margin="18 0"
                                        VerticalAlignment="Center">

                                <TextBlock Text="Инструменты"
                                           Style="{StaticResource MutedTextStyle}" />

                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#071B39">

                                    <Run Text="Выбрано инструментов: " />
                                    <Run Text="{Binding ToolsCount, Mode=OneWay}" />

                                </TextBlock>

                            </StackPanel>

                            <Button Grid.Column="2"
                                    Height="40"
                                    Padding="16 0"
                                    Command="{Binding SelectToolsCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}">

                                <StackPanel Orientation="Horizontal">

                                    <materialDesign:PackIcon Kind="Plus"
                                                             Width="18"
                                                             Height="18"
                                                             Margin="0 0 8 0" />

                                    <TextBlock Text="Добавить" />

                                </StackPanel>

                            </Button>
                        </Grid>

                    </Border>

                </Grid>

                <!-- Дата / комментарий -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <DatePicker Grid.Column="0"
                                Height="56"
                                SelectedDate="{Binding Order.OrderDate, UpdateSourceTrigger=PropertyChanged}"
                                materialDesign:HintAssist.Hint="Дата заказа"
                                Style="{StaticResource MaterialDesignOutlinedDatePicker}" />

                    <TextBox Grid.Column="2"
                             Height="56"
                             Text="{Binding Order.Comment, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Комментарий"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                </Grid>

                <!-- Заголовок таблицы -->
                <Grid Grid.Row="4">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility"
                                    Value="Visible" />

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ToolsCount}"
                                             Value="0">
                                    <Setter Property="Visibility"
                                            Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Инструменты в заказе"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#071B39"
                               VerticalAlignment="Center" />

                    <TextBlock Grid.Column="1"
                               Text="{Binding ToolsCount, StringFormat=Выбрано: {0}}"
                               FontSize="13"
                               Foreground="#6B7890"
                               VerticalAlignment="Center" />
                </Grid>

                <!-- Таблица / пустое состояние -->
                <Border Grid.Row="6"
                        Background="White"
                        CornerRadius="12"
                        BorderBrush="#EEF2F7"
                        BorderThickness="1">

                    <Grid>

                        <!-- Таблица -->
                        <DataGrid ItemsSource="{Binding Order.Tools}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#EEF2F7"
                                  BorderThickness="0"
                                  RowHeight="72">

                            <DataGrid.Style>
                                <Style TargetType="DataGrid"
                                       BasedOn="{StaticResource MaterialDesignDataGrid}">

                                    <Setter Property="Visibility"
                                            Value="Visible" />

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ToolsCount}"
                                                     Value="0">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>

                                </Style>
                            </DataGrid.Style>

                            <DataGrid.Columns>

                                <DataGridTemplateColumn Header="Инструмент"
                                                        Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center">

                                                <TextBlock Text="{Binding ToolName}"
                                                           FontWeight="SemiBold"
                                                           FontSize="14"
                                                           Foreground="#071B39" />

                                                <TextBlock
                                                    Text="{Binding RentalPricePerDay, StringFormat={}{0:N0} ₽ / день}"
                                                    FontSize="12"
                                                    Foreground="#6B7890"
                                                    Margin="0 4 0 0" />

                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Начало аренды"
                                                    Binding="{Binding StartDate, StringFormat={}{0:dd.MM.yyyy}}"
                                                    IsReadOnly="True"
                                                    ElementStyle="{StaticResource CenteredCellTextStyle}"
                                                    Width="150" />

                                <DataGridTemplateColumn Header="Окончание аренды"
                                                        Width="180">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <DatePicker
                                                SelectedDate="{Binding EndDate, UpdateSourceTrigger=PropertyChanged}"
                                                Height="44"
                                                Style="{StaticResource MaterialDesignFloatingHintDatePicker}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Дней"
                                                    Binding="{Binding RentalDays}"
                                                    IsReadOnly="True"
                                                    ElementStyle="{StaticResource CenteredCellTextStyle}"
                                                    Width="90" />

                                <DataGridTextColumn Header="Аренда"
                                                    Binding="{Binding TotalAmount, StringFormat={}{0:N0} ₽}"
                                                    IsReadOnly="True"
                                                    ElementStyle="{StaticResource CenteredCellTextStyle}"
                                                    Width="140" />

                                <DataGridTextColumn Header="Залог"
                                                    Binding="{Binding DepositAmount, StringFormat={}{0:N0} ₽}"
                                                    IsReadOnly="True"
                                                    ElementStyle="{StaticResource CenteredCellTextStyle}"
                                                    Width="130" />

                                <DataGridTemplateColumn Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>

                                            <Button Width="32"
                                                    Height="32"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding DataContext.RemoveToolCommand,
                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource MaterialDesignIconButton}">

                                                <materialDesign:PackIcon Kind="Close"
                                                                         Width="18"
                                                                         Height="18"
                                                                         Foreground="#EF4444" />

                                            </Button>

                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Пустое состояние -->
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">

                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility"
                                            Value="Collapsed" />

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ToolsCount}"
                                                     Value="0">
                                            <Setter Property="Visibility"
                                                    Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <Border Width="64"
                                    Height="64"
                                    CornerRadius="18"
                                    Background="#F1F5F9"
                                    HorizontalAlignment="Center">

                                <materialDesign:PackIcon Kind="Tools"
                                                         Width="32"
                                                         Height="32"
                                                         Foreground="#94A3B8"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center" />
                            </Border>

                            <TextBlock Text="Инструменты не выбраны"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#071B39"
                                       HorizontalAlignment="Center"
                                       Margin="0 16 0 0" />

                            <TextBlock Text="Добавьте инструменты для оформления заказа"
                                       FontSize="13"
                                       Foreground="#6B7890"
                                       HorizontalAlignment="Center"
                                       Margin="0 6 0 0" />

                            <Button Height="40"
                                    Padding="18 0"
                                    Margin="0 18 0 0"
                                    Command="{Binding SelectToolsCommand}"
                                    Style="{StaticResource PrimaryActionButtonStyle}">

                                <StackPanel Orientation="Horizontal">

                                    <materialDesign:PackIcon Kind="Plus"
                                                             Width="18"
                                                             Height="18"
                                                             Margin="0 0 8 0" />

                                    <TextBlock Text="Выбрать инструменты" />

                                </StackPanel>

                            </Button>

                        </StackPanel>

                    </Grid>

                </Border>

                <!-- Итоги -->
                <Border Grid.Row="8"
                        Style="{StaticResource SummaryCardStyle}">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="1.4*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">

                            <Border Width="46"
                                    Height="46"
                                    CornerRadius="13"
                                    Background="#EAF3FF">

                                <materialDesign:PackIcon Kind="Tools"
                                                         Width="23"
                                                         Height="23"
                                                         Foreground="#1E73FF"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Margin="12 0 0 0">
                                <TextBlock Text="Инструментов"
                                           Style="{StaticResource MutedTextStyle}" />
                                <TextBlock Text="{Binding ToolsCount}"
                                           Style="{StaticResource StrongTextStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">

                            <Border Width="46"
                                    Height="46"
                                    CornerRadius="13"
                                    Background="#DCFCE7">

                                <materialDesign:PackIcon Kind="CalendarCheck"
                                                         Width="23"
                                                         Height="23"
                                                         Foreground="#16A34A"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Margin="12 0 0 0">
                                <TextBlock Text="Дней"
                                           Style="{StaticResource MutedTextStyle}" />
                                <TextBlock Text="{Binding RentalDaysText}"
                                           Style="{StaticResource StrongTextStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">

                            <Border Width="46"
                                    Height="46"
                                    CornerRadius="13"
                                    Background="#FEF3C7">

                                <materialDesign:PackIcon Kind="WalletOutline"
                                                         Width="23"
                                                         Height="23"
                                                         Foreground="#D97706"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Margin="12 0 0 0">
                                <TextBlock Text="Залог"
                                           Style="{StaticResource MutedTextStyle}" />
                                <TextBlock Text="{Binding DepositAmount, StringFormat={}{0:N0} ₽}"
                                           Style="{StaticResource StrongTextStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="3"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">

                            <Border Width="46"
                                    Height="46"
                                    CornerRadius="13"
                                    Background="#DCFCE7">

                                <materialDesign:PackIcon Kind="Cash"
                                                         Width="23"
                                                         Height="23"
                                                         Foreground="#16A34A"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Margin="12 0 0 0">
                                <TextBlock Text="Аренда"
                                           Style="{StaticResource MutedTextStyle}" />
                                <TextBlock Text="{Binding RentalAmount, StringFormat={}{0:N0} ₽}"
                                           Style="{StaticResource StrongTextStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="4"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">

                            <TextBlock Text="К оплате"
                                       Foreground="#6B7890"
                                       FontSize="13"
                                       HorizontalAlignment="Right" />

                            <TextBlock Text="{Binding TotalToPay, StringFormat={}{0:N0} ₽}"
                                       Foreground="#071B39"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Margin="0 4 0 0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Кнопки -->
                <Grid Grid.Row="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#DC2626"
                               VerticalAlignment="Center"
                               FontSize="13" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">

                        <Button Height="42"
                                Padding="18 0"
                                Command="{Binding BackCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}">
                            <TextBlock Text="Отмена" />
                        </Button>

                        <Button Height="42"
                                Padding="18 0"
                                Margin="12 0 0 0"
                                Command="{Binding FillTestDataCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}">

                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="MagicStaff"
                                                         Width="17"
                                                         Height="17"
                                                         Margin="0 0 7 0" />
                                <TextBlock Text="Заполнить тестовыми данными" />
                            </StackPanel>
                        </Button>

                        <Button Margin="12 0 0 0"
                                Width="160"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}">

                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Check"
                                                         Width="18"
                                                         Height="18"
                                                         Margin="0 0 7 0" />
                                <TextBlock Text="Создать заказ" />
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </Grid>

            </Grid>

            <!-- Просмотр -->
            <ScrollViewer Grid.Row="2"
                          Visibility="{Binding IsViewMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Клиент / менеджер -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource SummaryCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Width="46"
                                        Height="46"
                                        CornerRadius="13"
                                        Background="#EAF3FF">
                                    <materialDesign:PackIcon Kind="AccountOutline"
                                                             Width="24"
                                                             Height="24"
                                                             Foreground="#1E73FF"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center" />
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Margin="14 0 0 0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Клиент"
                                               Style="{StaticResource MutedTextStyle}" />

                                    <TextBlock Text="{Binding Details.CustomerFullName}"
                                               Style="{StaticResource StrongTextStyle}"
                                               Margin="0 5 0 0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource SummaryCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Width="46"
                                        Height="46"
                                        CornerRadius="13"
                                        Background="#EAF3FF">
                                    <materialDesign:PackIcon Kind="AccountTie"
                                                             Width="24"
                                                             Height="24"
                                                             Foreground="#1E73FF"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center" />
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Margin="14 0 0 0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Менеджер"
                                               Style="{StaticResource MutedTextStyle}" />

                                    <TextBlock Text="{Binding Details.UserFullName}"
                                               Style="{StaticResource StrongTextStyle}"
                                               Margin="0 5 0 0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Платежи / документы -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Платежи -->
                        <Border Grid.Column="0"
                                Style="{StaticResource SummaryCardStyle}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal">
                                    <Border Width="42"
                                            Height="42"
                                            CornerRadius="12"
                                            Background="#DCFCE7">
                                        <materialDesign:PackIcon Kind="CreditCardOutline"
                                                                 Width="22"
                                                                 Height="22"
                                                                 Foreground="#16A34A"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center" />
                                    </Border>

                                    <StackPanel Margin="12 0 0 0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Платежи"
                                                   Style="{StaticResource StrongTextStyle}" />

                                        <TextBlock
                                            Text="{Binding Details.Payments.Count, StringFormat=Всего записей: {0}}"
                                            Style="{StaticResource MutedTextStyle}"
                                            Margin="0 3 0 0" />
                                    </StackPanel>
                                </StackPanel>

                                <ItemsControl Grid.Row="2"
                                              ItemsSource="{Binding Details.Payments}">

                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Setter Property="Visibility"
                                                    Value="Visible" />

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Details.Payments.Count}"
                                                             Value="0">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="0 8"
                                                    BorderBrush="#EEF2F7"
                                                    BorderThickness="0 0 0 1">

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="{Binding PaymentTypeName}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#071B39" />

                                                        <TextBlock FontSize="12"
                                                                   Foreground="#6B7890"
                                                                   Margin="0 3 0 0">
                                                            <Run Text="{Binding PaymentMethodName}" />
                                                            <Run Text=" · " />
                                                            <Run
                                                                Text="{Binding PaymentDate, StringFormat={}{0:dd.MM.yyyy HH:mm}}" />
                                                        </TextBlock>

                                                        <TextBlock Text="{Binding Comment}"
                                                                   FontSize="12"
                                                                   Foreground="#6B7890"
                                                                   Margin="0 3 0 0"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Amount, StringFormat={}{0:N0} ₽}"
                                                               FontWeight="SemiBold"
                                                               Foreground="#071B39"
                                                               VerticalAlignment="Center"
                                                               Margin="16 0 0 0" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Grid.Row="2"
                                           Text="Платежи отсутствуют"
                                           Foreground="#6B7890"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center">

                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Details.Payments.Count}"
                                                             Value="0">
                                                    <Setter Property="Visibility"
                                                            Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- Документы -->
                        <Border Grid.Column="2"
                                Style="{StaticResource SummaryCardStyle}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal">
                                    <Border Width="42"
                                            Height="42"
                                            CornerRadius="12"
                                            Background="#EAF3FF">
                                        <materialDesign:PackIcon Kind="FileDocumentOutline"
                                                                 Width="22"
                                                                 Height="22"
                                                                 Foreground="#1E73FF"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center" />
                                    </Border>

                                    <StackPanel Margin="12 0 0 0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Документы"
                                                   Style="{StaticResource StrongTextStyle}" />

                                        <TextBlock Text="Договор и акты по заказу"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Margin="0 3 0 0" />
                                    </StackPanel>
                                </StackPanel>

                                <ItemsControl Grid.Row="2"
                                              ItemsSource="{Binding OrderDocuments}">

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="0 8"
                                                    BorderBrush="#EEF2F7"
                                                    BorderThickness="0 0 0 1">

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{Binding Title}"
                                                               FontWeight="SemiBold"
                                                               Foreground="#071B39"
                                                               VerticalAlignment="Center" />

                                                    <StackPanel Grid.Column="1"
                                                                Orientation="Horizontal"
                                                                Margin="16 0 0 0">

                                                        <Button Width="32"
                                                                Height="32"
                                                                Command="{Binding DataContext.DownloadDocumentCommand,
                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource MaterialDesignIconButton}">
                                                            <materialDesign:PackIcon Kind="FileWordOutline"
                                                                    Width="20"
                                                                    Height="20"
                                                                    Foreground="#1E73FF" />
                                                        </Button>

                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Комментарий -->
                    <Border Grid.Row="4"
                            Style="{StaticResource SummaryCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Width="46"
                                    Height="46"
                                    CornerRadius="13"
                                    Background="#EAF3FF">
                                <materialDesign:PackIcon Kind="CommentTextOutline"
                                                         Width="24"
                                                         Height="24"
                                                         Foreground="#1E73FF"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Margin="14 0 0 0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Комментарий"
                                           Style="{StaticResource MutedTextStyle}" />

                                <TextBlock Foreground="#071B39"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Margin="0 6 0 0"
                                           TextWrapping="Wrap">

                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"
                                                    Value="{Binding Details.Comment}" />

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Details.Comment}"
                                                             Value="">
                                                    <Setter Property="Text"
                                                            Value="Комментарий отсутствует" />
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding Details.Comment}"
                                                             Value="{x:Null}">
                                                    <Setter Property="Text"
                                                            Value="Комментарий отсутствует" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Таблица инструментов -->
                    <Border Grid.Row="6"
                            Background="White"
                            CornerRadius="12"
                            BorderBrush="#EEF2F7"
                            BorderThickness="1">

                        <DataGrid ItemsSource="{Binding ViewItems}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#EEF2F7"
                                  BorderThickness="0"
                                  RowHeight="68"
                                  VerticalScrollBarVisibility="Auto"
                                  Style="{StaticResource MaterialDesignDataGrid}">

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="VerticalContentAlignment"
                                            Value="Center" />
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>

                                <DataGridTemplateColumn Header="Инструмент"
                                                        Width="2*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ToolName}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#071B39"
                                                           TextTrimming="CharacterEllipsis" />

                                                <TextBlock
                                                    Text="{Binding RentalPricePerDay, StringFormat={}{0:N0} ₽ / день}"
                                                    FontSize="12"
                                                    Foreground="#6B7890"
                                                    Margin="0 4 0 0" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Начало"
                                                    Binding="{Binding StartDate, StringFormat={}{0:dd.MM.yyyy}}"
                                                    Width="120"
                                                    ElementStyle="{StaticResource CenteredCellTextStyle}" />

                                <DataGridTextColumn Header="План возврата"
                                                    Binding="{Binding PlannedReturnDate, StringFormat={}{0:dd.MM.yyyy}}"
                                                    Width="140"
                                                    ElementStyle="{StaticResource CenteredCellTextStyle}" />

                                <DataGridTextColumn Header="Факт возврата"
                                                    Binding="{Binding ActualReturnedDate, StringFormat={}{0:dd.MM.yyyy}}"
                                                    Width="140"
                                                    ElementStyle="{StaticResource CenteredCellTextStyle}" />

                                <DataGridTextColumn Header="Дней"
                                                    Binding="{Binding RentalDays, StringFormat={}{0} дн.}"
                                                    Width="100"
                                                    ElementStyle="{StaticResource CenteredCellTextStyle}" />

                                <DataGridTextColumn Header="Аренда"
                                                    Binding="{Binding TotalAmount, StringFormat={}{0:N0} ₽}"
                                                    Width="130"
                                                    ElementStyle="{StaticResource CenteredCellTextStyle}" />

                                <DataGridTextColumn Header="Залог"
                                                    Binding="{Binding DepositAmount, StringFormat={}{0:N0} ₽}"
                                                    Width="130"
                                                    ElementStyle="{StaticResource CenteredCellTextStyle}" />

                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Итоги -->
                    <Border Grid.Row="8"
                            Style="{StaticResource SummaryCardStyle}">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="1.4*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Border Width="46"
                                        Height="46"
                                        CornerRadius="13"
                                        Background="#EAF3FF">
                                    <materialDesign:PackIcon Kind="CalendarRange"
                                                             Width="23"
                                                             Height="23"
                                                             Foreground="#1E73FF"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center" />
                                </Border>

                                <StackPanel Margin="12 0 0 0">
                                    <TextBlock Text="Период"
                                               Style="{StaticResource MutedTextStyle}" />
                                    <TextBlock Text="{Binding ViewPeriodText}"
                                               Style="{StaticResource StrongTextStyle}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Border Width="46"
                                        Height="46"
                                        CornerRadius="13"
                                        Background="#DCFCE7">
                                    <materialDesign:PackIcon Kind="Tools"
                                                             Width="23"
                                                             Height="23"
                                                             Foreground="#16A34A"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center" />
                                </Border>

                                <StackPanel Margin="12 0 0 0">
                                    <TextBlock Text="Инструментов"
                                               Style="{StaticResource MutedTextStyle}" />
                                    <TextBlock Text="{Binding ViewToolsCount, StringFormat={}{0} шт.}"
                                               Style="{StaticResource StrongTextStyle}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Border Width="46"
                                        Height="46"
                                        CornerRadius="13"
                                        Background="#FEF3C7">
                                    <materialDesign:PackIcon Kind="WalletOutline"
                                                             Width="23"
                                                             Height="23"
                                                             Foreground="#D97706"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center" />
                                </Border>

                                <StackPanel Margin="12 0 0 0">
                                    <TextBlock Text="Залог"
                                               Style="{StaticResource MutedTextStyle}" />
                                    <TextBlock Text="{Binding ViewDepositAmount, StringFormat={}{0:N0} ₽}"
                                               Style="{StaticResource StrongTextStyle}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="3"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Border Width="46"
                                        Height="46"
                                        CornerRadius="13"
                                        Background="#DCFCE7">
                                    <materialDesign:PackIcon Kind="Cash"
                                                             Width="23"
                                                             Height="23"
                                                             Foreground="#16A34A"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center" />
                                </Border>

                                <StackPanel Margin="12 0 0 0">
                                    <TextBlock Text="Аренда"
                                               Style="{StaticResource MutedTextStyle}" />
                                    <TextBlock Text="{Binding ViewRentalAmount, StringFormat={}{0:N0} ₽}"
                                               Style="{StaticResource StrongTextStyle}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="4"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <TextBlock Text="К оплате"
                                           Foreground="#6B7890"
                                           FontSize="13"
                                           HorizontalAlignment="Right" />

                                <TextBlock Text="{Binding ViewTotalToPay, StringFormat={}{0:N0} ₽}"
                                           Foreground="#071B39"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Margin="0 4 0 0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Кнопки -->
                    <Grid Grid.Row="10">
                        <Button Height="42"
                                Padding="18 0"
                                HorizontalAlignment="Right"
                                Command="{Binding BackCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}">
                            <TextBlock Text="Назад" />
                        </Button>
                    </Grid>

                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>