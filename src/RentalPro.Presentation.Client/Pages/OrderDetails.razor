@page "/orders/{Id:guid}"
@layout AdminLayout

@using RentalPro.Contracts.Orders
@using RentalPro.Contracts.Payments
@using RentalPro.Presentation.Client.Models.Dictionaries
@using RentalPro.Presentation.Client.Services

@inject OrdersService OrdersService
@inject PaymentsService PaymentsService
@inject DictionaryCrudService DictionaryCrudService
@inject NotificationService NotificationService
@inject NavigationManager Navigation

<PageTitle>Карточка заказа</PageTitle>

<div class="users-page orders-page">

    @if (_isLoading)
    {
        <div class="users-table-card">
            <div class="table-empty">Загрузка заказа...</div>
        </div>
    }
    else if (_viewOrder is null)
    {
        <div class="users-table-card">
            <div class="table-empty">Заказ не найден</div>
        </div>
    }
    else
    {
        <div class="users-table-card order-details-page">

            <div class="actions-modal-header order-details-header">

                <div>

                    <button class="back-link"
                            type="button"
                            @onclick="BackToOrders">

                        <i class="bi bi-arrow-left"></i>
                        К списку заказов

                    </button>

                    <h3>Заказ № @_viewOrder.Number</h3>

                    <p>
                        от @_viewOrder.OrderDate.ToString("dd.MM.yyyy")
                    </p>

                    @if (_viewOrder.UpdatedAt.HasValue)
                    {
                        <span class="order-updated">
                            Изменен: @_viewOrder.UpdatedAt.Value.ToString("dd.MM.yyyy HH:mm")
                        </span>
                    }
                    else
                    {
                        <span class="order-updated">
                            Не изменялся
                        </span>
                    }

                </div>

                <div class="modal-header-actions">
                    <span class="@GetOrderStatusClass(_viewOrder.StatusName)">
                        @_viewOrder.StatusName
                    </span>
                </div>

            </div>

            <div class="order-selected-grid">

                <button class="order-selected-card compact clickable"
                        type="button"
                        @onclick="OpenCustomerInfo">

                    <div class="order-selected-icon customer">
                        <i class="bi bi-person"></i>
                    </div>

                    <div class="order-selected-content">
                        <span>Клиент</span>

                        <strong>
                            @_viewOrder.CustomerFullName
                        </strong>

                        <p>
                            Нажмите для просмотра информации
                        </p>
                    </div>

                </button>

                <button class="order-selected-card compact clickable"
                        type="button"
                        @onclick="OpenManagerInfo">

                    <div class="order-selected-icon customer">
                        <i class="bi bi-person-badge"></i>
                    </div>

                    <div class="order-selected-content">
                        <span>Менеджер</span>

                        <strong>
                            @_viewOrder.UserFullName
                        </strong>

                        <p>
                            Нажмите для просмотра информации
                        </p>
                    </div>

                </button>

            </div>

            <div class="order-extra-grid">

                <div class="order-extra-card">

                    <div class="order-extra-title">
                        <div class="order-extra-icon green">
                            <i class="bi bi-credit-card"></i>
                        </div>

                        <div>
                            <span>Платежи</span>
                        </div>
                    </div>

                    @if (_viewOrder.Payments.Count == 0)
                    {
                        <div class="table-empty">
                            Платежи отсутствуют
                        </div>
                    }
                    else
                    {
                        <div class="order-payments-list">
                            @foreach (var payment in _viewOrder.Payments)
                            {
                                <div class="order-payment-row">
                                    <div>
                                        <strong>@payment.PaymentTypeName</strong>

                                        <span class="table-subtitle">
                                            @payment.PaymentMethodName · @payment.PaymentDate.ToString("dd.MM.yyyy HH:mm")
                                        </span>

                                        @if (!string.IsNullOrWhiteSpace(payment.Comment))
                                        {
                                            <span class="table-subtitle">
                                                @payment.Comment
                                            </span>
                                        }
                                    </div>

                                    <strong>
                                        @payment.Amount.ToString("N0") ₽
                                    </strong>
                                </div>
                            }
                        </div>
                    }

                </div>

                <div class="order-extra-card">

                    <div class="order-extra-title">
                        <div class="order-extra-icon blue">
                            <i class="bi bi-file-earmark-text"></i>
                        </div>

                        <div>
                            <span>Документы</span>
                        </div>
                    </div>

                    @if (_viewOrder.StatusName != "Отменен")
                    {
                        <div class="order-documents-list">

                            @foreach (var document in _orderDocuments)
                            {
                                <div class="order-document-row">
                                    <div>
                                        <strong>@document.Title</strong>
                                    </div>

                                    <div class="document-actions">

                                        @if (document.Type == OrderDocumentType.Contract)
                                        {
                                            <button class="icon-button"
                                                    type="button"
                                                    title="Скачать PDF"
                                                    @onclick="DownloadContractPdfAsync">
                                                <i class="bi bi-file-earmark-pdf"></i>
                                            </button>

                                            <button class="icon-button"
                                                    type="button"
                                                    title="Скачать DOCX"
                                                    @onclick="DownloadContractAsync">
                                                <i class="bi bi-file-earmark-word"></i>
                                            </button>
                                        }

                                        @if (document is { Type: OrderDocumentType.TransferAct, Date: not null })
                                        {
                                            <button class="icon-button"
                                                    type="button"
                                                    title="Скачать DOCX"
                                                    @onclick="() => DownloadTransferActAsync(document.Date.Value)">
                                                <i class="bi bi-file-earmark-word"></i>
                                            </button>
                                        }

                                        @if (document is { Type: OrderDocumentType.ReturnAct, Date: not null })
                                        {
                                            <button class="icon-button"
                                                    type="button"
                                                    title="Скачать DOCX"
                                                    @onclick="() => DownloadReturnActAsync(document.Date.Value)">
                                                <i class="bi bi-file-earmark-word"></i>
                                            </button>
                                        }

                                    </div>
                                </div>
                            }

                        </div>
                    }
                    else
                    {
                        <div class="table-empty">
                            Документы для отмененного заказа не формируются
                        </div>
                    }

                </div>

            </div>

            @if (!string.IsNullOrWhiteSpace(_viewOrder.Comment))
            {
                <div class="order-section">
                    <div class="order-extra-card wide">

                        <div class="order-extra-title">
                            <div class="order-extra-icon blue">
                                <i class="bi bi-chat-left-text"></i>
                            </div>

                            <div>
                                <span>Комментарий</span>
                            </div>
                        </div>

                        <p class="order-comment-text">
                            @_viewOrder.Comment
                        </p>

                    </div>
                </div>
            }

            <div class="order-section order-tools-section">
                <OrderItemsTable Items="_viewOrder.Items"/>
            </div>

            <div class="order-summary-card compact">

                <div class="order-summary-row">

                    <div class="order-summary-item">
                        <div class="summary-icon compact blue">
                            <i class="bi bi-calendar-range"></i>
                        </div>

                        <div>
                            <span>Период</span>

                            <strong>
                                @GetOrderPeriodText(_viewOrder)
                            </strong>
                        </div>
                    </div>

                    <div class="order-summary-item">
                        <div class="summary-icon compact green">
                            <i class="bi bi-tools"></i>
                        </div>

                        <div>
                            <span>Инструментов</span>

                            <strong>
                                @_viewOrder.Items.Count шт.
                            </strong>
                        </div>
                    </div>

                    <div class="order-summary-item">
                        <div class="summary-icon compact yellow">
                            <i class="bi bi-wallet2"></i>
                        </div>

                        <div>
                            <span>Залог</span>

                            <strong>
                                @_viewOrder.DepositTotal.ToString("N0") ₽
                            </strong>
                        </div>
                    </div>

                    <div class="order-summary-item">
                        <div class="summary-icon compact green">
                            <i class="bi bi-cash-stack"></i>
                        </div>

                        <div>
                            <span>Аренда</span>

                            <strong>
                                @_viewOrder.TotalCost.ToString("N0") ₽
                            </strong>
                        </div>
                    </div>

                    <div class="order-summary-total">
                        <span>К оплате</span>

                        <strong>
                            @((_viewOrder.TotalCost + _viewOrder.DepositTotal).ToString("N0"))₽
                        </strong>
                    </div>

                </div>

            </div>

            <div class="tool-form-actions modal-footer">

                @if (_viewOrder.StatusName == "Выполняется")
                {
                    <button class="primary-button"
                            type="button"
                            @onclick="OpenReturnModal">
                        <i class="bi bi-arrow-return-left"></i>
                        Оформить возврат
                    </button>
                }

                @if (_viewOrder.StatusName == "Ожидает возврата залога" &&
                     _viewOrder.RemainingDepositRefundAmount > 0)
                {
                    <button class="primary-button"
                            type="button"
                            @onclick="OpenDepositRefundModal">
                        <i class="bi bi-cash-coin"></i>
                        Вернуть залог
                    </button>
                }

                @if (_viewOrder.StatusName == "Готов к выдаче")
                {
                    <button class="primary-button"
                            type="button"
                            @onclick="IssueToolsAsync">
                        <i class="bi bi-box-seam"></i>
                        Выдать инструменты
                    </button>
                }

                @if (_viewOrder.TotalRemainingAmount > 0 &&
                     _viewOrder.StatusName == "Подтвержден")
                {
                    <button class="primary-button"
                            type="button"
                            @onclick="OpenPaymentModal">
                        <i class="bi bi-credit-card"></i>
                        Принять оплату
                    </button>
                }

                <button class="secondary-button"
                        type="button"
                        @onclick="BackToOrders">
                    Закрыть
                </button>

            </div>

        </div>
    }

    @if (_isReturnModalOpen && _viewOrder is not null)
    {
        <div class="actions-backdrop">
            <div class="payment-modal" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>Оформить возврат</h3>
                        <p>Заказ № @_viewOrder.Number</p>
                    </div>

                    <button type="button" @onclick="CloseReturnModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="payment-summary">
                    <div class="payment-summary-row">
                        <span>Клиент</span>
                        <strong>@_viewOrder.CustomerFullName</strong>
                    </div>
                </div>

                <div class="return-items-list">
                    @foreach (var item in _viewOrder.Items.Where(x => x.ActualReturnedDate is null))
                    {
                        <label class="return-item-row">
                            <input type="checkbox"
                                   checked="@_returnForm.SelectedOrderItemIds.Contains(item.Id)"
                                   @onchange="e => ToggleReturnItem(item.Id, e)"/>

                            <div class="return-item-content">
                                <div class="return-item-name">
                                    @item.ToolName
                                </div>

                                <div class="return-item-date">
                                    Плановый возврат:
                                    @item.PlannedReturnDate.ToString("dd.MM.yyyy")
                                </div>
                            </div>
                        </label>
                    }
                </div>

                <div class="payment-form-grid">
                    <div class="tool-form-field">
                        <label>Дата возврата <span>*</span></label>
                        <input type="date"
                               @bind="_returnForm.ActualReturnedDate"/>
                    </div>

                    <div class="tool-form-field">
                        <label>Состояние</label>
                        <select @bind="_returnForm.ReturnCondition">
                            <option value="Исправно">Исправно</option>
                            <option value="Требует обслуживания">Требует обслуживания</option>
                        </select>
                    </div>

                    <div class="tool-form-field full">
                        <label>Комментарий о повреждениях</label>
                        <input placeholder="Например: поврежден корпус, отсутствует насадка"
                               @bind="_returnForm.DamageComment"/>
                    </div>
                </div>

                <div class="tool-form-actions modal-footer">
                    <button class="secondary-button"
                            type="button"
                            @onclick="CloseReturnModal">
                        Отмена
                    </button>

                    <button class="primary-button"
                            type="button"
                            @onclick="ReturnItemsAsync">
                        <i class="bi bi-check2-circle"></i>
                        Оформить возврат
                    </button>
                </div>

            </div>
        </div>
    }

    @if (_isPaymentModalOpen && _viewOrder is not null)
    {
        <div class="actions-backdrop">
            <div class="payment-modal" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>Принять оплату</h3>
                        <p>Заказ № @_viewOrder.Number</p>
                    </div>

                    <button type="button" @onclick="ClosePaymentModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="payment-summary">
                    <div class="payment-summary-row">
                        <span>Клиент</span>
                        <strong>@_viewOrder.CustomerFullName</strong>
                    </div>

                    <div class="payment-summary-grid">
                        <div>
                            <span>Аренда</span>
                            <strong>@_viewOrder.TotalCost.ToString("N0") ₽</strong>
                            <small>Оплачено: @_viewOrder.PaidRentalAmount.ToString("N0") ₽</small>
                            <small>Осталось: @_viewOrder.RemainingRentalAmount.ToString("N0") ₽</small>
                        </div>

                        <div>
                            <span>Залог</span>
                            <strong>@_viewOrder.DepositTotal.ToString("N0") ₽</strong>
                            <small>Оплачено: @_viewOrder.PaidDepositAmount.ToString("N0") ₽</small>
                            <small>Осталось: @_viewOrder.RemainingDepositAmount.ToString("N0") ₽</small>
                        </div>

                        <div class="total">
                            <span>Итого</span>
                            <strong>@((_viewOrder.TotalCost + _viewOrder.DepositTotal).ToString("N0")) ₽</strong>
                            <small>Оплачено: @_viewOrder.TotalPaidAmount.ToString("N0") ₽</small>
                            <small>Осталось: @_viewOrder.TotalRemainingAmount.ToString("N0") ₽</small>
                        </div>
                    </div>
                </div>

                <div class="payment-form-grid">

                    <div class="tool-form-field">
                        <label>Тип оплаты <span>*</span></label>
                        <select @bind="_paymentForm.PaymentTypeId"
                                @bind:after="OnPaymentTypeChanged">
                            <option value="">Выберите тип оплаты</option>

                            @foreach (var type in _paymentTypes.Where(x => x.Name != "Возврат залога"))
                            {
                                <option value="@type.Id">@type.Name</option>
                            }
                        </select>
                    </div>

                    <div class="tool-form-field">
                        <label>Способ оплаты <span>*</span></label>
                        <select @bind="_paymentForm.PaymentMethodId">
                            <option value="">Выберите способ оплаты</option>

                            @foreach (var method in _paymentMethods)
                            {
                                <option value="@method.Id">@method.Name</option>
                            }
                        </select>
                    </div>

                    <div class="tool-form-field">
                        <label>Сумма <span>*</span></label>
                        <input type="number"
                               min="1"
                               step="0.01"
                               @bind="_paymentForm.Amount"
                               disabled="@(_paymentForm.PaymentTypeId == FullPaymentId)"/>
                    </div>

                    <div class="tool-form-field">
                        <label>Дата оплаты <span>*</span></label>
                        <input type="datetime-local"
                               @bind="_paymentForm.PaymentDate"/>
                    </div>

                    <div class="tool-form-field full">
                        <label>Комментарий</label>
                        <input placeholder="Комментарий к оплате"
                               @bind="_paymentForm.Comment"/>
                    </div>

                </div>

                <div class="tool-form-actions modal-footer">
                    <button class="secondary-button"
                            type="button"
                            @onclick="ClosePaymentModal">
                        Отмена
                    </button>

                    <button class="primary-button"
                            type="button"
                            @onclick="CreatePaymentAsync">
                        <i class="bi bi-credit-card"></i>
                        Принять оплату
                    </button>
                </div>

            </div>
        </div>
    }

    @if (_isDepositRefundModalOpen && _viewOrder is not null)
    {
        <div class="actions-backdrop">
            <div class="payment-modal"
                 @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>Возврат залога</h3>
                        <p>Заказ № @_viewOrder.Number</p>
                    </div>

                    <button type="button"
                            @onclick="CloseDepositRefundModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="payment-summary">
                    <div class="payment-summary-row">
                        <span>Клиент</span>
                        <strong>@_viewOrder.CustomerFullName</strong>
                    </div>

                    <div class="payment-summary-row">
                        <span>Осталось вернуть</span>
                        <strong>
                            @_viewOrder.RemainingDepositRefundAmount.ToString("N2") ₽
                        </strong>
                    </div>
                </div>

                <div class="payment-form-grid">

                    <div class="tool-form-field">
                        <label>Сумма возврата <span>*</span></label>

                        <InputNumber @bind-Value="_depositRefundForm.Amount"
                                     class="form-control"/>
                    </div>

                    <div class="tool-form-field">
                        <label>Способ возврата <span>*</span></label>

                        <InputSelect @bind-Value="_depositRefundForm.PaymentMethodId"
                                     class="form-select">

                            <option value="">Выберите способ</option>

                            @foreach (var method in _paymentMethods)
                            {
                                <option value="@method.Id">
                                    @method.Name
                                </option>
                            }
                        </InputSelect>
                    </div>

                    <div class="tool-form-field">
                        <label>Дата возврата</label>

                        <InputDate @bind-Value="_depositRefundForm.PaymentDate"
                                   class="form-control"/>
                    </div>

                    <div class="tool-form-field full">
                        <label>Комментарий</label>

                        <InputText @bind-Value="_depositRefundForm.Comment"
                                   class="form-control"
                                   placeholder="Комментарий"/>
                    </div>

                </div>

                <div class="tool-form-actions modal-footer">

                    <button class="secondary-button"
                            type="button"
                            @onclick="CloseDepositRefundModal">
                        Отмена
                    </button>

                    <button class="primary-button"
                            type="button"
                            @onclick="ReturnDepositAsync">

                        <i class="bi bi-cash-coin"></i>

                        Вернуть залог

                    </button>

                </div>

            </div>
        </div>
    }

</div>

@code
{
    [Parameter]
    public Guid Id { get; set; }

    private Guid? _depositRefundPaymentTypeId;
    private bool _isDepositRefundModalOpen;
    private DepositRefundFormModel _depositRefundForm = new();

    private bool _isReturnModalOpen;
    private ReturnFormModel _returnForm = new();

    private static readonly Guid FullPaymentId =
        Guid.Parse("FFFFFFFF-FFFF-FFFF-FFFF-FFFFFFFFFFFF");

    private bool _isPaymentModalOpen;
    private PaymentFormModel _paymentForm = new();

    private List<DictionaryItem> _paymentTypes = [];
    private List<DictionaryItem> _paymentMethods = [];

    private bool _isLoading;
    private OrderDetailsDto? _viewOrder;
    private IReadOnlyList<OrderDocumentDto> _orderDocuments = [];

    protected override async Task OnParametersSetAsync()
    {
        await LoadOrderAsync();
    }

    private async Task LoadOrderAsync()
    {
        _isLoading = true;

        var result = await OrdersService.GetByIdAsync(Id);

        if (result.IsFailure)
        {
            _viewOrder = null;
            _orderDocuments = [];
            _isLoading = false;

            NotificationService.Error(result.Error.Message);
            return;
        }

        _viewOrder = result.Value;

        await LoadOrderDocumentsAsync(Id);

        _isLoading = false;
    }

    private void BackToOrders()
    {
        Navigation.NavigateTo("/orders");
    }

    private void OpenCustomerInfo()
    {
        NotificationService.Info(
            "Просмотр информации о клиенте будет добавлен позже");
    }

    private void OpenManagerInfo()
    {
        NotificationService.Info(
            "Просмотр информации о сотруднике будет добавлен позже");
    }

    private static string GetOrderStatusClass(string status)
    {
        return status switch
        {
            "Активен" => "status-badge available",
            "Выполняется" => "status-badge available",
            "Готов к выдаче" => "status-badge info",
            "Подтвержден" => "status-badge info",
            "Ожидает возврата залога" => "status-badge warning",
            "Завершен" => "status-badge info",
            "Просрочен" => "status-badge danger",
            "Отменен" => "status-badge neutral",
            _ => "status-badge"
        };
    }

    private static string GetOrderPeriodText(OrderDetailsDto order)
    {
        if (order.Items.Count == 0)
            return "—";

        var start = order.Items.Min(x => x.StartDate);
        var end = order.Items.Max(x => x.PlannedReturnDate);

        return $"{start:dd.MM} — {end:dd.MM}";
    }

    private async Task DownloadContractAsync()
    {
        if (_viewOrder is null)
        {
            NotificationService.Error("Заказ не выбран");
            return;
        }

        var result = await OrdersService.ExportContractAsync(_viewOrder.Id);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success("Договор успешно сформирован");
    }

    private async Task DownloadContractPdfAsync()
    {
        if (_viewOrder is null)
        {
            NotificationService.Error("Заказ не выбран");
            return;
        }

        var result = await OrdersService.ExportContractPdfAsync(_viewOrder.Id);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success("PDF договора успешно сформирован");
    }

    private async Task DownloadTransferActAsync(DateOnly date)
    {
        if (_viewOrder is null)
        {
            NotificationService.Error("Заказ не выбран");
            return;
        }

        var result = await OrdersService.ExportTransferActAsync(
            _viewOrder.Id,
            date);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success("Акт выдачи успешно сформирован");
    }

    private async Task LoadOrderDocumentsAsync(Guid orderId)
    {
        var result = await OrdersService.GetDocumentsAsync(orderId);

        if (result.IsFailure)
        {
            _orderDocuments = [];
            NotificationService.Error(result.Error.Message);
            return;
        }

        _orderDocuments = result.Value;
    }

    private async Task DownloadReturnActAsync(DateOnly date)
    {
        if (_viewOrder is null)
        {
            NotificationService.Error("Заказ не выбран");
            return;
        }

        var result = await OrdersService.ExportReturnActAsync(
            _viewOrder.Id,
            date);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success("Акт возврата успешно сформирован");
    }

    private async Task OpenPaymentModal()
    {
        if (_viewOrder is null)
            return;

        await LoadPaymentDictionariesAsync();

        _paymentForm = new PaymentFormModel
        {
            PaymentTypeId = FullPaymentId,
            Amount = _viewOrder.TotalRemainingAmount,
            PaymentDate = DateTime.Now
        };

        _isPaymentModalOpen = true;
    }

    private void ClosePaymentModal()
    {
        _isPaymentModalOpen = false;
        _paymentForm = new PaymentFormModel();
    }

    private async Task CreatePaymentAsync()
    {
        if (!ValidatePaymentAmount())
            return;

        if (_paymentForm.PaymentTypeId == FullPaymentId)
        {
            await CreateFullPaymentAsync();
            return;
        }

        await CreateSinglePaymentAsync();
    }

    private async Task CreateFullPaymentAsync()
    {
        if (_viewOrder is null)
            return;

        var rentalType = _paymentTypes
            .FirstOrDefault(x => x.Name == "Аренда");

        var depositType = _paymentTypes
            .FirstOrDefault(x => x.Name == "Залог");

        if (rentalType is null || depositType is null)
        {
            NotificationService.Error("Не найдены типы оплаты");
            return;
        }

        if (_paymentForm.PaymentMethodId is null)
        {
            NotificationService.Error("Выберите способ оплаты");
            return;
        }

        if (_viewOrder.RemainingRentalAmount > 0)
        {
            var rentalRequest = new CreatePaymentRequest(
                _viewOrder.Id,
                rentalType.Id,
                _paymentForm.PaymentMethodId.Value,
                _viewOrder.RemainingRentalAmount,
                _paymentForm.PaymentDate,
                _paymentForm.Comment);

            var rentalResult = await PaymentsService.CreatePaymentAsync(rentalRequest);

            if (rentalResult.IsFailure)
            {
                NotificationService.Error(rentalResult.Error.Message);
                return;
            }
        }

        if (_viewOrder.RemainingDepositAmount > 0)
        {
            var depositRequest = new CreatePaymentRequest(
                _viewOrder.Id,
                depositType.Id,
                _paymentForm.PaymentMethodId.Value,
                _viewOrder.RemainingDepositAmount,
                _paymentForm.PaymentDate,
                _paymentForm.Comment);

            var depositResult = await PaymentsService.CreatePaymentAsync(depositRequest);

            if (depositResult.IsFailure)
            {
                NotificationService.Error(depositResult.Error.Message);
                return;
            }
        }

        ClosePaymentModal();

        await ReloadViewOrderAsync();

        NotificationService.Success("Полная оплата успешно принята");
    }

    private async Task CreateSinglePaymentAsync()
    {
        if (_viewOrder is null)
        {
            NotificationService.Error("Заказ не выбран");
            return;
        }

        if (_paymentForm.PaymentTypeId is null)
        {
            NotificationService.Error("Выберите тип оплаты");
            return;
        }

        if (_paymentForm.PaymentMethodId is null)
        {
            NotificationService.Error("Выберите способ оплаты");
            return;
        }

        if (_paymentForm.Amount <= 0)
        {
            NotificationService.Error("Сумма оплаты должна быть больше 0");
            return;
        }

        var request = new CreatePaymentRequest(
            OrderId: _viewOrder.Id,
            PaymentTypeId: _paymentForm.PaymentTypeId.Value,
            PaymentMethodId: _paymentForm.PaymentMethodId.Value,
            Amount: _paymentForm.Amount,
            PaymentDate: _paymentForm.PaymentDate,
            Comment: _paymentForm.Comment);

        var result = await PaymentsService.CreatePaymentAsync(request);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        ClosePaymentModal();

        await ReloadViewOrderAsync();

        NotificationService.Success("Оплата успешно принята");
    }

    private async Task LoadPaymentDictionariesAsync()
    {
        var typesResult = await DictionaryCrudService.GetListAsync<DictionaryItem>(
            "api/payment-types",
            "payment.types.load.failed",
            "Не удалось загрузить типы оплаты");

        if (typesResult.IsSuccess)
        {
            _paymentTypes =
            [
                new DictionaryItem(
                    FullPaymentId,
                    "Полная оплата",
                    null,
                    string.Empty,
                    null),

                ..typesResult.Value
            ];

            _depositRefundPaymentTypeId = typesResult.Value
                .FirstOrDefault(x => x.Name == "Возврат залога")
                ?.Id;
        }

        var methodsResult = await DictionaryCrudService.GetListAsync<DictionaryItem>(
            "api/payment-methods",
            "payment.methods.load.failed",
            "Не удалось загрузить способы оплаты");

        if (methodsResult.IsSuccess)
            _paymentMethods = methodsResult.Value;
    }

    private void OnPaymentTypeChanged()
    {
        if (_viewOrder is null || _paymentForm.PaymentTypeId is null)
            return;

        if (_paymentForm.PaymentTypeId == FullPaymentId)
        {
            _paymentForm.Amount = _viewOrder.TotalRemainingAmount;
            return;
        }

        var selectedType = _paymentTypes
            .FirstOrDefault(x => x.Id == _paymentForm.PaymentTypeId);

        if (selectedType is null)
            return;

        _paymentForm.Amount = selectedType.Name switch
        {
            "Аренда" => _viewOrder.RemainingRentalAmount,
            "Залог" => _viewOrder.RemainingDepositAmount,
            _ => 0
        };
    }

    private async Task ReloadViewOrderAsync()
    {
        if (_viewOrder is null)
            return;

        var orderId = _viewOrder.Id;

        var result = await OrdersService.GetByIdAsync(orderId);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        _viewOrder = result.Value;

        await LoadOrderDocumentsAsync(orderId);
    }

    private async Task IssueToolsAsync()
    {
        if (_viewOrder is null)
        {
            NotificationService.Error("Заказ не выбран");
            return;
        }

        var result = await OrdersService.IssueAsync(_viewOrder.Id);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        await ReloadViewOrderAsync();

        NotificationService.Success("Инструменты успешно выданы");
    }

    private void OpenReturnModal()
    {
        if (_viewOrder is null)
            return;

        _returnForm = new ReturnFormModel
        {
            ActualReturnedDate = DateOnly.FromDateTime(DateTime.Today),
            ReturnCondition = "Исправно",
            SelectedOrderItemIds = []
        };

        _isReturnModalOpen = true;
    }

    private void CloseReturnModal()
    {
        _isReturnModalOpen = false;
        _returnForm = new ReturnFormModel();
    }

    private async Task ReturnItemsAsync()
    {
        if (_viewOrder is null)
        {
            NotificationService.Error("Заказ не выбран");
            return;
        }

        if (_returnForm.SelectedOrderItemIds.Count == 0)
        {
            NotificationService.Error("Выберите инструменты для возврата");
            return;
        }

        var request = new ReturnOrderItemsRequest(
            _returnForm.ActualReturnedDate,
            _returnForm.ReturnCondition,
            _returnForm.DamageComment,
            _returnForm.SelectedOrderItemIds);

        var result = await OrdersService.ReturnItemsAsync(
            _viewOrder.Id,
            request);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        CloseReturnModal();

        await ReloadViewOrderAsync();

        NotificationService.Success("Возврат успешно оформлен");
    }

    private void ToggleReturnItem(Guid orderItemId, ChangeEventArgs e)
    {
        var isChecked = e.Value is bool value && value;

        if (isChecked)
        {
            if (!_returnForm.SelectedOrderItemIds.Contains(orderItemId))
                _returnForm.SelectedOrderItemIds.Add(orderItemId);

            return;
        }

        _returnForm.SelectedOrderItemIds.Remove(orderItemId);
    }

    private async Task OpenDepositRefundModal()
    {
        if (_viewOrder is null)
            return;

        _depositRefundForm = new DepositRefundFormModel
        {
            Amount = _viewOrder.RemainingDepositRefundAmount,
            PaymentDate = DateTime.Now
        };

        await LoadPaymentDictionariesAsync();

        _isDepositRefundModalOpen = true;
    }

    private void CloseDepositRefundModal()
    {
        _isDepositRefundModalOpen = false;
        _depositRefundForm = new DepositRefundFormModel();
    }

    private async Task ReturnDepositAsync()
    {
        if (_viewOrder is null)
        {
            NotificationService.Error("Заказ не выбран");
            return;
        }

        if (!_viewOrder.AllItemsReturned)
        {
            NotificationService.Error("Залог можно вернуть только после возврата всех инструментов");
            return;
        }

        if (_depositRefundForm.PaymentMethodId is null)
        {
            NotificationService.Error("Выберите способ возврата");
            return;
        }

        if (_depositRefundForm.Amount <= 0)
        {
            NotificationService.Error("Сумма возврата должна быть больше 0");
            return;
        }

        if (_depositRefundForm.Amount > _viewOrder.RemainingDepositRefundAmount)
        {
            NotificationService.Error("Сумма возврата не может быть больше остатка залога");
            return;
        }

        if (_depositRefundPaymentTypeId is null)
        {
            NotificationService.Error("Тип оплаты «Возврат залога» не найден");
            return;
        }

        var request = new CreatePaymentRequest(
            _viewOrder.Id,
            _depositRefundPaymentTypeId.Value,
            _depositRefundForm.PaymentMethodId.Value,
            _depositRefundForm.Amount,
            _depositRefundForm.PaymentDate,
            _depositRefundForm.Comment);

        var result = await PaymentsService.CreatePaymentAsync(request);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        CloseDepositRefundModal();

        await ReloadViewOrderAsync();

        NotificationService.Success("Залог успешно возвращен");
    }

    private bool ValidatePaymentAmount()
    {
        if (_viewOrder is null)
            return false;

        if (_paymentForm.PaymentTypeId is null)
        {
            NotificationService.Error("Выберите тип оплаты");
            return false;
        }

        if (_paymentForm.Amount <= 0)
        {
            NotificationService.Error("Сумма оплаты должна быть больше 0");
            return false;
        }

        if (_paymentForm.PaymentTypeId == FullPaymentId)
        {
            if (_paymentForm.Amount != _viewOrder.TotalRemainingAmount)
            {
                NotificationService.Error("Полная оплата должна быть равна остатку к оплате");
                return false;
            }

            return true;
        }

        var selectedType = _paymentTypes
            .FirstOrDefault(x => x.Id == _paymentForm.PaymentTypeId);

        if (selectedType is null)
        {
            NotificationService.Error("Тип оплаты не найден");
            return false;
        }

        var maxAmount = selectedType.Name switch
        {
            "Аренда" => _viewOrder.RemainingRentalAmount,
            "Залог" => _viewOrder.RemainingDepositAmount,
            _ => 0
        };

        if (_paymentForm.Amount > maxAmount)
        {
            NotificationService.Error(
                $"Сумма оплаты по типу «{selectedType.Name}» не может превышать {maxAmount:N2} ₽");

            return false;
        }

        return true;
    }

