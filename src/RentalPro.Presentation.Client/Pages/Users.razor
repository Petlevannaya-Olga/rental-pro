    private async Task ToggleUserStatus()
    {
        if (_selectedUser is null)
            return;

        try
        {
            await UsersApiClient.ChangeStatusAsync(
                _selectedUser.Id,
                !_selectedUser.IsActive);

            NotificationService.Success(
                _selectedUser.IsActive
                    ? "Пользователь успешно заблокирован"
                    : "Пользователь успешно разблокирован");

            CloseBlockModal();

            await LoadUsersAsync();
            await LoadStatsAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Error(
                $"Не удалось изменить статус пользователя: {ex.Message}");
        }
    }

    private async Task UpdateUser()
    {
        if (_editUser.RoleId is null)
        {
            NotificationService.Error("Выберите роль");
            return;
        }

        var request = new UpdateUserRequest
        {
            LastName = _editUser.LastName,
            FirstName = _editUser.FirstName,
            MiddleName = _editUser.MiddleName,
            Login = _editUser.Login,
            Email = _editUser.Email,
            PhoneNumber = _editUser.PhoneNumber,
            RoleId = _editUser.RoleId.Value
        };

        await UsersApiClient.UpdateUserAsync(_editUser.Id, request);

        NotificationService.Success("Пользователь обновлен");

        CloseEditModal();

        await LoadUsersAsync();
        await LoadStatsAsync();
    }
    
