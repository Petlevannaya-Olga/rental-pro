@page "/tools"
@layout AdminLayout

@using System.ComponentModel.DataAnnotations
@using RentalPro.Contracts.Tools
@using RentalPro.Presentation.Client.Models
@using RentalPro.Presentation.Client.Models.Dictionaries
@using RentalPro.Presentation.Client.Services

@inject NotificationService NotificationService
@inject ToolsService ToolsService
@inject DictionaryCrudService DictionaryCrudService
@inject FakeToolGeneratorService FakeToolGeneratorService

<div class="users-page">

    <div class="users-stats">

        <div class="stats-filter-card @GetStatsCardClass("all")"
             @onclick='() => ApplyStatsFilter("all")'>
            <StatCard Title="Всего инструментов"
                      Value="@_statsTotalCount.ToString()"
                      Icon="bi bi-tools"
                      Color="blue"/>
        </div>

        <div class="stats-filter-card @GetStatsCardClass("available")"
             @onclick='() => ApplyStatsFilter("available")'>
            <StatCard Title="Доступно"
                      Value="@_availableCount.ToString()"
                      Icon="bi bi-check-circle"
                      Color="green"/>
        </div>

        <div class="stats-filter-card @GetStatsCardClass("rented")"
             @onclick='() => ApplyStatsFilter("rented")'>
            <StatCard Title="В аренде"
                      Value="@_rentedCount.ToString()"
                      Icon="bi bi-arrow-left-right"
                      Color="orange"/>
        </div>

        <div class="stats-filter-card @GetStatsCardClass("repair")"
             @onclick='() => ApplyStatsFilter("repair")'>
            <StatCard Title="На ремонте"
                      Value="@_repairCount.ToString()"
                      Icon="bi bi-wrench-adjustable"
                      Color="red"/>
        </div>

        <button class="users-add-card"
                @onclick="OpenCreateModal">
            <i class="bi bi-plus-lg"></i>
            <span>Добавить инструмент</span>
        </button>

    </div>

    <div class="users-table-card">

        <div class="users-filters">
            <div class="users-filters-top">

                <div class="filter-group search-filter">
                    <label>Поиск по названию, инвентарному или серийному номеру</label>

                    <div class="search-box">
                        <i class="bi bi-search"></i>

                        <input placeholder="Название, инв. номер или серийный номер..."
                               value="@_search"
                               @oninput="OnSearchChanged"/>
                    </div>
                </div>

                <button class="secondary-button" @onclick="ExportTools">
                    <i class="bi bi-download"></i>
                    Экспорт
                </button>

            </div>

            <div class="users-filters-bottom">

                <div class="filter-group">
                    <label>Категория</label>

                    <select class="filter-select"
                            @bind="_categoryId"
                            @bind:after="ApplyFilters">
                        <option value="">Все категории</option>

                        @foreach (var category in _categories)
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    </select>
                </div>

                <div class="filter-group">
                    <label>Статус</label>

                    <select class="filter-select"
                            @bind="_statusId"
                            @bind:after="ApplyFilters">
                        <option value="">Все статусы</option>

                        @foreach (var status in _statuses)
                        {
                            <option value="@status.Id">@status.Name</option>
                        }
                    </select>
                </div>

                <div class="filter-group">
                    <label>Производитель</label>

                    <select class="filter-select"
                            @bind="_manufacturerId"
                            @bind:after="ApplyFilters">
                        <option value="">Все производители</option>

                        @foreach (var manufacturer in _manufacturers)
                        {
                            <option value="@manufacturer.Id">@manufacturer.Name</option>
                        }
                    </select>
                </div>

                <div class="filter-group">
                    <button class="secondary-button filter-reset-button"
                            @onclick="ResetFilters">
                        <i class="bi bi-arrow-counterclockwise"></i>
                        Сбросить
                    </button>
                </div>

            </div>
        </div>

        @if (_isLoading)
        {
            <table class="users-table">
                <thead>
                <tr>
                    <th>Инструмент</th>
                    <th>Категория</th>
                    <th>Производитель</th>
                    <th>Серийный номер</th>
                    <th>Аренда/день</th>
                    <th>Залог</th>
                    <th>Статус</th>
                    <th></th>
                </tr>
                </thead>

                <tbody>
                @for (var i = 0; i < PageSize; i++)
                {
                    <tr>
                        <td>
                            <div class="skeleton-user-cell">
                                <div class="skeleton skeleton-avatar"></div>
                                <div class="skeleton-lines">
                                    <div class="skeleton skeleton-line wide"></div>
                                    <div class="skeleton skeleton-line small"></div>
                                </div>
                            </div>
                        </td>

                        <td>
                            <div class="skeleton skeleton-line medium"></div>
                        </td>
                        <td>
                            <div class="skeleton skeleton-line medium"></div>
                        </td>
                        <td>
                            <div class="skeleton skeleton-line medium"></div>
                        </td>
                        <td>
                            <div class="skeleton skeleton-line small"></div>
                        </td>
                        <td>
                            <div class="skeleton skeleton-line small"></div>
                        </td>
                        <td>
                            <div class="skeleton skeleton-badge"></div>
                        </td>
                        <td>
                            <div class="skeleton skeleton-dot"></div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
        else if (_tools.Count == 0)
        {
            <div class="table-empty">Инструменты не найдены</div>
        }
        else
        {
            <table class="users-table">
                <thead>
                <tr>
                    <th class="sortable-column" @onclick='() => ChangeSort("name")'>
                        Инструмент <i class="bi bi-arrow-down-up"></i>
                    </th>
                    <th class="sortable-column" @onclick='() => ChangeSort("category")'>
                        Категория <i class="bi bi-arrow-down-up"></i>
                    </th>
                    <th class="sortable-column" @onclick='() => ChangeSort("manufacturer")'>
                        Производитель <i class="bi bi-arrow-down-up"></i>
                    </th>
                    <th class="sortable-column" @onclick='() => ChangeSort("serialnumber")'>
                        Серийный номер <i class="bi bi-arrow-down-up"></i>
                    </th>
                    <th class="sortable-column" @onclick='() => ChangeSort("rentalprice")'>
                        Аренда/день <i class="bi bi-arrow-down-up"></i>
                    </th>
                    <th class="sortable-column" @onclick='() => ChangeSort("deposit")'>
                        Залог <i class="bi bi-arrow-down-up"></i>
                    </th>
                    <th class="sortable-column" @onclick='() => ChangeSort("status")'>
                        Статус <i class="bi bi-arrow-down-up"></i>
                    </th>
                    <th></th>
                </tr>
                </thead>

                <tbody>
                @foreach (var tool in _tools)
                {
                    <tr>
                        <td>
                            <div class="user-cell">
                                <div class="user-avatar">
                                    <i class="bi bi-tools"></i>
                                </div>

                                <div>
                                    <strong>@tool.Name</strong>
                                    <span>Инв. № @tool.InventoryNumber</span>
                                </div>
                            </div>
                        </td>

                        <td>@tool.CategoryName</td>
                        <td>@tool.ManufacturerName</td>
                        <td>@tool.SerialNumber</td>
                        <td>@tool.RentalPricePerDay.ToString("N0") ₽</td>
                        <td>@tool.DepositAmount.ToString("N0") ₽</td>

                        <td>
                            <span class="@GetStatusClass(tool.StatusName)">
                                @tool.StatusName
                            </span>
                        </td>

                        <td class="actions-cell">
                            <button class="icon-button"
                                    @onclick="() => OpenActionsMenu(tool)">
                                <i class="bi bi-three-dots"></i>
                            </button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }

        <Pagination CurrentPage="_currentPage"
                    TotalPages="TotalPages"
                    TotalItems="_filteredTotalCount"
                    StartItem="PageStart"
                    EndItem="PageEnd"
                    PageChanged="GoToPage">
            <LeftContent>
                <button class="secondary-button"
                        type="button"
                        @onclick="GenerateFakeTools">
                    <i class="bi bi-magic"></i>
                    Заполнить тестовыми данными
                </button>
            </LeftContent>
        </Pagination>

    </div>

    @if (_isActionsMenuOpen && _selectedTool is not null)
    {
        <div class="actions-backdrop" @onclick="CloseActionsMenu">
            <div class="actions-modal" @onclick:stopPropagation="true">
                <div class="actions-modal-header">
                    <div>
                        <h3>Действия с инструментом</h3>
                        <p>@_selectedTool.Name</p>
                    </div>

                    <button type="button" @onclick="CloseActionsMenu">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <button class="menu-item" @onclick='() => ExecuteToolAction("Просмотр")'>
                    <i class="bi bi-eye"></i>
                    Просмотр
                </button>

                <button class="menu-item" @onclick='() => ExecuteToolAction("Редактирование")'>
                    <i class="bi bi-pencil"></i>
                    Редактировать
                </button>

                <button class="menu-item" @onclick='() => ExecuteToolAction("История аренды")'>
                    <i class="bi bi-clock-history"></i>
                    История аренды
                </button>

                @if (_selectedTool?.StatusName is "Доступен" or "На ремонте")
                {
                    <div class="menu-divider"></div>
                }

                @if (_selectedTool?.StatusName == "Доступен")
                {
                    <button class="menu-item" @onclick='() => ExecuteToolAction("Перевод в ремонт")'>
                        <i class="bi bi-wrench-adjustable"></i>
                        Перевести в ремонт
                    </button>
                }

                @if (_selectedTool?.StatusName == "На ремонте")
                {
                    <button class="menu-item" @onclick='() => ExecuteToolAction("Завершение ремонта")'>
                        <i class="bi bi-check-circle"></i>
                        Завершить ремонт
                    </button>

                    <button class="menu-item" @onclick='() => ExecuteToolAction("Списание")'>
                        <i class="bi bi-box-seam"></i>
                        Списать
                    </button>
                }

                @if (_selectedTool?.StatusName is not ("Забронирован" or "В аренде"))
                {
                    <div class="menu-divider"></div>

                    <button class="menu-item menu-danger" @onclick='() => ExecuteToolAction("Удаление")'>
                        <i class="bi bi-trash"></i>
                        Удалить
                    </button>
                }
            </div>
        </div>
    }

    @if (_isCreateModalOpen)
    {
        <div class="actions-backdrop">
            <div class="tool-create-modal large" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>Добавить инструмент</h3>
                        <p>Заполните данные инструмента</p>
                    </div>

                    <button type="button" @onclick="CloseCreateModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <EditForm Model="_newTool" OnValidSubmit="CreateTool">
                    <DataAnnotationsValidator/>

                    <div class="tool-create-layout tool-create-layout-compact">

                        <div class="photo-panel tool-photo-panel">
                            <label>Фотография инструмента</label>

                            <div class="photo-upload">

                                <div class="photo-preview">
                                    @if (!string.IsNullOrWhiteSpace(_photoPreviewUrl))
                                    {
                                        <img src="@_photoPreviewUrl" alt="Фото инструмента"/>
                                    }
                                    else
                                    {
                                        <i class="bi bi-tools"></i>
                                    }
                                </div>

                                <p class="photo-title">
                                    Перетащите файл сюда
                                </p>

                                <p class="photo-subtitle">
                                    или нажмите для выбора
                                </p>

                                <p class="photo-formats">
                                    PNG, JPG, JPEG до 10 МБ
                                </p>

                                <label class="photo-button">
                                    <i class="bi bi-upload"></i>
                                    Выбрать файл

                                    <InputFile OnChange="HandlePhotoSelected"
                                               accept="image/*"/>
                                </label>

                            </div>
                        </div>

                        <div class="tool-form-panel tool-form-panel-compact">

                            <div class="tool-form-grid tool-form-grid-compact">

                                <div class="tool-form-field">
                                    <label>Название <span>*</span></label>
                                    <InputText @bind-Value="_newTool.Name"
                                               placeholder="Введите название"/>
                                    <ValidationMessage For="@(() => _newTool.Name)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Артикул <span>*</span></label>
                                    <InputText @bind-Value="_newTool.ArticleNumber"
                                               placeholder="Введите артикул"/>
                                    <ValidationMessage For="@(() => _newTool.ArticleNumber)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Категория <span>*</span></label>
                                    <InputSelect @bind-Value="_newTool.CategoryId">
                                        <option value="">Выберите категорию</option>
                                        @foreach (var category in _categories)
                                        {
                                            <option value="@category.Id">@category.Name</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => _newTool.CategoryId)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Производитель <span>*</span></label>
                                    <InputSelect @bind-Value="_newTool.ManufacturerId">
                                        <option value="">Выберите производителя</option>
                                        @foreach (var manufacturer in _manufacturers)
                                        {
                                            <option value="@manufacturer.Id">@manufacturer.Name</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => _newTool.ManufacturerId)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Статус</label>

                                    <InputSelect @bind-Value="_newTool.StatusId"
                                                 disabled>
                                        @foreach (var status in _statuses)
                                        {
                                            <option value="@status.Id">
                                                @status.Name
                                            </option>
                                        }
                                    </InputSelect>
                                </div>

                                <div class="tool-form-field">
                                    <label>Серийный номер <span>*</span></label>
                                    <InputText @bind-Value="_newTool.SerialNumber"
                                               placeholder="Введите серийный номер"/>
                                    <ValidationMessage For="@(() => _newTool.SerialNumber)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Инвентарный номер <span>*</span></label>
                                    <InputText @bind-Value="_newTool.InventoryNumber"
                                               placeholder="Введите инвентарный номер"/>
                                    <ValidationMessage For="@(() => _newTool.InventoryNumber)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Стоимость аренды за день <span>*</span></label>
                                    <InputNumber @bind-Value="_newTool.RentalPricePerDay"/>
                                    <ValidationMessage For="@(() => _newTool.RentalPricePerDay)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Залог <span>*</span></label>
                                    <InputNumber @bind-Value="_newTool.DepositAmount"/>
                                    <ValidationMessage For="@(() => _newTool.DepositAmount)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Текущее состояние</label>
                                    <InputText @bind-Value="_newTool.CurrentCondition"
                                               placeholder="Введите состояние"/>
                                </div>

                                <div class="tool-form-field tool-description-field">
                                    <label>Описание</label>
                                    <InputTextArea @bind-Value="_newTool.Description"
                                                   placeholder="Краткое описание инструмента"/>
                                </div>

                            </div>
                        </div>
                    </div>

                    <div class="tool-form-actions modal-footer">
                        <button class="secondary-button"
                                type="button"
                                @onclick="CloseCreateModal">
                            Отмена
                        </button>

                        <button class="secondary-button"
                                type="button"
                                @onclick="FillFakeToolData">
                            <i class="bi bi-magic"></i>
                            Заполнить тестовыми данными
                        </button>

                        <button class="primary-button"
                                type="submit">
                            <i class="bi bi-check-lg"></i>
                            Сохранить инструмент
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @if (_isViewModalOpen && _viewTool is not null)
    {
        <div class="actions-backdrop">
            <div class="tool-view-modal" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>@_viewTool.Name</h3>
                        <p>Карточка инструмента</p>
                    </div>

                    <button type="button" @onclick="CloseViewModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="tool-view-layout">

                    <div class="tool-view-photo">
                        @if (!string.IsNullOrWhiteSpace(_viewTool.PhotoPath))
                        {
                            <img src="@GetToolImageUrl(_viewTool.PhotoPath)"
                                 alt="@_viewTool.Name"/>
                        }
                        else
                        {
                            <div class="tool-view-photo-empty">
                                <i class="bi bi-camera"></i>
                                <span>Фотография не загружена</span>
                            </div>
                        }
                    </div>

                    <div class="tool-view-info">

                        <div class="tool-view-grid">
                            <div class="tool-view-item">
                                <span>Артикул</span>
                                <strong>@_viewTool.ArticleNumber</strong>
                            </div>

                            <div class="tool-view-item">
                                <span>Категория</span>
                                <strong>@_viewTool.CategoryName</strong>
                            </div>

                            <div class="tool-view-item">
                                <span>Производитель</span>
                                <strong>@_viewTool.ManufacturerName</strong>
                            </div>

                            <div class="tool-view-item">
                                <span>Статус</span>
                                <strong>
                                <span class="@GetStatusClass(_viewTool.StatusName)">
                                    @_viewTool.StatusName
                                </span>
                                </strong>
                            </div>

                            <div class="tool-view-item">
                                <span>Серийный номер</span>
                                <strong>@_viewTool.SerialNumber</strong>
                            </div>

                            <div class="tool-view-item">
                                <span>Инвентарный номер</span>
                                <strong>@_viewTool.InventoryNumber</strong>
                            </div>

                            <div class="tool-view-item">
                                <span>Аренда за день</span>
                                <strong>@_viewTool.RentalPricePerDay.ToString("N0") ₽</strong>
                            </div>

                            <div class="tool-view-item">
                                <span>Залог</span>
                                <strong>@_viewTool.DepositAmount.ToString("N0") ₽</strong>
                            </div>
                        </div>

                        <div class="tool-view-section">
                            <span>Текущее состояние</span>
                            <p>@(_viewTool.CurrentCondition ?? "Не указано")</p>
                        </div>

                        <div class="tool-view-section">
                            <span>Описание</span>
                            <p>@(_viewTool.Description ?? "Описание не указано")</p>
                        </div>

                    </div>
                </div>

                <div class="tool-form-actions modal-footer">
                    <button class="secondary-button"
                            type="button"
                            @onclick="CloseViewModal">
                        Закрыть
                    </button>
                </div>

            </div>
        </div>
    }

    @if (_isEditModalOpen && _editingTool is not null)
    {
        <div class="actions-backdrop">
            <div class="tool-create-modal large" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>Редактировать инструмент</h3>
                        <p>Измените данные инструмента</p>
                    </div>

                    <button type="button" @onclick="CloseEditModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <EditForm Model="_editTool" OnValidSubmit="UpdateTool">
                    <DataAnnotationsValidator/>

                    <div class="tool-create-layout tool-create-layout-compact">

                        <div class="photo-panel tool-photo-panel">
                            <label>Фотография инструмента</label>

                            <div class="photo-upload tool-photo-upload">

                                @if (!string.IsNullOrWhiteSpace(_editPhotoPreviewUrl))
                                {
                                    <div class="photo-preview image">
                                        <img src="@_editPhotoPreviewUrl"
                                             alt="@_editTool.Name"/>
                                    </div>
                                }
                                else
                                {
                                    <div class="photo-preview">
                                        <i class="bi bi-camera"></i>
                                    </div>
                                }

                                <p class="photo-title">Перетащите файл сюда</p>
                                <p class="photo-subtitle">или нажмите для выбора</p>
                                <p class="photo-formats">PNG, JPG, JPEG до 10 МБ</p>

                                <label class="photo-button">
                                    <i class="bi bi-upload"></i>
                                    Заменить фото

                                    <InputFile OnChange="HandleEditPhotoSelected"
                                               accept="image/*"/>
                                </label>
                            </div>
                        </div>

                        <div class="tool-form-panel tool-form-panel-compact">

                            <div class="tool-form-grid tool-form-grid-compact">

                                <div class="tool-form-field">
                                    <label>Название <span>*</span></label>
                                    <InputText @bind-Value="_editTool.Name"
                                               placeholder="Введите название"/>
                                    <ValidationMessage For="@(() => _editTool.Name)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Артикул <span>*</span></label>
                                    <InputText @bind-Value="_editTool.ArticleNumber"
                                               placeholder="Введите артикул"/>
                                    <ValidationMessage For="@(() => _editTool.ArticleNumber)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Категория <span>*</span></label>
                                    <InputSelect @bind-Value="_editTool.CategoryId">
                                        <option value="">Выберите категорию</option>
                                        @foreach (var category in _categories)
                                        {
                                            <option value="@category.Id">@category.Name</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => _editTool.CategoryId)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Производитель <span>*</span></label>
                                    <InputSelect @bind-Value="_editTool.ManufacturerId">
                                        <option value="">Выберите производителя</option>
                                        @foreach (var manufacturer in _manufacturers)
                                        {
                                            <option value="@manufacturer.Id">@manufacturer.Name</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => _editTool.ManufacturerId)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Статус</label>

                                    <div class="readonly-status">
                                        <span class="@GetStatusClass(_editingTool.StatusName)">
                                            @_editingTool.StatusName
                                        </span>
                                    </div>
                                </div>

                                <div class="tool-form-field">
                                    <label>Серийный номер <span>*</span></label>
                                    <InputText @bind-Value="_editTool.SerialNumber"
                                               placeholder="Введите серийный номер"/>
                                    <ValidationMessage For="@(() => _editTool.SerialNumber)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Инвентарный номер <span>*</span></label>
                                    <InputText @bind-Value="_editTool.InventoryNumber"
                                               placeholder="Введите инвентарный номер"/>
                                    <ValidationMessage For="@(() => _editTool.InventoryNumber)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Стоимость аренды за день <span>*</span></label>
                                    <InputNumber @bind-Value="_editTool.RentalPricePerDay"/>
                                    <ValidationMessage For="@(() => _editTool.RentalPricePerDay)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Залог <span>*</span></label>
                                    <InputNumber @bind-Value="_editTool.DepositAmount"/>
                                    <ValidationMessage For="@(() => _editTool.DepositAmount)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Текущее состояние</label>
                                    <InputText @bind-Value="_editTool.CurrentCondition"
                                               placeholder="Введите состояние"/>
                                </div>

                                <div class="tool-form-field tool-description-field">
                                    <label>Описание</label>
                                    <InputTextArea @bind-Value="_editTool.Description"
                                                   placeholder="Краткое описание инструмента"/>
                                </div>

                            </div>

                        </div>
                    </div>

                    <div class="tool-form-actions modal-footer">
                        <button class="secondary-button"
                                type="button"
                                @onclick="CloseEditModal">
                            Отмена
                        </button>

                        <button class="primary-button"
                                type="submit">
                            <i class="bi bi-check-lg"></i>
                            Сохранить изменения
                        </button>
                    </div>
                </EditForm>

            </div>
        </div>
    }
    
    @if (_isRentalHistoryModalOpen && _rentalHistoryTool is not null)
{
    <div class="actions-backdrop" @onclick="CloseRentalHistoryModal">
        <div class="rental-history-modal" @onclick:stopPropagation="true">

            <div class="actions-modal-header">
                <div>
                    <h3>История аренды</h3>
                    <p>@_rentalHistoryTool.Name — инв. № @_rentalHistoryTool.InventoryNumber</p>
                </div>

                <button type="button" @onclick="CloseRentalHistoryModal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="rental-history-table-wrap">
                @if (_isRentalHistoryLoading)
                {
                    <div class="table-empty">
                        Загрузка истории аренды...
                    </div>
                }
                else if (_rentalHistory.Count == 0)
                {
                    <div class="table-empty">
                        По этому инструменту еще не было аренд
                    </div>
                }
                else
                {
                    <table class="users-table rental-history-table">
                        <thead>
                        <tr>
                            <th>№ заказа</th>
                            <th>Клиент</th>
                            <th>Начало</th>
                            <th>План</th>
                            <th>Факт</th>
                            <th>Дней</th>
                            <th>Сумма</th>
                            <th>Статус</th>
                        </tr>
                        </thead>

                        <tbody>
                        @foreach (var item in _rentalHistory)
                        {
                            <tr>
                                <td>
                                    <strong>@item.OrderNumber</strong>
                                </td>

                                <td>@item.CustomerFullName</td>

                                <td>@item.StartDate.ToString("dd.MM.yyyy")</td>

                                <td>@item.PlannedReturnDate.ToString("dd.MM.yyyy")</td>

                                <td>
                                    @(item.ActualReturnedDate?.ToString("dd.MM.yyyy") ?? "-")
                                </td>

                                <td>@item.RentalDays</td>

                                <td>@($"{item.RentalAmount:N0} ₽")</td>

                                <td>
                                    <span class="@GetOrderStatusClass(item.OrderStatusName)">
                                        @item.OrderStatusName
                                    </span>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>

            <div class="customer-view-footer">
                <button class="secondary-button"
                        type="button"
                        @onclick="CloseRentalHistoryModal">
                    Закрыть
                </button>
            </div>

        </div>
    </div>
}

</div>

@code
{
    private ToolDto? _rentalHistoryTool;
    private bool _isRentalHistoryModalOpen;
    private List<ToolRentalHistoryItemDto> _rentalHistory = [];
    private bool _isRentalHistoryLoading;
    
    private readonly Random _random = new();
    private CancellationTokenSource? _searchCts;
    private const int PageSize = 5;

    private List<ToolDto> _tools = [];
    private ToolDto? _selectedTool;
    private ToolFormModel _newTool = new();
    private IBrowserFile? _selectedImageFile;
    private string? _photoPreviewUrl;

    private List<DictionaryItem> _categories = [];
    private List<DictionaryItem> _manufacturers = [];
    private List<DictionaryItem> _statuses = [];

    private bool _isLoading = true;
    private bool _isActionsMenuOpen;
    private bool _isCreateModalOpen;

    private int _currentPage = 1;

    private int _statsTotalCount;
    private int _filteredTotalCount;
    private int _availableCount;
    private int _rentedCount;
    private int _repairCount;

    private string? _search;
    private Guid? _categoryId;
    private Guid? _statusId;
    private Guid? _manufacturerId;
    private string? _sortBy = "createdat";
    private bool _descending = true;

    private byte[]? _selectedImageBytes;
    private string? _selectedImageFileName;
    private string? _selectedImageContentType;

    private string _activeStatsFilter = "all";

    private bool _isViewModalOpen;
    private ToolDto? _viewTool;

    private bool _isEditModalOpen;
    private ToolDto? _editingTool;
    private ToolFormModel _editTool = new();

    private byte[]? _editImageBytes;
    private string? _editImageFileName;
    private string? _editImageContentType;
    private string? _editPhotoPreviewUrl;

    private int PageStart =>
        _filteredTotalCount == 0 ? 0 : ((_currentPage - 1) * PageSize) + 1;

    private int PageEnd =>
        Math.Min(_currentPage * PageSize, _filteredTotalCount);

    private int TotalPages =>
        _filteredTotalCount <= 0
            ? 1
            : (int)Math.Ceiling(_filteredTotalCount / (double)PageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadDictionariesAsync();
        await LoadStatsAsync();
        await LoadToolsAsync();
    }

    private async Task LoadDictionariesAsync()
    {
        await LoadDictionaryAsync("api/tool-categories", _categories, "Не удалось загрузить категории инструментов");
        await LoadDictionaryAsync("api/manufacturers", _manufacturers, "Не удалось загрузить производителей");
        await LoadDictionaryAsync("api/tool-statuses", _statuses, "Не удалось загрузить статусы инструментов");
    }

    private async Task LoadDictionaryAsync(
        string url,
        List<DictionaryItem> target,
        string errorMessage)
    {
        target.Clear();

        var result = await DictionaryCrudService.GetListAsync<DictionaryItem>(
            url,
            "dictionary.load.failed",
            errorMessage);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        target.AddRange(result.Value);
    }

    private async Task LoadToolsAsync()
    {
        _isLoading = true;

        var request = new GetToolsRequest(
            Search: _search,
            CategoryId: _categoryId,
            ManufacturerId: _manufacturerId,
            StatusId: _statusId,
            SortBy: _sortBy,
            Descending: _descending,
            Page: _currentPage,
            PageSize: PageSize);

        var result = await ToolsService.GetToolsAsync(request);

        if (result.IsFailure)
        {
            _tools = [];
            _filteredTotalCount = 0;
            _isLoading = false;

            NotificationService.Error(result.Error.Message);
            return;
        }

        _tools = result.Value.Items.ToList();
        _filteredTotalCount = result.Value.TotalCount;

        if (_currentPage > TotalPages)
        {
            _currentPage = TotalPages;
            await LoadToolsAsync();
            return;
        }

        _isLoading = false;
    }

    private async Task LoadStatsAsync()
    {
        var result = await ToolsService.GetStatsAsync();

        if (result.IsFailure)
        {
            _statsTotalCount = 0;
            _availableCount = 0;
            _rentedCount = 0;
            _repairCount = 0;

            NotificationService.Error(result.Error.Message);
            return;
        }

        _statsTotalCount = result.Value.TotalCount;
        _availableCount = result.Value.AvailableCount;
        _rentedCount = result.Value.RentedCount;
        _repairCount = result.Value.RepairCount;
    }

    private async Task ApplyStatsFilter(string filter)
    {
        _activeStatsFilter = filter;

        switch (filter)
        {
            case "all":
                _statusId = null;
                break;

            case "available":
                _statusId = FindStatusId("Доступен");
                break;

            case "rented":
                _statusId = FindStatusId("В аренде");
                break;

            case "repair":
                _statusId = FindStatusId("На ремонте");
                break;
        }

        _currentPage = 1;

        await LoadToolsAsync();
    }

    private async Task ApplyFilters()
    {
        _activeStatsFilter = "custom";
        _currentPage = 1;

        await LoadToolsAsync();
    }

    private async Task ResetFilters()
    {
        _search = string.Empty;
        _categoryId = null;
        _statusId = null;
        _manufacturerId = null;
        _activeStatsFilter = "all";
        _currentPage = 1;

        await LoadToolsAsync();
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        _search = e.Value?.ToString();

        _searchCts?.Cancel();
        _searchCts?.Dispose();

        _searchCts = new CancellationTokenSource();
        var token = _searchCts.Token;

        try
        {
            await Task.Delay(500, token);

            _currentPage = 1;
            await LoadToolsAsync();
        }
        catch (OperationCanceledException)
        {
            // ignored
        }
    }

    private async Task ChangeSort(string sortBy)
    {
        if (_sortBy == sortBy)
            _descending = !_descending;
        else
        {
            _sortBy = sortBy;
            _descending = false;
        }

        _currentPage = 1;

        await LoadToolsAsync();
    }

    private async Task GoToPage(int page)
    {
        if (page < 1)
            return;

        if (page > TotalPages)
            return;

        _currentPage = page;

        await LoadToolsAsync();
    }

    private Guid? FindStatusId(string statusName)
    {
        return _statuses
            .FirstOrDefault(x => x.Name == statusName)
            ?.Id;
    }

    private string GetStatsCardClass(string filter)
    {
        return _activeStatsFilter == filter
            ? "active"
            : string.Empty;
    }

    private void OpenActionsMenu(ToolDto tool)
    {
        _selectedTool = tool;
        _isActionsMenuOpen = true;
    }

    private void CloseActionsMenu()
    {
        _isActionsMenuOpen = false;
        _selectedTool = null;
    }

    private async Task ExecuteToolAction(string action)
    {
        if (_selectedTool is null)
            return;

        if (action == "Просмотр")
        {
            _viewTool = _selectedTool;
            _isViewModalOpen = true;
            CloseActionsMenu();
            return;
        }

        if (action == "Удаление")
        {
            await DeleteTool(_selectedTool);
            return;
        }

        if (action == "Редактирование")
        {
            OpenEditModal(_selectedTool);
            CloseActionsMenu();
            return;
        }
        
        if (action == "Перевод в ремонт")
        {
            await ChangeToolStatus(_selectedTool, "На ремонте");
            return;
        }

        if (action == "Списание")
        {
            await ChangeToolStatus(_selectedTool, "Списан");
            return;
        }
        
        if (action == "История аренды")
        {
            var tool = _selectedTool;

            CloseActionsMenu();

            if (tool is not null)
                await OpenRentalHistoryModal(tool);

            return;
        }
        
        if (action == "Завершение ремонта")
        {
            await ChangeToolStatus(_selectedTool, "Доступен");
            return;
        }

        NotificationService.Info($"{action}: {_selectedTool.Name}");

        CloseActionsMenu();
    }

    private void OpenCreateModal()
    {
        _newTool = new ToolFormModel();

        var availableStatus = _statuses.FirstOrDefault(x => x.Name == "Доступен");

        if (availableStatus is not null)
        {
            _newTool.StatusId = availableStatus.Id;
        }

        _isCreateModalOpen = true;
    }

    private void CloseCreateModal()
    {
        _isCreateModalOpen = false;
    }

    private async Task CreateTool()
    {
        if (_newTool.CategoryId is null ||
            _newTool.ManufacturerId is null ||
            _newTool.StatusId is null)
        {
            NotificationService.Error("Выберите категорию, производителя и статус");
            return;
        }

        var request = new CreateToolRequest(
            ArticleNumber: _newTool.ArticleNumber,
            Name: _newTool.Name,
            Description: _newTool.Description,
            CategoryId: _newTool.CategoryId.Value,
            ManufacturerId: _newTool.ManufacturerId.Value,
            StatusId: _newTool.StatusId.Value,
            RentalPricePerDay: _newTool.RentalPricePerDay,
            DepositAmount: _newTool.DepositAmount,
            SerialNumber: _newTool.SerialNumber,
            InventoryNumber: _newTool.InventoryNumber,
            CurrentCondition: _newTool.CurrentCondition);

        var result = await ToolsService.CreateToolAsync(request);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        var toolId = result.Value;

        var imageUploadFailed = false;

        if (_selectedImageBytes is not null &&
            !string.IsNullOrWhiteSpace(_selectedImageFileName) &&
            !string.IsNullOrWhiteSpace(_selectedImageContentType))
        {
            var uploadResult = await ToolsService.UploadToolImageAsync(
                toolId,
                _selectedImageBytes,
                _selectedImageFileName,
                _selectedImageContentType);

            if (uploadResult.IsFailure)
            {
                imageUploadFailed = true;

                NotificationService.Error(
                    $"Инструмент создан, но фото не загружено: {uploadResult.Error.Message}");
            }
        }

        if (!imageUploadFailed)
        {
            NotificationService.Success($"Инструмент «{_newTool.Name}» успешно добавлен");
        }

        CloseCreateModal();

        _selectedImageBytes = null;
        _selectedImageFileName = null;
        _selectedImageContentType = null;
        _photoPreviewUrl = null;

        _currentPage = 1;

        await LoadStatsAsync();
        await LoadToolsAsync();
    }

    private async Task HandlePhotoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;

        _selectedImageFileName = file.Name;
        _selectedImageContentType = file.ContentType;
        _newTool.PhotoPath = file.Name;

        await using var stream = file.OpenReadStream(
            maxAllowedSize: 10 * 1024 * 1024);

        using var memoryStream = new MemoryStream();

        await stream.CopyToAsync(memoryStream);

        _selectedImageBytes = memoryStream.ToArray();

        var base64 = Convert.ToBase64String(_selectedImageBytes);

        _photoPreviewUrl = $"data:{file.ContentType};base64,{base64}";
    }

    private void RemovePhoto()
    {
        _selectedImageFile = null;
        _newTool.PhotoPath = null;
        _photoPreviewUrl = null;
    }

    private async Task ExportTools()
    {
        var request = new ExportToolsRequest
        {
            Search = _search,
            CategoryId = _categoryId,
            ManufacturerId = _manufacturerId,
            StatusId = _statusId,
            SortBy = _sortBy,
            Descending = _descending
        };

        var result = await ToolsService.ExportToolsAsync(request);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success("Инструменты экспортированы");
    }

    private static T PickRandom<T>(
        IReadOnlyList<T> items,
        Random random)
    {
        return items[random.Next(items.Count)];
    }

    private void FillFakeToolData()
    {
        _newTool = FakeToolGeneratorService.Generate();

        if (_categories.Count > 0)
        {
            _newTool.CategoryId =
                PickRandom(_categories, _random).Id;
        }

        if (_manufacturers.Count > 0)
        {
            _newTool.ManufacturerId =
                PickRandom(_manufacturers, _random).Id;
        }

        SetAvailableStatus();
    }

    private void SetAvailableStatus()
    {
        var availableStatus = _statuses.FirstOrDefault(x => x.Name == "Доступен");

        if (availableStatus is not null)
        {
            _newTool.StatusId = availableStatus.Id;
        }
    }

    private async Task GenerateFakeTools()
    {
        if (_categories.Count == 0 ||
            _manufacturers.Count == 0 ||
            _statuses.Count == 0)
        {
            NotificationService.Error(
                "Не удалось загрузить справочники для генерации инструментов");

            return;
        }

        var availableStatus = _statuses
            .FirstOrDefault(x => x.Name == "Доступен");

        if (availableStatus is null)
        {
            NotificationService.Error("Не найден статус «Доступен»");
            return;
        }

        const int count = 10;

        for (var i = 0; i < count; i++)
        {
            var tool = FakeToolGeneratorService.Generate();

            tool.CategoryId =
                PickRandom(_categories, _random).Id;

            tool.ManufacturerId =
                PickRandom(_manufacturers, _random).Id;

            tool.StatusId = availableStatus.Id;

            var request = new CreateToolRequest(
                ArticleNumber: tool.ArticleNumber,
                Name: tool.Name,
                Description: tool.Description,
                CategoryId: tool.CategoryId!.Value,
                ManufacturerId: tool.ManufacturerId!.Value,
                StatusId: tool.StatusId!.Value,
                RentalPricePerDay: tool.RentalPricePerDay,
                DepositAmount: tool.DepositAmount,
                SerialNumber: tool.SerialNumber,
                InventoryNumber: tool.InventoryNumber,
                CurrentCondition: tool.CurrentCondition);

            var result = await ToolsService.CreateToolAsync(request);

            if (result.IsFailure)
            {
                NotificationService.Error(result.Error.Message);
                return;
            }
        }

        await LoadStatsAsync();
        await LoadToolsAsync();

        NotificationService.Success(
            $"Успешно создано {count} тестовых инструментов");
    }

    private void CloseViewModal()
    {
        _isViewModalOpen = false;
        _viewTool = null;
    }

    private static string GetToolImageUrl(string? photoPath)
    {
        if (string.IsNullOrWhiteSpace(photoPath))
            return string.Empty;

        if (photoPath.StartsWith("http", StringComparison.OrdinalIgnoreCase))
            return photoPath;

        return $"https://localhost:7099{photoPath}";
    }

    private async Task DeleteTool(ToolDto tool)
    {
        var result = await ToolsService.DeleteToolAsync(tool.Id);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success($"Инструмент «{tool.Name}» удалён");

        CloseActionsMenu();

        await LoadStatsAsync();
        await LoadToolsAsync();
    }

    private void OpenEditModal(ToolDto tool)
    {
        _editingTool = tool;

        _editTool = new ToolFormModel
        {
            ArticleNumber = tool.ArticleNumber,
            Name = tool.Name,
            Description = tool.Description,
            CategoryId = tool.CategoryId,
            ManufacturerId = tool.ManufacturerId,
            StatusId = tool.StatusId,
            RentalPricePerDay = tool.RentalPricePerDay,
            DepositAmount = tool.DepositAmount,
            SerialNumber = tool.SerialNumber,
            InventoryNumber = tool.InventoryNumber,
            CurrentCondition = tool.CurrentCondition,
            PhotoPath = tool.PhotoPath
        };

        _editPhotoPreviewUrl = GetToolImageUrl(tool.PhotoPath);

        _editImageBytes = null;
        _editImageFileName = null;
        _editImageContentType = null;

        _isEditModalOpen = true;
    }

    private void CloseEditModal()
    {
        _isEditModalOpen = false;
        _editingTool = null;

        _editTool = new ToolFormModel();

        _editImageBytes = null;
        _editImageFileName = null;
        _editImageContentType = null;
        _editPhotoPreviewUrl = null;
    }

    private async Task HandleEditPhotoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;

        _editImageFileName = file.Name;
        _editImageContentType = file.ContentType;
        _editTool.PhotoPath = file.Name;

        await using var stream = file.OpenReadStream(
            maxAllowedSize: 10 * 1024 * 1024);

        using var memoryStream = new MemoryStream();

        await stream.CopyToAsync(memoryStream);

        _editImageBytes = memoryStream.ToArray();

        var base64 = Convert.ToBase64String(_editImageBytes);

        _editPhotoPreviewUrl = $"data:{file.ContentType};base64,{base64}";
    }

    private async Task UpdateTool()
    {
        if (_editingTool is null)
            return;

        if (_editTool.CategoryId is null ||
            _editTool.ManufacturerId is null ||
            _editTool.StatusId is null)
        {
            NotificationService.Error("Выберите категорию, производителя и статус");
            return;
        }

        var request = new UpdateToolRequest(
            ArticleNumber: _editTool.ArticleNumber,
            Name: _editTool.Name,
            Description: _editTool.Description,
            CategoryId: _editTool.CategoryId.Value,
            ManufacturerId: _editTool.ManufacturerId.Value,
            RentalPricePerDay: _editTool.RentalPricePerDay,
            DepositAmount: _editTool.DepositAmount,
            SerialNumber: _editTool.SerialNumber,
            InventoryNumber: _editTool.InventoryNumber,
            CurrentCondition: _editTool.CurrentCondition);

        var result = await ToolsService.UpdateToolAsync(
            _editingTool.Id,
            request);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        if (_editImageBytes is not null &&
            !string.IsNullOrWhiteSpace(_editImageFileName) &&
            !string.IsNullOrWhiteSpace(_editImageContentType))
        {
            var uploadResult = await ToolsService.UploadToolImageAsync(
                _editingTool.Id,
                _editImageBytes,
                _editImageFileName,
                _editImageContentType);

            if (uploadResult.IsFailure)
            {
                NotificationService.Error(
                    $"Инструмент изменён, но фото не загружено: {uploadResult.Error.Message}");
            }
        }

        NotificationService.Success($"Инструмент «{_editTool.Name}» изменён");

        CloseEditModal();

        await LoadStatsAsync();
        await LoadToolsAsync();
    }
    
    private async Task ChangeToolStatus(
        ToolDto tool,
        string statusName)
    {
        var status = _statuses.FirstOrDefault(x => x.Name == statusName);

        if (status is null)
        {
            NotificationService.Error($"Статус «{statusName}» не найден");
            return;
        }

        var result = await ToolsService.ChangeToolStatusAsync(
            tool.Id,
            status.Id);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success(
            $"Инструмент «{tool.Name}» переведён в статус «{statusName}»");

        CloseActionsMenu();

        await LoadStatsAsync();
        await LoadToolsAsync();
    }
    
    private static string GetStatusClass(string statusName)
    {
        return statusName.Trim().ToLowerInvariant() switch
        {
            "доступен" => "status-badge available",
            "забронирован" => "status-badge reserved",
            "в аренде" => "status-badge rented",
            "на ремонте" => "status-badge maintenance",
            "списан" => "status-badge written-off",
            _ => "status-badge"
        };
    }
    
    private async Task OpenRentalHistoryModal(ToolDto tool)
    {
        _rentalHistoryTool = tool;
        _rentalHistory = [];
        _isRentalHistoryModalOpen = true;
        _isRentalHistoryLoading = true;

        var result = await ToolsService.GetRentalHistoryAsync(tool.Id);

        if (result.IsFailure)
        {
            _isRentalHistoryLoading = false;
            NotificationService.Error(result.Error.Message);
            return;
        }

        _rentalHistory = result.Value;
        _isRentalHistoryLoading = false;
    }
    
    private void CloseRentalHistoryModal()
    {
        _isRentalHistoryModalOpen = false;
        _isRentalHistoryLoading = false;
        _rentalHistoryTool = null;
        _rentalHistory = [];
    }

    private static string GetOrderStatusClass(string statusName)
    {
        return statusName.Trim().ToLowerInvariant() switch
        {
            "забронирован" => "status-badge reserved",
            "в аренде" => "status-badge rented",
            "выполняется" => "status-badge rented",
            "ожидает возврата залога" => "status-badge warning",
            "завершен" => "status-badge available",
            "отменен" => "status-badge cancelled",
            _ => "status-badge"
        };
    }
}