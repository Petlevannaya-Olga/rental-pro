@page "/dictionaries/{DictionaryCode}"
@layout AdminLayout

@using RentalPro.Presentation.Client.Models
@using RentalPro.Presentation.Client.Models.Dictionaries
@using RentalPro.Presentation.Client.Services

@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@inject DictionaryCrudService DictionaryCrudService

<div class="dictionary-details-page">

    <div class="dictionary-header">

        <button class="back-link" @onclick="GoBack">
            <i class="bi bi-arrow-left"></i>
            Назад
        </button>

        <div class="dictionary-title-row">
            <h2>@DictionaryTitle</h2>

            <button class="primary-button" @onclick="OpenCreateModal">
                <i class="bi bi-plus-lg"></i>
                Добавить запись
            </button>
        </div>

    </div>

    <div class="dictionary-details-card">
        @if (_isLoading)
        {
            <table class="tools-table">
                <thead>
                <tr>
                    <th>Название</th>
                    <th>Дата создания</th>
                    <th>Дата изменения</th>
                    <th>Действия</th>
                </tr>
                </thead>

                <tbody>
                @for (var i = 0; i < 5; i++)
                {
                    <tr>
                        <td><div class="skeleton skeleton-text"></div></td>
                        <td><div class="skeleton skeleton-date"></div></td>
                        <td><div class="skeleton skeleton-date"></div></td>
                        <td><div class="skeleton skeleton-icon"></div></td>
                    </tr>
                }
                </tbody>
            </table>
        }
        else if (_items.Count == 0)
        {
            <div class="table-empty">Записи не найдены</div>
        }
        else
        {
            <table class="tools-table">
                <thead>
                <tr>
                    <th>Название</th>
                    <th>Дата создания</th>
                    <th>Дата изменения</th>
                    <th>Действия</th>
                </tr>
                </thead>

                <tbody>
                @foreach (var item in _items)
                {
                    <tr>
                        <td><strong>@item.Name</strong></td>
                        <td>@item.CreatedAt</td>
                        <td>@item.UpdatedAt</td>
                        <td class="actions-cell">
                            <div class="table-actions">

                                <button class="action-button"
                                        title="Редактировать"
                                        @onclick="() => OpenEditModal(item)">
                                    <i class="bi bi-pencil"></i>
                                </button>

                                <button class="action-button action-button-danger"
                                        title="Удалить"
                                        @onclick="() => OpenDeleteModal(item)">
                                    <i class="bi bi-trash"></i>
                                </button>

                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>

    @if (_isEditModalOpen && _selectedItem is not null)
    {
        <div class="actions-backdrop" @onclick="CloseEditModal">
            <div class="confirm-modal" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>Редактировать запись</h3>
                        <p>@_selectedItem.Name</p>
                    </div>

                    <button type="button" @onclick="CloseEditModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="user-form-field">
                    <label>Название <span>*</span></label>
                    <input @bind="_editName" placeholder="Введите название" />
                </div>

                <div class="tool-form-actions modal-footer">
                    <button class="secondary-button" type="button" @onclick="CloseEditModal">
                        Отмена
                    </button>

                    <button class="primary-button" type="button" @onclick="UpdateDictionaryItem">
                        Сохранить
                    </button>
                </div>

            </div>
        </div>
    }

    @if (_isDeleteModalOpen && _selectedItem is not null)
    {
        <div class="actions-backdrop" @onclick="CloseDeleteModal">
            <div class="confirm-modal" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>Удалить запись</h3>
                        <p>@_selectedItem.Name</p>
                    </div>

                    <button type="button" @onclick="CloseDeleteModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <p class="confirm-text">
                    Запись будет удалена из справочника. Продолжить?
                </p>

                <div class="tool-form-actions modal-footer">
                    <button class="secondary-button" type="button" @onclick="CloseDeleteModal">
                        Отмена
                    </button>

                    <button class="danger-button" type="button" @onclick="DeleteDictionaryItem">
                        Удалить
                    </button>
                </div>

            </div>
        </div>
    }

    @if (_isCreateModalOpen)
    {
        <div class="actions-backdrop" @onclick="CloseCreateModal">
            <div class="confirm-modal" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>Добавить запись</h3>
                        <p>Создание новой записи справочника</p>
                    </div>

                    <button type="button" @onclick="CloseCreateModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="user-form-field">
                    <label>Название <span>*</span></label>
                    <input @bind="_createName"
                           placeholder="Введите название" />
                </div>

                <div class="tool-form-actions modal-footer">
                    <button class="secondary-button"
                            type="button"
                            @onclick="CloseCreateModal">
                        Отмена
                    </button>

                    <button class="primary-button"
                            type="button"
                            @onclick="CreateDictionaryItem">
                        Сохранить
                    </button>
                </div>

            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string DictionaryCode { get; set; } = string.Empty;

    private bool _isLoading = true;
    private List<DictionaryItem> _items = [];
    private DictionaryItem? _selectedItem;

    private bool _isEditModalOpen;
    private bool _isDeleteModalOpen;
    private bool _isCreateModalOpen;

    private string _createName = string.Empty;
    private string _editName = string.Empty;

    private string DictionaryTitle =>
        GetSettings()?.Title ?? "Справочник";

    protected override async Task OnParametersSetAsync()
    {
        await LoadDictionaryAsync();
    }

    private async Task LoadDictionaryAsync()
    {
        _isLoading = true;
        _items = [];
        _selectedItem = null;

        var settings = GetSettings();

        if (settings is null)
        {
            NotificationService.Error("Этот справочник пока не подключен");
            _isLoading = false;
            return;
        }

        var result = await DictionaryCrudService.GetListAsync<DictionaryDto>(
            settings.Url,
            settings.LoadErrorCode,
            settings.LoadErrorMessage);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            _isLoading = false;
            return;
        }

        _items = result.Value
            .Select(x => new DictionaryItem(
                x.Id,
                x.Name,
                x.CreatedAt.ToString("dd.MM.yyyy"),
                x.UpdatedAt?.ToString("dd.MM.yyyy") ?? "-"))
            .ToList();

        _isLoading = false;
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/dictionaries");
    }

    private void OpenCreateModal()
    {
        _createName = string.Empty;
        _isCreateModalOpen = true;
    }

    private void CloseCreateModal()
    {
        _isCreateModalOpen = false;
        _createName = string.Empty;
    }

    private void OpenEditModal(DictionaryItem item)
    {
        _selectedItem = item;
        _editName = item.Name;
        _isEditModalOpen = true;
    }

    private void CloseEditModal()
    {
        _isEditModalOpen = false;
        _editName = string.Empty;
    }

    private void OpenDeleteModal(DictionaryItem item)
    {
        _selectedItem = item;
        _isDeleteModalOpen = true;
    }

    private void CloseDeleteModal()
    {
        _isDeleteModalOpen = false;
    }

    private async Task CreateDictionaryItem()
    {
        if (string.IsNullOrWhiteSpace(_createName))
        {
            NotificationService.Error("Введите название");
            return;
        }

        var settings = GetSettings();

        if (settings is null)
        {
            NotificationService.Error("Этот справочник пока не подключен");
            return;
        }

        var result = await DictionaryCrudService.CreateAsync(
            settings.Url,
            new DictionaryNameRequest(_createName.Trim()),
            settings.CreateErrorCode,
            settings.CreateErrorMessage);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success(settings.CreateSuccessMessage);

        CloseCreateModal();

        await LoadDictionaryAsync();
    }

    private async Task UpdateDictionaryItem()
    {
        if (_selectedItem is null)
            return;

        if (string.IsNullOrWhiteSpace(_editName))
        {
            NotificationService.Error("Введите название");
            return;
        }

        var settings = GetSettings();

        if (settings is null)
        {
            NotificationService.Error("Этот справочник пока не подключен");
            return;
        }

        var result = await DictionaryCrudService.UpdateAsync(
            $"{settings.Url}/{_selectedItem.Id}",
            new DictionaryNameRequest(_editName.Trim()),
            settings.UpdateErrorCode,
            settings.UpdateErrorMessage);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success(settings.UpdateSuccessMessage);

        CloseEditModal();

        await LoadDictionaryAsync();
    }

    private async Task DeleteDictionaryItem()
    {
        if (_selectedItem is null)
            return;

        var settings = GetSettings();

        if (settings is null)
        {
            NotificationService.Error("Этот справочник пока не подключен");
            return;
        }

        var result = await DictionaryCrudService.DeleteAsync(
            $"{settings.Url}/{_selectedItem.Id}",
            settings.DeleteErrorCode,
            settings.DeleteErrorMessage);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success(settings.DeleteSuccessMessage);

        CloseDeleteModal();

        await LoadDictionaryAsync();
    }

    private DictionarySettings? GetSettings()
    {
        return DictionaryCode switch
        {
            "payment-methods" => new DictionarySettings(
                Title: "Способы оплаты",
                Url: "api/payment-methods",
                CreateSuccessMessage: "Способ оплаты создан",
                UpdateSuccessMessage: "Способ оплаты обновлен",
                DeleteSuccessMessage: "Способ оплаты удален",
                LoadErrorCode: "payment.methods.load.failed",
                CreateErrorCode: "payment.method.create.failed",
                UpdateErrorCode: "payment.method.update.failed",
                DeleteErrorCode: "payment.method.delete.failed",
                LoadErrorMessage: "Не удалось загрузить способы оплаты",
                CreateErrorMessage: "Не удалось создать способ оплаты",
                UpdateErrorMessage: "Не удалось обновить способ оплаты",
                DeleteErrorMessage: "Не удалось удалить способ оплаты"),

            "payment-types" => new DictionarySettings(
                Title: "Типы оплат",
                Url: "api/payment-types",
                CreateSuccessMessage: "Тип оплаты создан",
                UpdateSuccessMessage: "Тип оплаты обновлен",
                DeleteSuccessMessage: "Тип оплаты удален",
                LoadErrorCode: "payment.types.load.failed",
                CreateErrorCode: "payment.type.create.failed",
                UpdateErrorCode: "payment.type.update.failed",
                DeleteErrorCode: "payment.type.delete.failed",
                LoadErrorMessage: "Не удалось загрузить типы оплат",
                CreateErrorMessage: "Не удалось создать тип оплаты",
                UpdateErrorMessage: "Не удалось обновить тип оплаты",
                DeleteErrorMessage: "Не удалось удалить тип оплаты"),

            "order-statuses" => new DictionarySettings(
                Title: "Статусы заказов",
                Url: "api/order-statuses",
                CreateSuccessMessage: "Статус заказа создан",
                UpdateSuccessMessage: "Статус заказа обновлен",
                DeleteSuccessMessage: "Статус заказа удален",
                LoadErrorCode: "order.statuses.load.failed",
                CreateErrorCode: "order.status.create.failed",
                UpdateErrorCode: "order.status.update.failed",
                DeleteErrorCode: "order.status.delete.failed",
                LoadErrorMessage: "Не удалось загрузить статусы заказов",
                CreateErrorMessage: "Не удалось создать статус заказа",
                UpdateErrorMessage: "Не удалось обновить статус заказа",
                DeleteErrorMessage: "Не удалось удалить статус заказа"),

            "tool-categories" => new DictionarySettings(
                Title: "Категории инструментов",
                Url: "api/tool-categories",
                CreateSuccessMessage: "Категория инструментов создана",
                UpdateSuccessMessage: "Категория инструментов обновлена",
                DeleteSuccessMessage: "Категория инструментов удалена",
                LoadErrorCode: "tool.categories.load.failed",
                CreateErrorCode: "tool.category.create.failed",
                UpdateErrorCode: "tool.category.update.failed",
                DeleteErrorCode: "tool.category.delete.failed",
                LoadErrorMessage: "Не удалось загрузить категории инструментов",
                CreateErrorMessage: "Не удалось создать категорию инструментов",
                UpdateErrorMessage: "Не удалось обновить категорию инструментов",
                DeleteErrorMessage: "Не удалось удалить категорию инструментов"),

            _ => null
        };
    }
}