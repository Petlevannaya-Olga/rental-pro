@page "/dictionaries/{DictionaryCode}"
@layout AdminLayout

@using RentalPro.Contracts.PaymentMethods
@using RentalPro.Contracts.PaymentTypes
@using RentalPro.Contracts.OrderStatuses
@using RentalPro.Presentation.Client.Models.Dictionaries
@using RentalPro.Presentation.Client.Services

@inject NavigationManager NavigationManager
@inject DictionariesService DictionariesService
@inject NotificationService NotificationService
@inject PaymentMethodsService PaymentMethodsService
@inject PaymentTypesService PaymentTypesService
@inject OrderStatusesService OrderStatusesService

<div class="dictionary-details-page">

    <div class="dictionary-header">

        <button class="back-link" @onclick="GoBack">
            <i class="bi bi-arrow-left"></i>
            Назад
        </button>

        <div class="dictionary-title-row">
            <h2>@DictionaryTitle</h2>

            <button class="primary-button" @onclick="OpenCreateModal">
                <i class="bi bi-plus-lg"></i>
                Добавить запись
            </button>
        </div>

    </div>

    <div class="dictionary-details-card">
        @if (_isLoading)
        {
            <table class="tools-table">
                <thead>
                <tr>
                    <th>Название</th>
                    <th>Дата создания</th>
                    <th>Дата изменения</th>
                    <th>Действия</th>
                </tr>
                </thead>

                <tbody>
                @for (var i = 0; i < 5; i++)
                {
                    <tr>
                        <td><div class="skeleton skeleton-text"></div></td>
                        <td><div class="skeleton skeleton-date"></div></td>
                        <td><div class="skeleton skeleton-date"></div></td>
                        <td><div class="skeleton skeleton-icon"></div></td>
                    </tr>
                }
                </tbody>
            </table>
        }
        else if (_items.Count == 0)
        {
            <div class="table-empty">Записи не найдены</div>
        }
        else
        {
            <table class="tools-table">
                <thead>
                <tr>
                    <th>Название</th>
                    <th>Дата создания</th>
                    <th>Дата изменения</th>
                    <th>Действия</th>
                </tr>
                </thead>

                <tbody>
                @foreach (var item in _items)
                {
                    <tr>
                        <td><strong>@item.Name</strong></td>
                        <td>@item.CreatedAt</td>
                        <td>@item.UpdatedAt</td>
                        <td class="actions-cell">
                            <div class="table-actions">

                                <button class="action-button"
                                        title="Редактировать"
                                        @onclick="() => OpenEditModal(item)">
                                    <i class="bi bi-pencil"></i>
                                </button>

                                <button class="action-button action-button-danger"
                                        title="Удалить"
                                        @onclick="() => OpenDeleteModal(item)">
                                    <i class="bi bi-trash"></i>
                                </button>

                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>

    @if (_isEditModalOpen && _selectedItem is not null)
    {
        <div class="actions-backdrop" @onclick="CloseEditModal">
            <div class="confirm-modal" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>Редактировать запись</h3>
                        <p>@_selectedItem.Name</p>
                    </div>

                    <button type="button" @onclick="CloseEditModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="user-form-field">
                    <label>Название <span>*</span></label>
                    <input @bind="_editName" placeholder="Введите название" />
                </div>

                <div class="tool-form-actions modal-footer">
                    <button class="secondary-button" type="button" @onclick="CloseEditModal">
                        Отмена
                    </button>

                    <button class="primary-button" type="button" @onclick="UpdateDictionaryItem">
                        Сохранить
                    </button>
                </div>

            </div>
        </div>
    }

    @if (_isDeleteModalOpen && _selectedItem is not null)
    {
        <div class="actions-backdrop" @onclick="CloseDeleteModal">
            <div class="confirm-modal" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>Удалить запись</h3>
                        <p>@_selectedItem.Name</p>
                    </div>

                    <button type="button" @onclick="CloseDeleteModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <p class="confirm-text">
                    Запись будет удалена из справочника. Продолжить?
                </p>

                <div class="tool-form-actions modal-footer">
                    <button class="secondary-button" type="button" @onclick="CloseDeleteModal">
                        Отмена
                    </button>

                    <button class="danger-button" type="button" @onclick="DeleteDictionaryItem">
                        Удалить
                    </button>
                </div>

            </div>
        </div>
    }

    @if (_isCreateModalOpen)
    {
        <div class="actions-backdrop" @onclick="CloseCreateModal">
            <div class="confirm-modal" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>Добавить запись</h3>
                        <p>Создание новой записи справочника</p>
                    </div>

                    <button type="button" @onclick="CloseCreateModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="user-form-field">
                    <label>Название <span>*</span></label>
                    <input @bind="_createName"
                           placeholder="Введите название" />
                </div>

                <div class="tool-form-actions modal-footer">
                    <button class="secondary-button"
                            type="button"
                            @onclick="CloseCreateModal">
                        Отмена
                    </button>

                    <button class="primary-button"
                            type="button"
                            @onclick="CreateDictionaryItem">
                        Сохранить
                    </button>
                </div>

            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string DictionaryCode { get; set; } = string.Empty;

    private bool _isLoading = true;
    private List<DictionaryItem> _items = [];
    private DictionaryItem? _selectedItem;

    private bool _isEditModalOpen;
    private bool _isDeleteModalOpen;
    private bool _isCreateModalOpen;

    private string _createName = string.Empty;
    private string _editName = string.Empty;

    private string DictionaryTitle => DictionaryCode switch
    {
        "tool-categories" => "Категории инструментов",
        "tool-statuses" => "Статусы инструментов",
        "manufacturers" => "Производители",
        "order-statuses" => "Статусы заказов",
        "payment-methods" => "Способы оплаты",
        "payment-types" => "Типы оплат",
        "maintenance-statuses" => "Статусы обслуживания",
        "roles" => "Роли пользователей",
        "suppliers" => "Поставщики",
        _ => "Справочник"
    };

    protected override async Task OnParametersSetAsync()
    {
        await LoadDictionaryAsync();
    }

    private async Task LoadDictionaryAsync()
    {
        _isLoading = true;
        _items = [];
        _selectedItem = null;

        switch (DictionaryCode)
        {
            case "payment-methods":
                await LoadPaymentMethodsAsync();
                break;

            case "payment-types":
                await LoadPaymentTypesAsync();
                break;

            case "order-statuses":
                await LoadOrderStatusesAsync();
                break;

            default:
                NotificationService.Error("Этот справочник пока не подключен");
                break;
        }

        _isLoading = false;
    }

    private async Task LoadPaymentMethodsAsync()
    {
        var result = await DictionariesService.GetPaymentMethodsAsync();

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        _items = result.Value
            .Select(x => new DictionaryItem(
                x.Id,
                x.Name,
                x.CreatedAt.ToString("dd.MM.yyyy"),
                x.UpdatedAt?.ToString("dd.MM.yyyy") ?? "-"))
            .ToList();
    }

    private async Task LoadPaymentTypesAsync()
    {
        var result = await DictionariesService.GetPaymentTypesAsync();

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        _items = result.Value
            .Select(x => new DictionaryItem(
                x.Id,
                x.Name,
                x.CreatedAt.ToString("dd.MM.yyyy"),
                x.UpdatedAt?.ToString("dd.MM.yyyy") ?? "-"))
            .ToList();
    }

    private async Task LoadOrderStatusesAsync()
    {
        var result = await OrderStatusesService.GetOrderStatusesAsync();

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        _items = result.Value
            .Select(x => new DictionaryItem(
                x.Id,
                x.Name,
                x.CreatedAt.ToString("dd.MM.yyyy"),
                x.UpdatedAt?.ToString("dd.MM.yyyy") ?? "-"))
            .ToList();
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/dictionaries");
    }

    private void OpenCreateModal()
    {
        _createName = string.Empty;
        _isCreateModalOpen = true;
    }

    private void CloseCreateModal()
    {
        _isCreateModalOpen = false;
        _createName = string.Empty;
    }

    private void OpenEditModal(DictionaryItem item)
    {
        _selectedItem = item;
        _editName = item.Name;
        _isEditModalOpen = true;
    }

    private void CloseEditModal()
    {
        _isEditModalOpen = false;
        _editName = string.Empty;
    }

    private void OpenDeleteModal(DictionaryItem item)
    {
        _selectedItem = item;
        _isDeleteModalOpen = true;
    }

    private void CloseDeleteModal()
    {
        _isDeleteModalOpen = false;
    }

    private async Task CreateDictionaryItem()
    {
        if (string.IsNullOrWhiteSpace(_createName))
        {
            NotificationService.Error("Введите название");
            return;
        }

        var name = _createName.Trim();

        switch (DictionaryCode)
        {
            case "payment-methods":
                await CreatePaymentMethod(name);
                break;

            case "payment-types":
                await CreatePaymentType(name);
                break;

            case "order-statuses":
                await CreateOrderStatus(name);
                break;
        }
    }

    private async Task UpdateDictionaryItem()
    {
        if (_selectedItem is null)
            return;

        if (string.IsNullOrWhiteSpace(_editName))
        {
            NotificationService.Error("Введите название");
            return;
        }

        var name = _editName.Trim();

        switch (DictionaryCode)
        {
            case "payment-methods":
                await UpdatePaymentMethod(name);
                break;

            case "payment-types":
                await UpdatePaymentType(name);
                break;

            case "order-statuses":
                await UpdateOrderStatus(name);
                break;
        }
    }

    private async Task DeleteDictionaryItem()
    {
        if (_selectedItem is null)
            return;

        switch (DictionaryCode)
        {
            case "payment-methods":
                await DeletePaymentMethod();
                break;

            case "payment-types":
                await DeletePaymentType();
                break;

            case "order-statuses":
                await DeleteOrderStatus();
                break;
        }
    }

    private async Task CreatePaymentMethod(string name)
    {
        var result = await PaymentMethodsService.CreatePaymentMethodAsync(
            new CreatePaymentMethodRequest(name));

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success("Способ оплаты создан");

        CloseCreateModal();

        await LoadDictionaryAsync();
    }

    private async Task UpdatePaymentMethod(string name)
    {
        if (_selectedItem is null)
            return;

        var result = await PaymentMethodsService.UpdatePaymentMethodAsync(
            _selectedItem.Id,
            new UpdatePaymentMethodRequest(name));

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success("Способ оплаты обновлен");

        CloseEditModal();

        await LoadDictionaryAsync();
    }

    private async Task DeletePaymentMethod()
    {
        if (_selectedItem is null)
            return;

        var result = await PaymentMethodsService.DeletePaymentMethodAsync(
            _selectedItem.Id);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success("Способ оплаты удален");

        CloseDeleteModal();

        await LoadDictionaryAsync();
    }

    private async Task CreatePaymentType(string name)
    {
        var result = await PaymentTypesService.CreatePaymentTypeAsync(
            new CreatePaymentTypeRequest(name));

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success("Тип оплаты создан");

        CloseCreateModal();

        await LoadDictionaryAsync();
    }

    private async Task UpdatePaymentType(string name)
    {
        if (_selectedItem is null)
            return;

        var result = await PaymentTypesService.UpdatePaymentTypeAsync(
            _selectedItem.Id,
            new UpdatePaymentTypeRequest(name));

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success("Тип оплаты обновлен");

        CloseEditModal();

        await LoadDictionaryAsync();
    }

    private async Task DeletePaymentType()
    {
        if (_selectedItem is null)
            return;

        var result = await PaymentTypesService.DeletePaymentTypeAsync(
            _selectedItem.Id);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success("Тип оплаты удален");

        CloseDeleteModal();

        await LoadDictionaryAsync();
    }

    private async Task CreateOrderStatus(string name)
    {
        var result = await OrderStatusesService.CreateOrderStatusAsync(
            new CreateOrderStatusRequest(name));

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success("Статус заказа создан");

        CloseCreateModal();

        await LoadDictionaryAsync();
    }

    private async Task UpdateOrderStatus(string name)
    {
        if (_selectedItem is null)
            return;

        var result = await OrderStatusesService.UpdateOrderStatusAsync(
            _selectedItem.Id,
            new UpdateOrderStatusRequest(name));

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success("Статус заказа обновлен");

        CloseEditModal();

        await LoadDictionaryAsync();
    }

    private async Task DeleteOrderStatus()
    {
        if (_selectedItem is null)
            return;

        var result = await OrderStatusesService.DeleteOrderStatusAsync(
            _selectedItem.Id);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success("Статус заказа удален");

        CloseDeleteModal();

        await LoadDictionaryAsync();
    }
}