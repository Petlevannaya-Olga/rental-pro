            Search: _toolSearch,
            CategoryId: null,
            ManufacturerId: null,
            StatusId: _availableToolStatusId,
            SortBy: _toolSortBy,
            Descending: _toolDescending,
            Page: _toolsCurrentPage,
            PageSize: ToolPageSize);

        var result = await ToolsService.GetToolsAsync(request);

        if (result.IsFailure)
        {
            _tools = [];
            _toolsTotalCount = 0;
            _isToolsLoading = false;

            NotificationService.Error(result.Error.Message);
            return;
        }

        _tools = result.Value.Items.ToList();
        _toolsTotalCount = result.Value.TotalCount;

        if (_toolsCurrentPage > ToolsTotalPages)
        {
            _toolsCurrentPage = ToolsTotalPages;
            await LoadToolsForSelectAsync();
            return;
        }

        _isToolsLoading = false;
    }

    private async Task OpenToolSelectModal()
    {
        _toolSearch = string.Empty;
        _toolSortBy = "name";
        _toolDescending = false;
        _toolsCurrentPage = 1;

        _isToolSelectModalOpen = true;

        _availableToolStatusId ??= await GetAvailableToolStatusIdAsync();

        if (_availableToolStatusId is null)
            return;

        await LoadToolsForSelectAsync();
    }

    private void CloseToolSelectModal()
    {
        _toolSearch = string.Empty;
        _tools = [];
        _toolsTotalCount = 0;

        _isToolSelectModalOpen = false;
    }

    private bool IsToolSelected(ToolDto tool)
    {
        return _newOrder.Tools.Any(x => x.ToolId == tool.Id);
    }

    private void ToggleToolSelection(ToolDto tool)
    {
        var selectedTool = _newOrder.Tools
            .FirstOrDefault(x => x.ToolId == tool.Id);

        if (selectedTool is not null)
        {
            _newOrder.Tools.Remove(selectedTool);
            RecalculateOrder();
            FixOrderToolsPage();
            return;
        }

        _newOrder.Tools.Add(new OrderToolFormModel
        {
            ToolId = tool.Id,
            ToolName = tool.Name,
            RentalPricePerDay = tool.RentalPricePerDay,
            DepositAmount = tool.DepositAmount,
            StartDate = _newOrder.StartDate,
            EndDate = _newOrder.EndDate
        });

        RecalculateOrder();
    }

    private void SelectTools()
    {
        if (_newOrder.Tools.Count == 0)
        {
            NotificationService.Error("Выберите инструменты");
            return;
        }

        RecalculateOrder();

        CloseToolSelectModal();

        NotificationService.Success($"Выбрано инструментов: {_newOrder.Tools.Count}");
    }

    private async Task OnToolSearchChanged(ChangeEventArgs e)
    {
        _toolSearch = e.Value?.ToString();

        _toolSearchCts?.Cancel();
        _toolSearchCts?.Dispose();

        _toolSearchCts = new CancellationTokenSource();
        var token = _toolSearchCts.Token;

        try
        {
            await Task.Delay(500, token);

            _toolsCurrentPage = 1;
            await LoadToolsForSelectAsync();
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task ChangeToolSort(string sortBy)
    {
        if (_toolSortBy == sortBy)
            _toolDescending = !_toolDescending;
        else
        {
            _toolSortBy = sortBy;
            _toolDescending = false;
        }

        _toolsCurrentPage = 1;

        await LoadToolsForSelectAsync();
    }

    private async Task GoToToolPage(int page)
    {
        if (page < 1 || page > ToolsTotalPages)
            return;

        _toolsCurrentPage = page;

        await LoadToolsForSelectAsync();
    }

    private int GetRentalDays()
    {
        var days = _newOrder.EndDate.DayNumber - _newOrder.StartDate.DayNumber;

        return days <= 0 ? 0 : days;
    }

    private async Task CreateOrder()
    {
        if (_currentUserId is null)
        {
            NotificationService.Error(
                "Не удалось определить пользователя");

            return;
        }

        if (_newOrder.CustomerId is null ||
            _newOrder.Tools.Count == 0)
        {
            NotificationService.Error("Выберите клиента и инструменты");
            return;
        }

        var statusId = _selectedStatusId
                       ?? _orderStatuses.FirstOrDefault(x => x.Name == "Подтвержден")?.Id;

        if (statusId is null)
        {
            NotificationService.Error("Статус заказа «Подтвержден» не найден");
            return;
        }

        var request = new CreateOrderRequest(
            UserId: _currentUserId.Value,
            CustomerId: _newOrder.CustomerId.Value,
            StatusId: statusId.Value,
            OrderDate: _newOrder.OrderDate.ToDateTime(TimeOnly.MinValue),
            DepositTotal: _newOrder.DepositAmount,
            Comment: _newOrder.Comment,
            Items: _newOrder.Tools
                .Select(x => new CreateOrderItemDto(
                    ToolId: x.ToolId,
                    RentalPricePerDay: x.RentalPricePerDay,
                    DepositAmount: x.DepositAmount,
                    StartDate: _newOrder.OrderDate,
                    PlannedReturnDate: x.EndDate))
                .ToList());

        var result = await OrdersService.CreateOrderAsync(request);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        var createdOrderId = result.Value.Id;

        CloseCreateModal();

        NotificationService.Success("Заказ успешно создан");

        Navigation.NavigateTo($"/orders/{createdOrderId}");
    }

    private void ExecuteOrderAction(string action)
    {
        if (_selectedOrder is null)
            return;

        NotificationService.Info($"{action}: {_selectedOrder.Number}");

        CloseActionsMenu();
    }

    private void ExportOrders()
    {
        NotificationService.Success("Заказы экспортированы");
    }

    private static string GetOrderStatusClass(string status)
    {
        return status switch
        {
            "Активен" => "status-badge available",
            "Выполняется" => "status-badge available",
            "Готов к выдаче" => "status-badge info",
            "Подтвержден" => "status-badge info",
            "Ожидает закрытия аренды" => "status-badge warning",
            "Завершен" => "status-badge info",
            "Просрочен" => "status-badge danger",
            "Отменен" => "status-badge neutral",
            _ => "status-badge"
        };
    }

    private static string GetInitials(CustomerDto customer)
    {
        var lastNameInitial = string.IsNullOrWhiteSpace(customer.LastName)
            ? string.Empty
            : customer.LastName[0].ToString();

        var firstNameInitial = string.IsNullOrWhiteSpace(customer.FirstName)
            ? string.Empty
            : customer.FirstName[0].ToString();

        var initials = $"{lastNameInitial}{firstNameInitial}";

        return string.IsNullOrWhiteSpace(initials)
            ? "?"
            : initials;
    }

    private static string GetAddressOrDash(CustomerDto customer)
    {
        return string.IsNullOrWhiteSpace(customer.Address)
            ? "Адрес не указан"
            : customer.Address;
    }

    private static string GetToolImageUrl(string? photoPath)
    {
        if (string.IsNullOrWhiteSpace(photoPath))
            return string.Empty;

        if (photoPath.StartsWith("http", StringComparison.OrdinalIgnoreCase))
            return photoPath;

        return $"https://localhost:7099{photoPath}";
    }

    private static string GetToolStatusClass(string status)
    {
        return status switch
        {
            "Доступен" => "status-badge available",
            "В аренде" => "status-badge rented",
            "На ремонте" => "status-badge repair",
            "Списан" => "status-badge danger",
            _ => "status-badge"
        };
    }

    private async Task<Guid?> GetAvailableToolStatusIdAsync()
    {
        var result = await DictionaryCrudService.GetListAsync<DictionaryItem>(
            "api/tool-statuses",
            "dictionary.load.failed",
            "Не удалось загрузить статусы инструментов");

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return null;
        }

        var availableStatus = result.Value
            .FirstOrDefault(x => x.Name == "Доступен");

        if (availableStatus is null)
        {
            NotificationService.Error("Статус инструмента «Доступен» не найден");
            return null;
        }

        return availableStatus.Id;
    }

    private void OpenCreateCustomerModal()
    {
        _isCreateCustomerModalOpen = true;
    }

    private Task CloseCreateCustomerModal()
    {
        _isCreateCustomerModalOpen = false;

        return Task.CompletedTask;
    }

    private async Task OnCustomerCreated(CreateCustomerResponse customer)
    {
        _selectedCustomer = null;

        _newOrder.CustomerId = customer.Id;
        _newOrder.CustomerName = customer.FullName;

        _customersCurrentPage = 1;

        await LoadCustomersForSelectAsync();
    }

    private void RecalculateOrder()
    {
        foreach (var tool in _newOrder.Tools)
        {
            tool.StartDate = _newOrder.OrderDate;
        }

        _newOrder.TotalAmount = _newOrder.Tools.Sum(x => x.TotalAmount);
        _newOrder.DepositAmount = _newOrder.Tools.Sum(x => x.DepositAmount);

        _newOrder.ToolName = string.Join(", ",
            _newOrder.Tools.Select(x => x.ToolName));

        if (_newOrder.Tools.Count > 0)
        {
            _newOrder.StartDate = _newOrder.OrderDate;
            _newOrder.EndDate = _newOrder.Tools.Max(x => x.EndDate);
        }
    }

    private void RemoveToolFromOrder(Guid toolId)
    {
        var tool = _newOrder.Tools
            .FirstOrDefault(x => x.ToolId == toolId);

        if (tool is null)
            return;

        _newOrder.Tools.Remove(tool);

        RecalculateOrder();
        FixOrderToolsPage();
    }

    private void FixOrderToolsPage()
    {
        if (_orderToolsCurrentPage > OrderToolsTotalPages)
        {
            _orderToolsCurrentPage = OrderToolsTotalPages;
        }
    }

    private async Task FillTestOrderAsync()
    {
        if (_customers.Count == 0)
        {
            await LoadCustomersForSelectAsync();
        }

        if (_tools.Count == 0)
        {
            _availableToolStatusId ??= await GetAvailableToolStatusIdAsync();

            if (_availableToolStatusId is not null)
                await LoadToolsForSelectAsync();
        }

        FakeOrderGenerator.Fill(
            _newOrder,
            _customers,
            _tools);

        RecalculateOrder();

        NotificationService.Success("Тестовые данные заказа заполнены");
    }

    private async Task ApplyFilters()
    {
        _activeStatsFilter = "custom";
        _currentPage = 1;

        ApplyStatusFilter();

        await LoadOrdersAsync();
    }

    private void ApplyStatusFilter()
    {
        if (string.IsNullOrWhiteSpace(_status))
        {
            _selectedStatusId = null;
            return;
        }

        _selectedStatusId = _orderStatuses
            .FirstOrDefault(x => x.Name == _status)
            ?.Id;
    }

    private async Task ResetFilters()
    {
        _search = string.Empty;
        _status = null;
        _selectedStatusId = null;
        _startFrom = null;
        _startTo = null;

        _activeStatsFilter = "all";
        _currentPage = 1;

        await LoadOrdersAsync();
    }

    private async Task GoToPage(int page)
    {
        if (page < 1 || page > TotalPages)
            return;

        _currentPage = page;

        await LoadOrdersAsync();
    }

    private string GetReturnDateClass(OrderDto order)
    {
        if (!order.PlannedReturnDate.HasValue)
            return "return-date";

        if (order.StatusName != "Активен" &&
            order.StatusName != "Выполняется")
        {
            return "return-date";
        }

        var today = DateOnly.FromDateTime(DateTime.Today);

        if (order.PlannedReturnDate.Value < today)
            return "return-date overdue";

        if (order.PlannedReturnDate.Value <= today.AddDays(3))
            return "return-date warning";

        return "return-date";
    }

    private void OpenCancelOrderModal()
    {
        if (_selectedOrder is null)
            return;

        _cancellingOrder = _selectedOrder;
        _isActionsMenuOpen = false;
        _isCancelOrderModalOpen = true;
    }

    private void CloseCancelOrderModal()
    {
        _isCancelOrderModalOpen = false;
        _cancellingOrder = null;
    }

    private async Task CancelOrderAsync()
    {
        if (_cancellingOrder is null)
            return;

        var orderNumber = _cancellingOrder.Number;
        var result = await OrdersService.CancelOrderAsync(_cancellingOrder.Id);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        CloseCancelOrderModal();

        await LoadOrdersAsync();

        NotificationService.Success($"Заказ «{orderNumber}» отменен");
    }
}
