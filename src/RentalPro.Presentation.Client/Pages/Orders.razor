@page "/orders"
@layout AdminLayout

@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using RentalPro.Contracts.Customers
@using RentalPro.Contracts.OrderStatuses
@using RentalPro.Contracts.Orders
@using RentalPro.Contracts.Tools
@using RentalPro.Presentation.Client.Models
@using RentalPro.Presentation.Client.Models.Dictionaries
@using RentalPro.Presentation.Client.Services

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject OrderStatusesService OrderStatusesService
@inject OrdersService OrdersService
@inject ToolsService ToolsService
@inject NotificationService NotificationService
@inject CustomersService CustomersService
@inject DictionaryCrudService DictionaryCrudService
@inject FakeOrderGeneratorService FakeOrderGenerator
@inject NavigationManager Navigation

<div class="users-page orders-page">

    <div class="users-stats">

        <div class="stats-filter-card @GetStatsCardClass("all")"
             @onclick='() => ApplyStatsFilter("all")'>
            <StatCard Title="Всего заказов"
                      Value="@FilteredTotalCount.ToString()"
                      Icon="bi bi-receipt"
                      Color="blue"/>
        </div>

        <div class="stats-filter-card @GetStatsCardClass("active")"
             @onclick='() => ApplyStatsFilter("active")'>
            <StatCard Title="Активные"
                      Value="@_orders.Count(x => x.StatusName == "Активен").ToString()"
                      Icon="bi bi-play-circle"
                      Color="green"/>
        </div>

        <div class="stats-filter-card @GetStatsCardClass("completed")"
             @onclick='() => ApplyStatsFilter("completed")'>
            <StatCard Title="Завершенные"
                      Value="@_orders.Count(x => x.StatusName == "Завершен").ToString()"
                      Icon="bi bi-check-circle"
                      Color="cyan"/>
        </div>

        <div class="stats-filter-card @GetStatsCardClass("overdue")"
             @onclick='() => ApplyStatsFilter("overdue")'>
            <StatCard Title="Просроченные"
                      Value="@_orders.Count(x => x.StatusName == "Просрочен").ToString()"
                      Icon="bi bi-exclamation-circle"
                      Color="red"/>
        </div>

        <button class="users-add-card"
                @onclick="OpenCreateModal">
            <i class="bi bi-plus-lg"></i>
            <span>Создать заказ</span>
        </button>

    </div>

    <div class="users-table-card">

        <div class="orders-inline-filters">

            <div class="filter-group search-filter">
                <label>Поиск</label>

                <div class="search-box">
                    <i class="bi bi-search"></i>

                    <input placeholder="Номер заказа, клиент или инструмент..."
                           value="@_search"
                           @oninput="OnSearchChanged"/>
                </div>
            </div>

            <div class="filter-group">
                <label>Статус</label>

                <select class="filter-select"
                        @bind="_status"
                        @bind:after="ApplyFilters">
                    <option value="">Все статусы</option>

                    @foreach (var status in _orderStatuses)
                    {
                        <option value="@status.Name">@status.Name</option>
                    }
                </select>
            </div>

            <div class="filter-group">
                <label>Начало с</label>
                <input type="date"
                       class="filter-select date-input"
                       @bind="_startFrom"
                       @bind:after="ApplyFilters"/>
            </div>

            <div class="filter-group">
                <label>Начало по</label>
                <input type="date"
                       class="filter-select date-input"
                       @bind="_startTo"
                       @bind:after="ApplyFilters"/>
            </div>

            <button class="secondary-button"
                    @onclick="ResetFilters">
                <i class="bi bi-arrow-counterclockwise"></i>
                Сбросить
            </button>

            <button class="secondary-button"
                    @onclick="ExportOrders">
                <i class="bi bi-download"></i>
                Экспорт
            </button>

        </div>

        @if (_isLoading)
        {
            <table class="users-table">
                <thead>
                <tr>
                    <th>Заказ</th>
                    <th>Клиент</th>
                    <th>Статус</th>
                    <th>Инструменты</th>
                    <th>Ближайший возврат</th>
                    <th>Сумма</th>
                    <th>Залог</th>
                    <th></th>
                </tr>
                </thead>

                <tbody>
                @for (var i = 0; i < PageSize; i++)
                {
                    <tr>
                        <td>
                            <div class="skeleton-lines">
                                <div class="skeleton skeleton-line wide"></div>
                                <div class="skeleton skeleton-line small"></div>
                            </div>
                        </td>

                        <td><div class="skeleton skeleton-line medium"></div></td>
                        <td><div class="skeleton skeleton-badge"></div></td>
                        <td><div class="skeleton skeleton-line small"></div></td>
                        <td><div class="skeleton skeleton-line small"></div></td>
                        <td><div class="skeleton skeleton-line small"></div></td>
                        <td><div class="skeleton skeleton-line small"></div></td>
                        <td><div class="skeleton skeleton-dot"></div></td>
                    </tr>
                }
                </tbody>
            </table>
        }
        else if (_orders.Count == 0)
        {
            <div class="table-empty">Заказы не найдены</div>
        }
        else
        {
            <table class="users-table">
                <thead>
                <tr>
                    <th class="sortable-column" @onclick='() => ChangeSort("number")'>
                        Заказ <i class="bi bi-arrow-down-up"></i>
                    </th>

                    <th class="sortable-column" @onclick='() => ChangeSort("customer")'>
                        Клиент <i class="bi bi-arrow-down-up"></i>
                    </th>

                    <th class="sortable-column" @onclick='() => ChangeSort("status")'>
                        Статус <i class="bi bi-arrow-down-up"></i>
                    </th>

                    <th class="sortable-column" @onclick='() => ChangeSort("itemscount")'>
                        Инструменты <i class="bi bi-arrow-down-up"></i>
                    </th>

                    <th class="sortable-column" @onclick='() => ChangeSort("plannedreturndate")'>
                        Ближайший возврат <i class="bi bi-arrow-down-up"></i>
                    </th>

                    <th class="sortable-column" @onclick='() => ChangeSort("totalcost")'>
                        Сумма <i class="bi bi-arrow-down-up"></i>
                    </th>

                    <th class="sortable-column" @onclick='() => ChangeSort("deposittotal")'>
                        Залог <i class="bi bi-arrow-down-up"></i>
                    </th>

                    <th></th>
                </tr>
                </thead>

                <tbody>
                @foreach (var order in _orders)
                {
                    <tr @ondblclick="() => OpenOrder(order.Id)">
                        <td>
                            <strong>@order.Number</strong>
                            <span class="table-subtitle">
                                @order.OrderDate.ToString("dd.MM.yyyy")
                            </span>
                        </td>

                        <td>@order.CustomerFullName</td>

                        <td>
                            <span class="@GetOrderStatusClass(order.StatusName)">
                                @order.StatusName
                            </span>
                        </td>

                        <td>@order.ItemsCount шт.</td>

                        <td>
                            @if (order.PlannedReturnDate.HasValue)
                            {
                                <span class="@GetReturnDateClass(order)">
                                    @order.PlannedReturnDate.Value.ToString("dd.MM.yyyy")
                                </span>
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </td>

                        <td>@order.TotalCost.ToString("N0") ₽</td>
                        <td>@order.DepositTotal.ToString("N0") ₽</td>

                        <td class="actions-cell">
                            <button class="icon-button"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => OpenActionsMenu(order)">
                                <i class="bi bi-three-dots"></i>
                            </button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }

        <Pagination CurrentPage="_currentPage"
                    TotalPages="TotalPages"
                    TotalItems="FilteredTotalCount"
                    StartItem="PageStart"
                    EndItem="PageEnd"
                    PageChanged="GoToPage"/>

    </div>

    @if (_isActionsMenuOpen && _selectedOrder is not null)
    {
        <div class="actions-backdrop" @onclick="CloseActionsMenu">
            <div class="actions-modal" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>Действия с заказом</h3>
                        <p>@_selectedOrder.Number</p>
                    </div>

                    <button type="button" @onclick="CloseActionsMenu">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <button class="menu-item" @onclick="OpenSelectedOrderView">
                    <i class="bi bi-eye"></i>
                    Просмотр
                </button>

                @if (_selectedOrder.StatusName == "Подтвержден")
                {
                    <button type="button"
                            class="menu-item danger"
                            @onclick="OpenCancelOrderModal">
                        <i class="bi bi-x-circle"></i>
                        Отменить заказ
                    </button>
                }

            </div>
        </div>
    }

    @if (_isCreateModalOpen)
    {
        <div class="actions-backdrop">
            <div class="order-create-modal-v2" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>Создать заказ</h3>
                        <p>Заполните данные заказа</p>
                    </div>

                    <button type="button" @onclick="CloseCreateModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="order-modal-body">

                    <div class="order-section">
                        <div class="order-selected-grid">

                            <div class="order-selected-card">
                                <div class="order-selected-icon customer">
                                    <i class="bi bi-person"></i>
                                </div>

                                <div class="order-selected-content">
                                    <strong>@(string.IsNullOrWhiteSpace(_newOrder.CustomerName)
                                            ? "Клиент не выбран"
                                            : _newOrder.CustomerName)</strong>
                                </div>

                                <button class="secondary-button"
                                        type="button"
                                        @onclick="OpenCustomerSelectModal">
                                    <i class="bi bi-pencil"></i>
                                    Изменить
                                </button>
                            </div>

                            <div class="order-selected-card">
                                <div class="order-selected-icon tools">
                                    <i class="bi bi-tools"></i>
                                </div>

                                <div class="order-selected-content">
                                    <strong>Выбрано инструментов: @SelectedToolsCount</strong>
                                </div>

                                <button class="secondary-button"
                                        type="button"
                                        @onclick="OpenToolSelectModal">
                                    <i class="bi bi-pencil"></i>
                                    Изменить
                                </button>
                            </div>

                        </div>
                    </div>

                    <div class="order-section">
                        <div class="order-date-money-grid">

                            <div class="tool-form-field">
                                <label>Дата заказа <span>*</span></label>
                                <input type="date" @bind="_newOrder.OrderDate"/>
                            </div>

                            <div class="tool-form-field">
                                <label>Комментарий</label>
                                <input @bind="_newOrder.Comment"
                                       placeholder="Комментарий к заказу (необязательно)"/>
                            </div>

                        </div>
                    </div>

                    @if (_newOrder.Tools.Count > 0)
                    {
                        <div class="order-section">
                            <table class="users-table order-tools-period-table">
                                <thead>
                                <tr>
                                    <th>Инструмент</th>
                                    <th>Начало аренды</th>
                                    <th>Окончание аренды</th>
                                    <th>Дней</th>
                                    <th>Аренда</th>
                                    <th>Залог</th>
                                    <th></th>
                                </tr>
                                </thead>

                                <tbody>
                                @foreach (var tool in PagedOrderTools)
                                {
                                    <tr>
                                        <td>
                                            <strong>@tool.ToolName</strong>
                                            <span class="table-subtitle">
                                                @tool.RentalPricePerDay.ToString("N0") ₽ / день
                                            </span>
                                        </td>

                                        <td>
                                            <span>
                                                @_newOrder.OrderDate.ToString("dd.MM.yyyy")
                                            </span>
                                        </td>

                                        <td>
                                            <input type="date"
                                                   class="filter-select date-input"
                                                   @bind="tool.EndDate"
                                                   @bind:after="RecalculateOrder"/>
                                        </td>

                                        <td>@tool.RentalDays</td>
                                        <td>@tool.TotalAmount.ToString("N0") ₽</td>
                                        <td>@tool.DepositAmount.ToString("N0") ₽</td>

                                        <td class="actions-cell">
                                            <button class="icon-button"
                                                    type="button"
                                                    @onclick="() => RemoveToolFromOrder(tool.ToolId)">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>

                            @if (_newOrder.Tools.Count > OrderToolsPageSize)
                            {
                                <Pagination CurrentPage="_orderToolsCurrentPage"
                                            TotalPages="OrderToolsTotalPages"
                                            TotalItems="_newOrder.Tools.Count"
                                            StartItem="OrderToolsPageStart"
                                            EndItem="OrderToolsPageEnd"
                                            PageChanged="GoToOrderToolsPage"/>
                            }
                        </div>
                    }

                    @if (_newOrder.Tools.Count > 0)
                    {
                        <div class="order-summary-card compact">

                            <div class="order-summary-row">

                                <div class="order-summary-item">
                                    <div class="summary-icon compact blue">
                                        <i class="bi bi-calendar-range"></i>
                                    </div>

                                    <div>
                                        <span>Период</span>

                                        <strong>
                                            @_newOrder.StartDate.ToString("dd.MM")
                                            —
                                            @_newOrder.EndDate.ToString("dd.MM")
                                        </strong>
                                    </div>
                                </div>

                                <div class="order-summary-item">
                                    <div class="summary-icon compact green">
                                        <i class="bi bi-calendar-check"></i>
                                    </div>

                                    <div>
                                        <span>Дней</span>

                                        <strong>
                                            @RentalDaysText
                                        </strong>
                                    </div>
                                </div>

                                <div class="order-summary-item">
                                    <div class="summary-icon compact yellow">
                                        <i class="bi bi-wallet2"></i>
                                    </div>

                                    <div>
                                        <span>Залог</span>

                                        <strong>
                                            @_newOrder.DepositAmount.ToString("N0") ₽
                                        </strong>
                                    </div>
                                </div>

                                <div class="order-summary-item">
                                    <div class="summary-icon compact green">
                                        <i class="bi bi-cash-stack"></i>
                                    </div>

                                    <div>
                                        <span>Аренда</span>

                                        <strong>
                                            @_newOrder.TotalAmount.ToString("N0") ₽
                                        </strong>
                                    </div>
                                </div>

                                <div class="order-summary-total">
                                    <span>К оплате</span>

                                    <strong>
                                        @TotalToPay.ToString("N0") ₽
                                    </strong>
                                </div>

                            </div>

                        </div>
                    }

                </div>

                <div class="tool-form-actions modal-footer">
                    <button class="secondary-button"
                            type="button"
                            @onclick="CloseCreateModal">
                        Отмена
                    </button>

                    <button class="secondary-button"
                            type="button"
                            @onclick="FillTestOrderAsync">
                        <i class="bi bi-magic"></i>
                        Заполнить тестовыми данными
                    </button>

                    <button class="primary-button"
                            type="button"
                            @onclick="CreateOrder">
                        <i class="bi bi-check-lg"></i>
                        Создать заказ
                    </button>
                </div>

            </div>
        </div>
    }

    @if (_isCustomerSelectModalOpen)
    {
        <div class="actions-backdrop">
            <div class="customer-view-modal" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>Выбор клиента</h3>
                        <p>Выберите одного клиента для оформления заказа</p>
                    </div>

                    <button type="button" @onclick="CloseCustomerSelectModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="selected-customer-banner @(_selectedCustomer is null ? "empty" : "selected")">

                    @if (_selectedCustomer is null)
                    {
                        <i class="bi bi-person-x-fill"></i>

                        <span>
                            Клиент не выбран
                        </span>
                    }
                    else
                    {
                        <i class="bi bi-check-circle-fill"></i>

                        <span>
                            Выбран клиент:
                            <strong>@_selectedCustomer.FullName</strong>
                        </span>
                    }

                </div>

                <div class="filter-group search-filter">
                    <label>Поиск клиента</label>

                    <div class="search-box">
                        <i class="bi bi-search"></i>

                        <input placeholder="ФИО, телефон, email, паспорт или адрес..."
                               value="@_customerSearch"
                               @oninput="OnCustomerSearchChanged"/>
                    </div>
                </div>

                @if (_isCustomersLoading)
                {
                    <table class="users-table user-select-table">
                        <thead>
                        <tr>
                            <th class="customer-column">Клиент</th>
                            <th class="phone-column">Телефон</th>
                            <th class="passport-column">Паспорт</th>
                        </tr>
                        </thead>

                        <tbody>
                        @for (var i = 0; i < CustomerPageSize; i++)
                        {
                            <tr>
                                <td>
                                    <div class="user-select-customer">
                                        <div class="skeleton skeleton-avatar"></div>

                                        <div class="skeleton-lines">
                                            <div class="skeleton skeleton-line wide"></div>
                                            <div class="skeleton skeleton-line small"></div>
                                        </div>
                                    </div>
                                </td>

                                <td><div class="skeleton skeleton-line medium"></div></td>
                                <td><div class="skeleton skeleton-line small"></div></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
                else if (_customers.Count == 0)
                {
                    <div class="table-empty">Клиенты не найдены</div>
                }
                else
                {
                    <table class="users-table user-select-table">
                        <thead>
                        <tr>
                            <th class="customer-column sortable-column"
                                @onclick='() => ChangeCustomerSort("fullname")'>
                                Клиент <i class="bi bi-arrow-down-up"></i>
                            </th>

                            <th class="phone-column sortable-column"
                                @onclick='() => ChangeCustomerSort("phone")'>
                                Телефон <i class="bi bi-arrow-down-up"></i>
                            </th>

                            <th class="passport-column sortable-column"
                                @onclick='() => ChangeCustomerSort("passport")'>
                                Паспорт <i class="bi bi-arrow-down-up"></i>
                            </th>
                        </tr>
                        </thead>

                        <tbody>
                        @foreach (var customer in _customers)
                        {
                            <tr class="@(_selectedCustomer?.Id == customer.Id ? "selected" : "")"
                                @onclick="() => _selectedCustomer = customer">

                                <td>
                                    <div class="user-select-customer">
                                        <div class="user-select-avatar">
                                            @GetInitials(customer)
                                        </div>

                                        <div class="user-select-info">
                                            <strong>@customer.FullName</strong>
                                            <span>@GetAddressOrDash(customer)</span>
                                        </div>
                                    </div>
                                </td>

                                <td>@customer.PhoneNumber</td>
                                <td>@customer.Passport</td>
                            </tr>
                        }
                        </tbody>
                    </table>

                    <Pagination CurrentPage="_customersCurrentPage"
                                TotalPages="CustomersTotalPages"
                                TotalItems="_customersTotalCount"
                                StartItem="CustomersPageStart"
                                EndItem="CustomersPageEnd"
                                PageChanged="GoToCustomerPage"/>
                }

                <div class="customer-view-footer">
                    <button class="secondary-button"
                            type="button"
                            @onclick="CloseCustomerSelectModal">
                        Отмена
                    </button>

                    <button class="secondary-button"
                            type="button"
                            @onclick="OpenCreateCustomerModal">
                        <i class="bi bi-plus-lg"></i>
                        Новый клиент
                    </button>

                    <button class="primary-button"
                            type="button"
                            disabled="@(_selectedCustomer is null)"
                            @onclick="SelectCustomer">
                        <i class="bi bi-check-lg"></i>
                        Выбрать клиента
                    </button>
                </div>

            </div>
        </div>
    }

    @if (_isToolSelectModalOpen)
    {
        <div class="actions-backdrop">
            <div class="customer-view-modal tool-select-modal" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>Выбор инструментов</h3>
                        <p>Выберите один или несколько инструментов для заказа</p>
                    </div>

                    <button type="button" @onclick="CloseToolSelectModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="selected-customer-banner @(_newOrder.Tools.Count == 0 ? "empty" : "selected")">

                    @if (_newOrder.Tools.Count == 0)
                    {
                        <i class="bi bi-tools"></i>

                        <span>
                            Инструменты не выбраны
                        </span>
                    }
                    else
                    {
                        <i class="bi bi-check-circle-fill"></i>

                        <span>
                            Выбрано инструментов:
                            <strong>@_newOrder.Tools.Count</strong>
                        </span>
                    }

                </div>

                <div class="filter-group search-filter">
                    <label>Поиск инструмента</label>

                    <div class="search-box">
                        <i class="bi bi-search"></i>

                        <input placeholder="Название, инвентарный или серийный номер..."
                               value="@_toolSearch"
                               @oninput="OnToolSearchChanged"/>
                    </div>
                </div>

                @if (_isToolsLoading)
                {
                    <table class="users-table user-select-table tool-select-table">
                        <thead>
                        <tr>
                            <th class="tool-name-column">Инструмент</th>
                            <th class="tool-category-column">Категория</th>
                            <th class="tool-manufacturer-column">Производитель</th>
                            <th class="tool-serial-column">Серийный номер</th>
                            <th class="tool-price-column">Аренда/день</th>
                            <th class="tool-deposit-column">Залог</th>
                            <th class="tool-status-column">Статус</th>
                        </tr>
                        </thead>

                        <tbody>
                        @for (var i = 0; i < ToolPageSize; i++)
                        {
                            <tr>
                                <td>
                                    <div class="user-select-customer">
                                        <div class="skeleton skeleton-avatar"></div>

                                        <div class="skeleton-lines">
                                            <div class="skeleton skeleton-line wide"></div>
                                            <div class="skeleton skeleton-line small"></div>
                                        </div>
                                    </div>
                                </td>

                                <td><div class="skeleton skeleton-line medium"></div></td>
                                <td><div class="skeleton skeleton-line medium"></div></td>
                                <td><div class="skeleton skeleton-line medium"></div></td>
                                <td><div class="skeleton skeleton-line small"></div></td>
                                <td><div class="skeleton skeleton-line small"></div></td>
                                <td><div class="skeleton skeleton-badge"></div></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
                else if (_tools.Count == 0)
                {
                    <div class="table-empty">Инструменты не найдены</div>
                }
                else
                {
                    <table class="users-table user-select-table tool-select-table">
                        <thead>
                        <tr>
                            <th class="tool-name-column sortable-column"
                                @onclick='() => ChangeToolSort("name")'>
                                Инструмент <i class="bi bi-arrow-down-up"></i>
                            </th>

                            <th class="tool-category-column sortable-column"
                                @onclick='() => ChangeToolSort("category")'>
                                Категория <i class="bi bi-arrow-down-up"></i>
                            </th>

                            <th class="tool-manufacturer-column sortable-column"
                                @onclick='() => ChangeToolSort("manufacturer")'>
                                Производитель <i class="bi bi-arrow-down-up"></i>
                            </th>

                            <th class="tool-serial-column sortable-column"
                                @onclick='() => ChangeToolSort("serialnumber")'>
                                Серийный номер <i class="bi bi-arrow-down-up"></i>
                            </th>

                            <th class="tool-price-column sortable-column"
                                @onclick='() => ChangeToolSort("rentalprice")'>
                                Аренда/день <i class="bi bi-arrow-down-up"></i>
                            </th>

                            <th class="tool-deposit-column sortable-column"
                                @onclick='() => ChangeToolSort("deposit")'>
                                Залог <i class="bi bi-arrow-down-up"></i>
                            </th>

                            <th class="tool-status-column sortable-column"
                                @onclick='() => ChangeToolSort("status")'>
                                Статус <i class="bi bi-arrow-down-up"></i>
                            </th>
                        </tr>
                        </thead>

                        <tbody>
                        @foreach (var tool in _tools)
                        {
                            <tr class="@(IsToolSelected(tool) ? "selected" : "")"
                                @onclick="() => ToggleToolSelection(tool)">

                                <td>
                                    <div class="user-select-customer">
                                        <div class="tool-select-image">
                                            @if (!string.IsNullOrWhiteSpace(tool.PhotoPath))
                                            {
                                                <img src="@GetToolImageUrl(tool.PhotoPath)"
                                                     alt="@tool.Name"/>
                                            }
                                            else
                                            {
                                                <i class="bi bi-tools"></i>
                                            }
                                        </div>

                                        <div class="user-select-info">
                                            <strong>@tool.Name</strong>
                                            <span>Инв. № @tool.InventoryNumber</span>
                                        </div>
                                    </div>
                                </td>

                                <td>@tool.CategoryName</td>
                                <td>@tool.ManufacturerName</td>
                                <td>@tool.SerialNumber</td>
                                <td>@tool.RentalPricePerDay.ToString("N0") ₽</td>
                                <td>@tool.DepositAmount.ToString("N0") ₽</td>

                                <td>
                                    <span class="@GetToolStatusClass(tool.StatusName)">
                                        @tool.StatusName
                                    </span>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>

                    <Pagination CurrentPage="_toolsCurrentPage"
                                TotalPages="ToolsTotalPages"
                                TotalItems="_toolsTotalCount"
                                StartItem="ToolsPageStart"
                                EndItem="ToolsPageEnd"
                                PageChanged="GoToToolPage"/>
                }

                <div class="customer-view-footer">
                    <button class="secondary-button"
                            type="button"
                            @onclick="CloseToolSelectModal">
                        Отмена
                    </button>

                    <button class="primary-button"
                            type="button"
                            disabled="@(_newOrder.Tools.Count == 0)"
                            @onclick="SelectTools">
                        <i class="bi bi-check-lg"></i>
                        Выбрать инструменты
                    </button>
                </div>

            </div>
        </div>
    }

    @if (_isCancelOrderModalOpen && _cancellingOrder is not null)
    {
        <div class="actions-backdrop">
            <div class="actions-modal" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>Отмена заказа</h3>
                        <p>Подтверждение операции</p>
                    </div>

                    <button type="button"
                            @onclick="CloseCancelOrderModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="actions-modal-body">

                    <p>
                        Вы действительно хотите отменить заказ
                        <strong>@_cancellingOrder.Number</strong>?
                    </p>

                    <p class="text-muted">
                        Заказ перейдет в статус «Отменен», а все инструменты будут возвращены в статус «Доступен».
                    </p>

                    <p class="text-muted">
                        Документы для отмененного заказа отображаться не будут.
                    </p>

                </div>

                <div class="tool-form-actions modal-footer">

                    <button class="secondary-button"
                            type="button"
                            @onclick="CloseCancelOrderModal">
                        Нет
                    </button>

                    <button class="primary-button"
                            type="button"
                            @onclick="CancelOrderAsync">
                        <i class="bi bi-x-circle"></i>
                        Да, отменить
                    </button>

                </div>

            </div>
        </div>
    }

    <CreateCustomerModal IsOpen="_isCreateCustomerModalOpen"
                         IsOpenChanged="CloseCreateCustomerModal"
                         CustomerCreated="OnCustomerCreated"/>
</div>

@code
{
    private OrderDto? _cancellingOrder;
    private bool _isCancelOrderModalOpen;

    private Guid? _currentUserId;

    private const int PageSize = 5;
    private const int CustomerPageSize = 3;
    private const int ToolPageSize = 3;

    private int _currentPage = 1;

    private string? _search;
    private string? _status;
    private DateOnly? _startFrom;
    private DateOnly? _startTo;

    private string _activeStatsFilter = "all";
    private string _sortBy = "createdat";
    private bool _descending = true;

    private bool _isActionsMenuOpen;
    private bool _isCreateModalOpen;
    private bool _isCustomerSelectModalOpen;
    private bool _isToolSelectModalOpen;

    private OrderDto? _selectedOrder;

    private CancellationTokenSource? _customerSearchCts;
    private List<CustomerDto> _customers = [];
    private CustomerDto? _selectedCustomer;
    private bool _isCustomersLoading;
    private int _customersCurrentPage = 1;
    private int _customersTotalCount;
    private string? _customerSearch;
    private string? _customerSortBy = "fullname";
    private bool _customerDescending;
    private bool _isCreateCustomerModalOpen;

    private Guid? _availableToolStatusId;
    private CancellationTokenSource? _toolSearchCts;
    private List<ToolDto> _tools = [];
    private bool _isToolsLoading;
    private int _toolsCurrentPage = 1;
    private int _toolsTotalCount;
    private string? _toolSearch;
    private string? _toolSortBy = "name";
    private bool _toolDescending;

    private OrderFormModel _newOrder = new();

    private int SelectedToolsCount => _newOrder.Tools.Count;

    private decimal TotalToPay =>
        _newOrder.TotalAmount + _newOrder.DepositAmount;

    private const int OrderToolsPageSize = 3;

    private int _orderToolsCurrentPage = 1;

    private IEnumerable<OrderToolFormModel> PagedOrderTools =>
        _newOrder.Tools
            .Skip((_orderToolsCurrentPage - 1) * OrderToolsPageSize)
            .Take(OrderToolsPageSize);

    private int OrderToolsTotalPages =>
        _newOrder.Tools.Count == 0
            ? 1
            : (int)Math.Ceiling(_newOrder.Tools.Count / (double)OrderToolsPageSize);

    private int OrderToolsPageStart =>
        _newOrder.Tools.Count == 0
            ? 0
            : ((_orderToolsCurrentPage - 1) * OrderToolsPageSize) + 1;

    private int OrderToolsPageEnd =>
        Math.Min(_orderToolsCurrentPage * OrderToolsPageSize, _newOrder.Tools.Count);

    private string RentalDaysText
    {
        get
        {
            var days = GetRentalDays();

            return days <= 0
                ? "0 дней"
                : $"{days} дня";
        }
    }

    private int FilteredTotalCount => _filteredTotalCount;

    private int TotalPages =>
        _filteredTotalCount <= 0
            ? 1
            : (int)Math.Ceiling(_filteredTotalCount / (double)PageSize);

    private int PageStart =>
        _filteredTotalCount == 0
            ? 0
            : ((_currentPage - 1) * PageSize) + 1;

    private int PageEnd =>
        Math.Min(_currentPage * PageSize, _filteredTotalCount);

    private int CustomersTotalPages =>
        _customersTotalCount <= 0
            ? 1
            : (int)Math.Ceiling(_customersTotalCount / (double)CustomerPageSize);

    private int CustomersPageStart =>
        _customersTotalCount == 0
            ? 0
            : ((_customersCurrentPage - 1) * CustomerPageSize) + 1;

    private int CustomersPageEnd =>
        Math.Min(_customersCurrentPage * CustomerPageSize, _customersTotalCount);

    private int ToolsTotalPages =>
        _toolsTotalCount <= 0
            ? 1
            : (int)Math.Ceiling(_toolsTotalCount / (double)ToolPageSize);

    private int ToolsPageStart =>
        _toolsTotalCount == 0
            ? 0
            : ((_toolsCurrentPage - 1) * ToolPageSize) + 1;

    private int ToolsPageEnd =>
        Math.Min(_toolsCurrentPage * ToolPageSize, _toolsTotalCount);

    private bool _isLoading;

    private List<OrderDto> _orders = [];

    private List<OrderStatusDto> _orderStatuses = [];
    private Guid? _selectedStatusId;

    private int _filteredTotalCount;

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentUserAsync();
        await LoadOrderStatusesAsync();
        await LoadOrdersAsync();
    }

    private async Task LoadOrdersAsync()
    {
        _isLoading = true;
        await InvokeAsync(StateHasChanged);

        var request = new GetOrdersRequest(
            Search: _search,
            StatusId: _selectedStatusId,
            StartFrom: _startFrom,
            StartTo: _startTo,
            EndFrom: null,
            EndTo: null,
            SortBy: _sortBy,
            Descending: _descending,
            Page: _currentPage,
            PageSize: PageSize);

        var result = await OrdersService.GetOrdersAsync(request);

        if (result.IsFailure)
        {
            _orders = [];
            _filteredTotalCount = 0;
            _isLoading = false;

            NotificationService.Error(result.Error.Message);
            return;
        }

        _orders = result.Value.Items.ToList();
        _filteredTotalCount = result.Value.TotalCount;

        if (_currentPage > TotalPages)
        {
            _currentPage = TotalPages;
            await LoadOrdersAsync();
            return;
        }

        _isLoading = false;
    }

    private async Task LoadOrderStatusesAsync()
    {
        var result = await OrderStatusesService.GetOrderStatusesAsync();

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        _orderStatuses = result.Value;
    }

    private async Task LoadCurrentUserAsync()
    {
        var authState =
            await AuthenticationStateProvider.GetAuthenticationStateAsync();

        var userId = authState.User
            .FindFirst(ClaimTypes.NameIdentifier)?
            .Value;

        if (string.IsNullOrWhiteSpace(userId) ||
            !Guid.TryParse(userId, out var id))
        {
            NotificationService.Error("Не удалось определить текущего пользователя");
            return;
        }

        _currentUserId = id;
    }

    private void GoToOrderToolsPage(int page)
    {
        if (page < 1 || page > OrderToolsTotalPages)
            return;

        _orderToolsCurrentPage = page;
    }

    private async Task ApplyStatsFilter(string filter)
    {
        _activeStatsFilter = filter;
        _status = null;
        _selectedStatusId = null;

        switch (filter)
        {
            case "active":
                _status = "Активен";
                break;

            case "completed":
                _status = "Завершен";
                break;

            case "overdue":
                _status = "Просрочен";
                break;
        }

        ApplyStatusFilter();

        _currentPage = 1;

        await LoadOrdersAsync();
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        _search = e.Value?.ToString();
        _activeStatsFilter = "custom";
        _currentPage = 1;

        await LoadOrdersAsync();
    }

    private async Task ChangeSort(string sortBy)
    {
        if (_sortBy == sortBy)
            _descending = !_descending;
        else
        {
            _sortBy = sortBy;
            _descending = false;
        }

        _currentPage = 1;

        await LoadOrdersAsync();
    }

    private string GetStatsCardClass(string filter)
    {
        return _activeStatsFilter == filter
            ? "active"
            : string.Empty;
    }

    private void OpenActionsMenu(OrderDto order)
    {
        _selectedOrder = order;
        _isActionsMenuOpen = true;
    }

    private void CloseActionsMenu()
    {
        _selectedOrder = null;
        _isActionsMenuOpen = false;
    }

    private void OpenOrder(Guid orderId)
    {
        Navigation.NavigateTo($"/orders/{orderId}");
    }

    private void OpenSelectedOrderView()
    {
        if (_selectedOrder is null)
            return;

        var orderId = _selectedOrder.Id;

        CloseActionsMenu();

        OpenOrder(orderId);
    }

    private void OpenCreateModal()
    {
        _newOrder = new OrderFormModel
        {
            OrderDate = DateOnly.FromDateTime(DateTime.Today),
            StartDate = DateOnly.FromDateTime(DateTime.Today),
            EndDate = DateOnly.FromDateTime(DateTime.Today.AddDays(3))
        };

        _orderToolsCurrentPage = 1;
        _isCreateModalOpen = true;
    }

    private void CloseCreateModal()
    {
        _newOrder = new OrderFormModel();
        _selectedCustomer = null;
        _isCreateModalOpen = false;
    }

    private async Task LoadCustomersForSelectAsync()
    {
        _isCustomersLoading = true;

        var request = new GetCustomersRequest(
            Search: _customerSearch,
            HasOrders: null,
            HasActiveOrders: null,
            IsRegular: null,
            SortBy: _customerSortBy,
            Descending: _customerDescending,
            Page: _customersCurrentPage,
            PageSize: CustomerPageSize);

        var result = await CustomersService.GetCustomersAsync(request);

        if (result.IsFailure)
        {
            _customers = [];
            _customersTotalCount = 0;
            _isCustomersLoading = false;

            NotificationService.Error(result.Error.Message);
            return;
        }

        _customers = result.Value.Items.ToList();
        _customersTotalCount = result.Value.TotalCount;

        if (_customersCurrentPage > CustomersTotalPages)
        {
            _customersCurrentPage = CustomersTotalPages;
            await LoadCustomersForSelectAsync();
            return;
        }

        _isCustomersLoading = false;
    }

    private async Task OpenCustomerSelectModal()
    {
        _customerSearch = string.Empty;
        _customerSortBy = "fullname";
        _customerDescending = false;
        _customersCurrentPage = 1;
        _selectedCustomer = null;

        _isCustomerSelectModalOpen = true;

        await LoadCustomersForSelectAsync();
    }

    private void CloseCustomerSelectModal()
    {
        _customerSearch = string.Empty;
        _selectedCustomer = null;
        _customers = [];
        _customersTotalCount = 0;

        _isCustomerSelectModalOpen = false;
    }

    private async Task OnCustomerSearchChanged(ChangeEventArgs e)
    {
        _customerSearch = e.Value?.ToString();

        _customerSearchCts?.Cancel();
        _customerSearchCts?.Dispose();

        _customerSearchCts = new CancellationTokenSource();
        var token = _customerSearchCts.Token;

        try
        {
            await Task.Delay(500, token);

            _customersCurrentPage = 1;
            await LoadCustomersForSelectAsync();
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task ChangeCustomerSort(string sortBy)
    {
        if (_customerSortBy == sortBy)
            _customerDescending = !_customerDescending;
        else
        {
            _customerSortBy = sortBy;
            _customerDescending = false;
        }

        _customersCurrentPage = 1;

        await LoadCustomersForSelectAsync();
    }

    private async Task GoToCustomerPage(int page)
    {
        if (page < 1 || page > CustomersTotalPages)
            return;

        _customersCurrentPage = page;

        await LoadCustomersForSelectAsync();
    }

    private void SelectCustomer()
    {
        if (_selectedCustomer is null)
        {
            NotificationService.Error("Выберите клиент");
            return;
        }

        _newOrder.CustomerId = _selectedCustomer.Id;
        _newOrder.CustomerName = _selectedCustomer.FullName;

        CloseCustomerSelectModal();

        NotificationService.Success($"Выбран клиент: {_newOrder.CustomerName}");
    }

    private async Task LoadToolsForSelectAsync()
    {
        _isToolsLoading = true;

