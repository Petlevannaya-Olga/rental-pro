@page "/customers"
@layout AdminLayout

@using RentalPro.Contracts.Customers
@using RentalPro.Contracts.Orders
@using RentalPro.Presentation.Client.Models.Customers
@using RentalPro.Presentation.Client.Services

@inject CustomersService CustomersService
@inject NotificationService NotificationService
@inject FakeCustomerGeneratorService FakeCustomerGeneratorService
@inject OrdersService OrdersService

<div class="users-page">

    <div class="users-stats">

        <div class="stats-filter-card @GetStatsCardClass("all")"
             @onclick='() => ApplyStatsFilter("all")'>
            <StatCard Title="Всего клиентов"
                      Value="@_statsTotalCount.ToString()"
                      Icon="bi bi-people"
                      Color="blue"/>
        </div>

        <div class="stats-filter-card @GetStatsCardClass("withOrders")"
             @onclick='() => ApplyStatsFilter("withOrders")'>
            <StatCard Title="С заказами"
                      Value="@_withOrdersCount.ToString()"
                      Icon="bi bi-receipt"
                      Color="orange"/>
        </div>

        <div class="stats-filter-card @GetStatsCardClass("regular")"
             @onclick='() => ApplyStatsFilter("regular")'>
            <StatCard Title="Постоянные"
                      Value="@_regularCustomersCount.ToString()"
                      Icon="bi bi-star"
                      Color="purple"/>
        </div>

        <div class="stats-filter-card @GetStatsCardClass("withActiveOrders")"
             @onclick='() => ApplyStatsFilter("withActiveOrders")'>
            <StatCard Title="С активной арендой"
                      Value="@_withActiveOrdersCount.ToString()"
                      Icon="bi bi-tools"
                      Color="green"/>
        </div>

        <button class="users-add-card"
                @onclick="OpenCreateModal">
            <i class="bi bi-plus-lg"></i>
            <span>Добавить клиента</span>
        </button>

    </div>

    <div class="users-table-card">

        <div class="customers-filters">

            <div class="customers-filters-top">

                <div class="filter-group search-filter">
                    <label>Поиск по ФИО, телефону, email или адресу</label>

                    <div class="search-box">
                        <i class="bi bi-search"></i>

                        <input placeholder="ФИО, телефон, email, паспорт или адрес..."
                               value="@_search"
                               @oninput="OnSearchChanged"/>
                    </div>
                </div>

                <button class="secondary-button"
                        @onclick="ExportCustomers">
                    <i class="bi bi-download"></i>
                    Экспорт
                </button>

            </div>

            <div class="customers-filters-bottom">

                <div class="filter-group">
                    <label>Заказы</label>

                    <select class="filter-select"
                            @bind="_ordersFilter"
                            @bind:after="ApplyFilters">
                        <option value="">Все клиенты</option>
                        <option value="withOrders">С заказами</option>
                        <option value="withoutOrders">Без заказов</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label>Постоянные</label>

                    <select class="filter-select"
                            @bind="_regularFilter"
                            @bind:after="ApplyFilters">
                        <option value="">Все клиенты</option>
                        <option value="regular">Постоянные</option>
                        <option value="notRegular">Не постоянные</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label>Активная аренда</label>

                    <select class="filter-select"
                            @bind="_activeOrdersFilter"
                            @bind:after="ApplyFilters">
                        <option value="">Все клиенты</option>
                        <option value="withActiveOrders">С активной арендой</option>
                        <option value="withoutActiveOrders">Без активной аренды</option>
                    </select>
                </div>

                <button class="secondary-button"
                        @onclick="ResetFilters">
                    <i class="bi bi-arrow-counterclockwise"></i>
                    Сбросить
                </button>

            </div>

        </div>

        @if (_isLoading)
        {
            <table class="users-table">
                <thead>
                <tr>
                    <th>Клиент</th>
                    <th>Телефон</th>
                    <th>Email</th>
                    <th>Паспорт</th>
                    <th>Заказов</th>
                    <th>Активных</th>
                    <th></th>
                </tr>
                </thead>

                <tbody>
                @for (var i = 0; i < PageSize; i++)
                {
                    <tr>
                        <td>
                            <div class="skeleton-user-cell">
                                <div class="skeleton skeleton-avatar"></div>
                                <div class="skeleton-lines">
                                    <div class="skeleton skeleton-line wide"></div>
                                    <div class="skeleton skeleton-line small"></div>
                                </div>
                            </div>
                        </td>

                        <td>
                            <div class="skeleton skeleton-line medium"></div>
                        </td>
                        <td>
                            <div class="skeleton skeleton-line medium"></div>
                        </td>
                        <td>
                            <div class="skeleton skeleton-line medium"></div>
                        </td>
                        <td>
                            <div class="skeleton skeleton-line small"></div>
                        </td>
                        <td>
                            <div class="skeleton skeleton-badge"></div>
                        </td>
                        <td>
                            <div class="skeleton skeleton-dot"></div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
        else if (_customers.Count == 0)
        {
            <div class="table-empty">Клиенты не найдены</div>
        }
        else
        {
            <table class="users-table">
                <thead>
                <tr>
                    <th class="sortable-column" @onclick='() => ChangeSort("fullname")'>
                        Клиент <i class="bi bi-arrow-down-up"></i>
                    </th>

                    <th class="sortable-column" @onclick='() => ChangeSort("phone")'>
                        Телефон <i class="bi bi-arrow-down-up"></i>
                    </th>

                    <th class="sortable-column" @onclick='() => ChangeSort("email")'>
                        Email <i class="bi bi-arrow-down-up"></i>
                    </th>

                    <th class="sortable-column" @onclick='() => ChangeSort("passport")'>
                        Паспорт <i class="bi bi-arrow-down-up"></i>
                    </th>

                    <th class="sortable-column" @onclick='() => ChangeSort("orders")'>
                        Заказов <i class="bi bi-arrow-down-up"></i>
                    </th>

                    <th class="sortable-column" @onclick='() => ChangeSort("activeorders")'>
                        Активных <i class="bi bi-arrow-down-up"></i>
                    </th>

                    <th></th>
                </tr>
                </thead>

                <tbody>
                @foreach (var customer in _customers)
                {
                    <tr>
                        <td>
                            <div class="user-cell">
                                <div class="user-avatar">
                                    @GetInitials(customer)
                                </div>

                                <div>
                                    <strong>@customer.FullName</strong>
                                    <span>@GetAddressOrDash(customer)</span>
                                </div>
                            </div>
                        </td>

                        <td>@customer.PhoneNumber</td>
                        <td>@customer.Email</td>
                        <td>@customer.Passport</td>
                        <td>@customer.OrdersCount</td>

                        <td>
                            <span class="@GetActiveOrdersClass(customer.ActiveOrdersCount)">
                                @customer.ActiveOrdersCount
                            </span>
                        </td>

                        <td class="actions-cell">
                            <button class="icon-button"
                                    @onclick="() => OpenActionsMenu(customer)">
                                <i class="bi bi-three-dots"></i>
                            </button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }

        <Pagination CurrentPage="_currentPage"
                    TotalPages="TotalPages"
                    TotalItems="_filteredTotalCount"
                    StartItem="PageStart"
                    EndItem="PageEnd"
                    PageChanged="GoToPage">
            <LeftContent>
                <button class="secondary-button"
                        type="button"
                        @onclick="GenerateFakeCustomers">
                    <i class="bi bi-magic"></i>
                    Заполнить тестовыми данными
                </button>
            </LeftContent>
        </Pagination>

    </div>

    @if (_isActionsMenuOpen && _selectedCustomer is not null)
    {
        <div class="actions-backdrop" @onclick="CloseActionsMenu">
            <div class="actions-modal" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>Действия с клиентом</h3>
                        <p>@_selectedCustomer.FullName</p>
                    </div>

                    <button type="button" @onclick="CloseActionsMenu">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <button class="menu-item" @onclick="OpenViewModal">
                    <i class="bi bi-eye"></i>
                    Просмотр
                </button>

                <button class="menu-item" @onclick="OpenEditModal">
                    <i class="bi bi-pencil"></i>
                    Редактировать
                </button>

                <button class="menu-item" @onclick='() => ExecuteCustomerAction("История заказов")'>
                    <i class="bi bi-clock-history"></i>
                    История заказов
                </button>

                <div class="menu-divider"></div>

                <button class="menu-item menu-danger" @onclick="OpenDeleteModal">
                    <i class="bi bi-trash"></i>
                    Удалить
                </button>

            </div>
        </div>
    }

    @if (_isCreateModalOpen)
    {
        <div class="actions-backdrop">
            <div class="tool-create-modal large" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>Добавить клиента</h3>
                        <p>Заполните данные клиента</p>
                    </div>

                    <button type="button" @onclick="CloseCreateModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <EditForm Model="_newCustomer" OnValidSubmit="CreateCustomer">
                    <DataAnnotationsValidator/>

                    <div class="customer-create-layout">

                        <div class="customer-create-section">
                            <div class="customer-create-section-title">
                                <i class="bi bi-person"></i>
                                <span>Данные клиента</span>
                            </div>

                            <div class="customer-create-grid">

                                <div class="tool-form-field">
                                    <label>Фамилия <span>*</span></label>
                                    <InputText @bind-Value="_newCustomer.LastName"
                                               placeholder="Введите фамилию"/>
                                    <ValidationMessage For="@(() => _newCustomer.LastName)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Имя <span>*</span></label>
                                    <InputText @bind-Value="_newCustomer.FirstName"
                                               placeholder="Введите имя"/>
                                    <ValidationMessage For="@(() => _newCustomer.FirstName)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Отчество <span>*</span></label>
                                    <InputText @bind-Value="_newCustomer.MiddleName"
                                               placeholder="Введите отчество"/>
                                    <ValidationMessage For="@(() => _newCustomer.MiddleName)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Телефон <span>*</span></label>
                                    <InputText @bind-Value="_newCustomer.PhoneNumber"
                                               placeholder="Введите номер телефона"/>
                                    <ValidationMessage For="@(() => _newCustomer.PhoneNumber)"/>
                                </div>

                                <div class="tool-form-field wide">
                                    <label>Email <span>*</span></label>
                                    <InputText @bind-Value="_newCustomer.Email"
                                               placeholder="Введите email"/>
                                    <ValidationMessage For="@(() => _newCustomer.Email)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Серия паспорта <span>*</span></label>
                                    <InputText @bind-Value="_newCustomer.PassportSeries"
                                               placeholder="Введите серию паспорта"/>
                                    <ValidationMessage For="@(() => _newCustomer.PassportSeries)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Номер паспорта <span>*</span></label>
                                    <InputText @bind-Value="_newCustomer.PassportNumber"
                                               placeholder="Введите номер паспорта"/>
                                    <ValidationMessage For="@(() => _newCustomer.PassportNumber)"/>
                                </div>

                            </div>
                        </div>

                        <div class="customer-create-section">
                            <div class="customer-create-section-title">
                                <i class="bi bi-geo-alt"></i>
                                <span>Адрес</span>
                            </div>

                            <div class="customer-create-grid">

                                <div class="tool-form-field">
                                    <label>Индекс <span>*</span></label>
                                    <InputText @bind-Value="_newCustomer.PostalCode"
                                               placeholder="Введите индекс"/>
                                    <ValidationMessage For="@(() => _newCustomer.PostalCode)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Регион <span>*</span></label>
                                    <InputText @bind-Value="_newCustomer.Region"
                                               placeholder="Введите регион"/>
                                    <ValidationMessage For="@(() => _newCustomer.Region)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Город <span>*</span></label>
                                    <InputText @bind-Value="_newCustomer.City"
                                               placeholder="Введите город"/>
                                    <ValidationMessage For="@(() => _newCustomer.City)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Улица <span>*</span></label>
                                    <InputText @bind-Value="_newCustomer.Street"
                                               placeholder="Введите улицу"/>
                                    <ValidationMessage For="@(() => _newCustomer.Street)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Дом <span>*</span></label>
                                    <InputText @bind-Value="_newCustomer.House"
                                               placeholder="Введите номер дома"/>
                                    <ValidationMessage For="@(() => _newCustomer.House)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Корпус</label>
                                    <InputText @bind-Value="_newCustomer.Building"
                                               placeholder="Введите корпус"/>
                                </div>

                                <div class="tool-form-field wide">
                                    <label>Квартира/офис</label>
                                    <InputText @bind-Value="_newCustomer.Apartment"
                                               placeholder="Введите квартиру или офис"/>
                                </div>

                            </div>
                        </div>

                    </div>

                    <div class="customer-create-actions">
                        <button class="secondary-button"
                                type="button"
                                @onclick="CloseCreateModal">
                            Отмена
                        </button>

                        <button class="secondary-button"
                                type="button"
                                @onclick="FillFakeCustomerData">
                            <i class="bi bi-magic"></i>
                            Заполнить тестовыми данными
                        </button>

                        <button class="primary-button"
                                type="submit">
                            <i class="bi bi-check-lg"></i>
                            Сохранить клиента
                        </button>
                    </div>
                </EditForm>

            </div>
        </div>
    }

    @if (_isViewModalOpen && _viewCustomer is not null)
    {
        <div class="actions-backdrop">
            <div class="customer-view-modal" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>Просмотр клиента</h3>
                        <p>@_viewCustomer.FullName</p>
                    </div>

                    <button type="button" @onclick="CloseViewModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="customer-details-grid">

                    <div class="customer-detail-item">
                        <span>ФИО</span>
                        <strong>@_viewCustomer.FullName</strong>
                    </div>

                    <div class="customer-detail-item">
                        <span>Телефон</span>
                        <strong>@_viewCustomer.PhoneNumber</strong>
                    </div>

                    <div class="customer-detail-item">
                        <span>Email</span>
                        <strong>@_viewCustomer.Email</strong>
                    </div>

                    <div class="customer-detail-item">
                        <span>Паспорт</span>
                        <strong>@_viewCustomer.Passport</strong>
                    </div>

                    <div class="customer-detail-item">
                        <span>Заказов</span>
                        <strong>@_viewCustomer.OrdersCount</strong>
                    </div>

                    <div class="customer-detail-item">
                        <span>Активных аренд</span>
                        <strong>@_viewCustomer.ActiveOrdersCount</strong>
                    </div>

                    <div class="customer-detail-item">
                        <span>Дата создания</span>
                        <strong>@_viewCustomer.CreatedAt.ToString("dd.MM.yyyy HH:mm")</strong>
                    </div>

                    <div class="customer-detail-item">
                        <span>Дата изменения</span>
                        <strong>@(_viewCustomer.UpdatedAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")</strong>
                    </div>

                    <div class="customer-detail-item customer-address-item">
                        <span>Адрес</span>
                        <strong>@GetAddressOrDash(_viewCustomer)</strong>
                    </div>

                </div>

                <div class="customer-view-footer">
                    <button class="secondary-button"
                            type="button"
                            @onclick="CloseViewModal">
                        Закрыть
                    </button>
                </div>

            </div>
        </div>
    }

    @if (_isEditModalOpen && _editingCustomer is not null)
    {
        <div class="actions-backdrop">
            <div class="tool-create-modal large" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>Редактировать клиента</h3>
                        <p>@_editingCustomer.FullName</p>
                    </div>

                    <button type="button" @onclick="CloseEditModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <EditForm Model="_editCustomer" OnValidSubmit="UpdateCustomer">
                    <DataAnnotationsValidator/>

                    <div class="customer-create-layout">

                        <div class="customer-create-section">
                            <div class="customer-create-section-title">
                                <i class="bi bi-person"></i>
                                <span>Данные клиента</span>
                            </div>

                            <div class="customer-create-grid">

                                <div class="tool-form-field">
                                    <label>Фамилия <span>*</span></label>
                                    <InputText @bind-Value="_editCustomer.LastName"
                                               placeholder="Введите фамилию"/>
                                    <ValidationMessage For="@(() => _editCustomer.LastName)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Имя <span>*</span></label>
                                    <InputText @bind-Value="_editCustomer.FirstName"
                                               placeholder="Введите имя"/>
                                    <ValidationMessage For="@(() => _editCustomer.FirstName)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Отчество <span>*</span></label>
                                    <InputText @bind-Value="_editCustomer.MiddleName"
                                               placeholder="Введите отчество"/>
                                    <ValidationMessage For="@(() => _editCustomer.MiddleName)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Телефон <span>*</span></label>
                                    <InputText @bind-Value="_editCustomer.PhoneNumber"
                                               placeholder="Введите номер телефона"/>
                                    <ValidationMessage For="@(() => _editCustomer.PhoneNumber)"/>
                                </div>

                                <div class="tool-form-field wide">
                                    <label>Email <span>*</span></label>
                                    <InputText @bind-Value="_editCustomer.Email"
                                               placeholder="Введите email"/>
                                    <ValidationMessage For="@(() => _editCustomer.Email)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Серия паспорта <span>*</span></label>
                                    <InputText @bind-Value="_editCustomer.PassportSeries"
                                               placeholder="Введите серию паспорта"/>
                                    <ValidationMessage For="@(() => _editCustomer.PassportSeries)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Номер паспорта <span>*</span></label>
                                    <InputText @bind-Value="_editCustomer.PassportNumber"
                                               placeholder="Введите номер паспорта"/>
                                    <ValidationMessage For="@(() => _editCustomer.PassportNumber)"/>
                                </div>

                            </div>
                        </div>

                        <div class="customer-create-section">
                            <div class="customer-create-section-title">
                                <i class="bi bi-geo-alt"></i>
                                <span>Адрес</span>
                            </div>

                            <div class="customer-create-grid">

                                <div class="tool-form-field">
                                    <label>Индекс <span>*</span></label>
                                    <InputText @bind-Value="_editCustomer.PostalCode"
                                               placeholder="Введите индекс"/>
                                    <ValidationMessage For="@(() => _editCustomer.PostalCode)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Регион <span>*</span></label>
                                    <InputText @bind-Value="_editCustomer.Region"
                                               placeholder="Введите регион"/>
                                    <ValidationMessage For="@(() => _editCustomer.Region)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Город <span>*</span></label>
                                    <InputText @bind-Value="_editCustomer.City"
                                               placeholder="Введите город"/>
                                    <ValidationMessage For="@(() => _editCustomer.City)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Улица <span>*</span></label>
                                    <InputText @bind-Value="_editCustomer.Street"
                                               placeholder="Введите улицу"/>
                                    <ValidationMessage For="@(() => _editCustomer.Street)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Дом <span>*</span></label>
                                    <InputText @bind-Value="_editCustomer.House"
                                               placeholder="Введите номер дома"/>
                                    <ValidationMessage For="@(() => _editCustomer.House)"/>
                                </div>

                                <div class="tool-form-field">
                                    <label>Корпус</label>
                                    <InputText @bind-Value="_editCustomer.Building"
                                               placeholder="Введите корпус"/>
                                </div>

                                <div class="tool-form-field wide">
                                    <label>Квартира/офис</label>
                                    <InputText @bind-Value="_editCustomer.Apartment"
                                               placeholder="Введите квартиру или офис"/>
                                </div>

                            </div>
                        </div>

                    </div>

                    <div class="customer-create-actions">
                        <button class="secondary-button"
                                type="button"
                                @onclick="CloseEditModal">
                            Отмена
                        </button>

                        <button class="primary-button"
                                type="submit">
                            <i class="bi bi-check-lg"></i>
                            Сохранить изменения
                        </button>
                    </div>
                </EditForm>

            </div>
        </div>
    }

    @if (_isDeleteModalOpen && _deletingCustomer is not null)
    {
        <div class="actions-backdrop">
            <div class="actions-modal" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>Удалить клиента?</h3>
                        <p>@_deletingCustomer.FullName</p>
                    </div>

                    <button type="button" @onclick="CloseDeleteModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <p>
                    Клиент будет удален из системы. Это действие нельзя отменить.
                </p>

                <div class="tool-form-actions modal-footer">
                    <button class="secondary-button"
                            type="button"
                            @onclick="CloseDeleteModal">
                        Отмена
                    </button>

                    <button class="primary-button"
                            type="button"
                            @onclick="DeleteCustomer">
                        Удалить
                    </button>
                </div>

            </div>
        </div>
    }

    @if (_isOrderHistoryModalOpen && _orderHistoryCustomer is not null)
    {
        <div class="actions-backdrop" @onclick="CloseOrderHistoryModal">
            <div class="customer-history-modal" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>История заказов</h3>
                        <p>@_orderHistoryCustomer.FullName</p>
                    </div>

                    <button type="button" @onclick="CloseOrderHistoryModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="customer-history-table-wrap">
                    @if (_isOrderHistoryLoading)
                    {
                        <div class="table-empty">
                            Загрузка истории заказов...
                        </div>
                    }
                    else if (_orderHistory.Count == 0)
                    {
                        <div class="table-empty">
                            У клиента пока нет заказов
                        </div>
                    }
                    else
                    {
                        <table class="users-table customer-history-table">
                            <thead>
                            <tr>
                                <th>Заказ</th>
                                <th>Инстр.</th>
                                <th>Выдача</th>
                                <th>Статус</th>
                                <th>Аренда</th>
                                <th>Залог</th>
                            </tr>
                            </thead>

                            <tbody>
                            @foreach (var item in _orderHistory)
                            {
                                <tr class="clickable-row"
                                    @onclick="() => OpenCustomerOrderItemsModal(item.OrderId)">
                                    <td>
                                        <strong>@item.OrderNumber</strong>
                                        <span class="table-subtitle">
                                        @item.OrderDate.ToString("dd.MM.yyyy")
                                    </span>
                                    </td>

                                    <td>@item.ToolsCount</td>

                                    <td>
                                        @(item.StartDate?.ToString("dd.MM.yyyy") ?? "-")
                                    </td>

                                    <td>
                                    <span class="@GetOrderStatusClass(item.StatusName)">
                                        @item.StatusName
                                    </span>
                                    </td>

                                    <td>@($"{item.RentalAmount:N0} ₽")</td>

                                    <td>@($"{item.DepositAmount:N0} ₽")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    }
                </div>

                <div class="customer-view-footer">
                    <button class="secondary-button"
                            type="button"
                            @onclick="CloseOrderHistoryModal">
                        Закрыть
                    </button>
                </div>

            </div>
        </div>
    }

    @if (_isOrderItemsModalOpen)
    {
        <div class="actions-backdrop" @onclick="CloseOrderItemsModal">
            <div class="order-items-modal" @onclick:stopPropagation="true">

                <div class="actions-modal-header">
                    <div>
                        <h3>Состав заказа</h3>
                        <p>@(_selectedOrderNumber is null ? "Загрузка данных заказа" : $"Заказ № {_selectedOrderNumber}")</p>
                    </div>

                    <button type="button" @onclick="CloseOrderItemsModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="order-items-table-wrap">
                    @if (_isOrderItemsLoading)
                    {
                        <div class="table-empty">
                            Загрузка состава заказа...
                        </div>
                    }
                    else
                    {
                        <OrderItemsTable Items="_selectedOrderItems" />
                    }
                </div>

                <div class="customer-view-footer">
                    <button class="secondary-button"
                            type="button"
                            @onclick="CloseOrderItemsModal">
                        Закрыть
                    </button>
                </div>

            </div>
        </div>
    }
</div>

@code
{
    private bool _isOrderItemsModalOpen;
    private bool _isOrderItemsLoading;

    private string? _selectedOrderNumber;
    private List<OrderDetailsItemDto> _selectedOrderItems = [];
    
    private bool _isOrderHistoryModalOpen;
    private bool _isOrderHistoryLoading;

    private CustomerDto? _orderHistoryCustomer;
    private List<CustomerOrderHistoryItemDto> _orderHistory = [];

    private const int PageSize = 5;

    private CancellationTokenSource? _searchCts;

    private List<CustomerDto> _customers = [];

    private CustomerDto? _selectedCustomer;
    private CustomerDto? _viewCustomer;
    private CustomerDto? _editingCustomer;
    private CustomerDto? _deletingCustomer;

    private CustomerFormModel _newCustomer = new();
    private CustomerFormModel _editCustomer = new();

    private bool _isLoading = true;
    private bool _isActionsMenuOpen;
    private bool _isCreateModalOpen;
    private bool _isViewModalOpen;
    private bool _isEditModalOpen;
    private bool _isDeleteModalOpen;

    private int _currentPage = 1;

    private int _statsTotalCount;
    private int _filteredTotalCount;
    private int _withOrdersCount;
    private int _regularCustomersCount;
    private int _withActiveOrdersCount;

    private string? _search;
    private string? _ordersFilter;
    private string? _regularFilter;
    private string? _activeOrdersFilter;

    private string? _sortBy = "createdat";
    private bool _descending = true;

    private string _activeStatsFilter = "all";

    private bool? HasOrders =>
        _ordersFilter switch
        {
            "withOrders" => true,
            "withoutOrders" => false,
            _ => null
        };

    private bool? IsRegular =>
        _regularFilter switch
        {
            "regular" => true,
            "notRegular" => false,
            _ => null
        };

    private bool? HasActiveOrders =>
        _activeOrdersFilter switch
        {
            "withActiveOrders" => true,
            "withoutActiveOrders" => false,
            _ => null
        };

    private int PageStart =>
        _filteredTotalCount == 0 ? 0 : ((_currentPage - 1) * PageSize) + 1;

    private int PageEnd =>
        Math.Min(_currentPage * PageSize, _filteredTotalCount);

    private int TotalPages =>
        _filteredTotalCount <= 0
            ? 1
            : (int)Math.Ceiling(_filteredTotalCount / (double)PageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadStatsAsync();
        await LoadCustomersAsync();
    }

    private async Task LoadCustomersAsync()
    {
        _isLoading = true;

        var request = new GetCustomersRequest(
            Search: _search,
            HasOrders: HasOrders,
            IsRegular: IsRegular,
            HasActiveOrders: HasActiveOrders,
            SortBy: _sortBy,
            Descending: _descending,
            Page: _currentPage,
            PageSize: PageSize);

        var result = await CustomersService.GetCustomersAsync(request);

        if (result.IsFailure)
        {
            _customers = [];
            _filteredTotalCount = 0;
            _isLoading = false;

            NotificationService.Error(result.Error.Message);
            return;
        }

        _customers = result.Value.Items.ToList();
        _filteredTotalCount = result.Value.TotalCount;

        if (_currentPage > TotalPages)
        {
            _currentPage = TotalPages;
            await LoadCustomersAsync();
            return;
        }

        _isLoading = false;
    }

    private async Task LoadStatsAsync()
    {
        var result = await CustomersService.GetStatsAsync();

        if (result.IsFailure)
        {
            _statsTotalCount = 0;
            _withOrdersCount = 0;
            _regularCustomersCount = 0;
            _withActiveOrdersCount = 0;

            NotificationService.Error(result.Error.Message);
            return;
        }

        _statsTotalCount = result.Value.TotalCount;
        _withOrdersCount = result.Value.WithOrdersCount;
        _regularCustomersCount = result.Value.RegularCustomersCount;
        _withActiveOrdersCount = result.Value.WithActiveOrdersCount;
    }

    private async Task ApplyStatsFilter(string filter)
    {
        _activeStatsFilter = filter;

        _ordersFilter = null;
        _regularFilter = null;
        _activeOrdersFilter = null;

        switch (filter)
        {
            case "withOrders":
                _ordersFilter = "withOrders";
                break;

            case "regular":
                _regularFilter = "regular";
                break;

            case "withActiveOrders":
                _activeOrdersFilter = "withActiveOrders";
                break;
        }

        _currentPage = 1;

        await LoadCustomersAsync();
    }

    private async Task ApplyFilters()
    {
        _activeStatsFilter = ResolveActiveStatsFilter();
        _currentPage = 1;

        await LoadCustomersAsync();
    }

    private async Task ResetFilters()
    {
        _search = string.Empty;
        _ordersFilter = null;
        _regularFilter = null;
        _activeOrdersFilter = null;
        _activeStatsFilter = "all";
        _currentPage = 1;

        await LoadCustomersAsync();
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        _search = e.Value?.ToString();
        _activeStatsFilter = ResolveActiveStatsFilter();

        _searchCts?.Cancel();
        _searchCts?.Dispose();

        _searchCts = new CancellationTokenSource();
        var token = _searchCts.Token;

        try
        {
            await Task.Delay(500, token);

            _currentPage = 1;
            await LoadCustomersAsync();
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task ChangeSort(string sortBy)
    {
        if (_sortBy == sortBy)
            _descending = !_descending;
        else
        {
            _sortBy = sortBy;
            _descending = false;
        }

        _currentPage = 1;

        await LoadCustomersAsync();
    }

    private async Task GoToPage(int page)
    {
        if (page < 1)
            return;

        if (page > TotalPages)
            return;

        _currentPage = page;

        await LoadCustomersAsync();
    }

    private string GetStatsCardClass(string filter)
    {
        return _activeStatsFilter == filter
            ? "active"
            : string.Empty;
    }

    private string ResolveActiveStatsFilter()
    {
        if (_ordersFilter == "withOrders" &&
            string.IsNullOrWhiteSpace(_regularFilter) &&
            string.IsNullOrWhiteSpace(_activeOrdersFilter))
            return "withOrders";

        if (_regularFilter == "regular" &&
            string.IsNullOrWhiteSpace(_ordersFilter) &&
            string.IsNullOrWhiteSpace(_activeOrdersFilter))
            return "regular";

        if (_activeOrdersFilter == "withActiveOrders" &&
            string.IsNullOrWhiteSpace(_ordersFilter) &&
            string.IsNullOrWhiteSpace(_regularFilter))
            return "withActiveOrders";

        if (string.IsNullOrWhiteSpace(_ordersFilter) &&
            string.IsNullOrWhiteSpace(_regularFilter) &&
            string.IsNullOrWhiteSpace(_activeOrdersFilter) &&
            string.IsNullOrWhiteSpace(_search))
            return "all";

        return "custom";
    }

    private void OpenActionsMenu(CustomerDto customer)
    {
        _selectedCustomer = customer;
        _isActionsMenuOpen = true;
    }

    private void CloseActionsMenu()
    {
        _selectedCustomer = null;
        _isActionsMenuOpen = false;
    }

    private void OpenCreateModal()
    {
        _newCustomer = new CustomerFormModel();
        _isCreateModalOpen = true;
    }

    private void CloseCreateModal()
    {
        _isCreateModalOpen = false;
        _newCustomer = new CustomerFormModel();
    }

    private async Task CreateCustomer()
    {
        var request = new CreateCustomerRequest(
            _newCustomer.LastName,
            _newCustomer.FirstName,
            _newCustomer.MiddleName,
            _newCustomer.PhoneNumber,
            _newCustomer.Email,
            _newCustomer.PassportSeries,
            _newCustomer.PassportNumber,
            _newCustomer.PostalCode,
            _newCustomer.Region,
            _newCustomer.City,
            _newCustomer.Street,
            _newCustomer.House,
            ToNullable(_newCustomer.Building),
            ToNullable(_newCustomer.Apartment));

        var result = await CustomersService.CreateCustomerAsync(request);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success($"Клиент «{result.Value.FullName}» добавлен");

        CloseCreateModal();

        _currentPage = 1;

        await LoadStatsAsync();
        await LoadCustomersAsync();
    }

    private void OpenViewModal()
    {
        if (_selectedCustomer is null)
            return;

        _viewCustomer = _selectedCustomer;

        CloseActionsMenu();

        _isViewModalOpen = true;
    }

    private void CloseViewModal()
    {
        _viewCustomer = null;
        _isViewModalOpen = false;
    }

    private void OpenEditModal()
    {
        if (_selectedCustomer is null)
            return;

        _editingCustomer = _selectedCustomer;
        _editCustomer = ToFormModel(_selectedCustomer);

        CloseActionsMenu();

        _isEditModalOpen = true;
    }

    private void CloseEditModal()
    {
        _editingCustomer = null;
        _editCustomer = new CustomerFormModel();
        _isEditModalOpen = false;
    }

    private async Task UpdateCustomer()
    {
        if (_editingCustomer is null)
            return;

        var request = new UpdateCustomerRequest(
            _editCustomer.LastName,
            _editCustomer.FirstName,
            _editCustomer.MiddleName,
            _editCustomer.PhoneNumber,
            _editCustomer.Email,
            _editCustomer.PassportSeries,
            _editCustomer.PassportNumber,
            _editCustomer.PostalCode,
            _editCustomer.Region,
            _editCustomer.City,
            _editCustomer.Street,
            _editCustomer.House,
            ToNullable(_editCustomer.Building),
            ToNullable(_editCustomer.Apartment));

        var result = await CustomersService.UpdateCustomerAsync(
            _editingCustomer.Id,
            request);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success($"Клиент «{_editCustomer.FullName}» изменен");

        CloseEditModal();

        await LoadStatsAsync();
        await LoadCustomersAsync();
    }

    private void OpenDeleteModal()
    {
        if (_selectedCustomer is null)
            return;

        _deletingCustomer = _selectedCustomer;

        CloseActionsMenu();

        _isDeleteModalOpen = true;
    }

    private void CloseDeleteModal()
    {
        _deletingCustomer = null;
        _isDeleteModalOpen = false;
    }

    private async Task DeleteCustomer()
    {
        if (_deletingCustomer is null)
            return;

        var deletedName = _deletingCustomer.FullName;

        var result = await CustomersService.DeleteCustomerAsync(
            _deletingCustomer.Id);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success($"Клиент «{deletedName}» удален");

        CloseDeleteModal();

        await LoadStatsAsync();
        await LoadCustomersAsync();
    }

    private async Task ExecuteCustomerAction(string action)
    {
        if (_selectedCustomer is null)
            return;

        if (action == "История заказов")
        {
            var customer = _selectedCustomer;

            CloseActionsMenu();

            await OpenOrderHistoryModal(customer);
            return;
        }

        NotificationService.Info($"{action}: {_selectedCustomer.FullName}");

        CloseActionsMenu();
    }

    private async Task OpenOrderHistoryModal(CustomerDto customer)
    {
        _orderHistoryCustomer = customer;
        _orderHistory = [];
        _isOrderHistoryModalOpen = true;
        _isOrderHistoryLoading = true;

        var result = await CustomersService.GetOrderHistoryAsync(customer.Id);

        if (result.IsFailure)
        {
            _isOrderHistoryLoading = false;
            NotificationService.Error(result.Error.Message);
            return;
        }

        _orderHistory = result.Value;
        _isOrderHistoryLoading = false;
    }

    private void CloseOrderHistoryModal()
    {
        _isOrderHistoryModalOpen = false;
        _isOrderHistoryLoading = false;
        _orderHistoryCustomer = null;
        _orderHistory = [];
    }

    private static string GetOrderStatusClass(string statusName)
    {
        return statusName.Trim().ToLowerInvariant() switch
        {
            "забронирован" => "status-badge reserved",
            "в аренде" => "status-badge rented",
            "выполняется" => "status-badge rented",
            "ожидает возврата залога" => "status-badge warning",
            "завершен" => "status-badge available",
            "отменен" => "status-badge cancelled",
            _ => "status-badge"
        };
    }

    private async Task ExportCustomers()
    {
        var request = new ExportCustomersRequest(
            _search,
            HasOrders,
            IsRegular,
            HasActiveOrders,
            _sortBy,
            _descending);

        var result = await CustomersService.ExportCustomersAsync(request);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success("Клиенты экспортированы");
    }

    private void FillFakeCustomerData()
    {
        _newCustomer = FakeCustomerGeneratorService.Generate();
    }

    private async Task GenerateFakeCustomers()
    {
        const int count = 10;

        for (var i = 0; i < count; i++)
        {
            var customer = FakeCustomerGeneratorService.Generate();

            var request = new CreateCustomerRequest(
                customer.LastName,
                customer.FirstName,
                customer.MiddleName,
                customer.PhoneNumber,
                customer.Email,
                customer.PassportSeries,
                customer.PassportNumber,
                customer.PostalCode,
                customer.Region,
                customer.City,
                customer.Street,
                customer.House,
                ToNullable(customer.Building),
                ToNullable(customer.Apartment));

            var result = await CustomersService.CreateCustomerAsync(request);

            if (result.IsFailure)
            {
                NotificationService.Error(result.Error.Message);
                return;
            }
        }

        _currentPage = 1;

        await LoadStatsAsync();
        await LoadCustomersAsync();

        NotificationService.Success($"Успешно создано {count} тестовых клиентов");
    }

    private static CustomerFormModel ToFormModel(CustomerDto customer)
    {
        return new CustomerFormModel
        {
            LastName = customer.LastName,
            FirstName = customer.FirstName,
            MiddleName = customer.MiddleName,
            PhoneNumber = customer.PhoneNumber,
            Email = customer.Email,
            PassportSeries = customer.PassportSeries,
            PassportNumber = customer.PassportNumber,
            PostalCode = customer.PostalCode,
            Region = customer.Region,
            City = customer.City,
            Street = customer.Street,
            House = customer.House,
            Building = customer.Building ?? string.Empty,
            Apartment = customer.Apartment ?? string.Empty
        };
    }

    private static string? ToNullable(string? value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? null
            : value.Trim();
    }

    private static string GetInitials(CustomerDto customer)
    {
        var lastNameInitial = string.IsNullOrWhiteSpace(customer.LastName)
            ? string.Empty
            : customer.LastName[0].ToString();

        var firstNameInitial = string.IsNullOrWhiteSpace(customer.FirstName)
            ? string.Empty
            : customer.FirstName[0].ToString();

        var initials = $"{lastNameInitial}{firstNameInitial}";

        return string.IsNullOrWhiteSpace(initials)
            ? "?"
            : initials;
    }

    private static string GetActiveOrdersClass(int activeOrdersCount)
    {
        return activeOrdersCount > 0
            ? "status-badge repair"
            : "status-badge available";
    }

    private static string GetAddressOrDash(CustomerDto customer)
    {
        return string.IsNullOrWhiteSpace(customer.Address)
            ? "Адрес не указан"
            : customer.Address;
    }
    
    private async Task OpenCustomerOrderItemsModal(Guid orderId)
    {
        _isOrderItemsModalOpen = true;
        _isOrderItemsLoading = true;
        _selectedOrderNumber = null;
        _selectedOrderItems = [];

        var result = await OrdersService.GetByIdAsync(orderId);

        if (result.IsFailure)
        {
            _isOrderItemsModalOpen = false;
            _isOrderItemsLoading = false;

            NotificationService.Error(result.Error.Message);
            return;
        }

        _selectedOrderNumber = result.Value.Number;
        _selectedOrderItems = result.Value.Items.ToList();

        _isOrderItemsLoading = false;
    }
    
    private void CloseOrderItemsModal()
    {
        _isOrderItemsModalOpen = false;
        _isOrderItemsLoading = false;
        _selectedOrderNumber = null;
        _selectedOrderItems = [];
    }
}ы