@page "/payments"
@layout AdminLayout

@using RentalPro.Contracts.Payments
@using RentalPro.Contracts.PaymentTypes
@using RentalPro.Contracts.PaymentMethods
@using RentalPro.Presentation.Client.Services

@inject NotificationService NotificationService
@inject PaymentsService PaymentsService
@inject PaymentTypesService PaymentTypesService
@inject PaymentMethodsService PaymentMethodsService

<div class="payments-page">

    <div class="payments-stats">

        <button class="@GetStatsCardClass("all")"
                @onclick='() => ApplyStatsFilter("all")'>
            <StatCard Title="Всего оплат"
                      Value="@_totalCount.ToString()"
                      Icon="bi bi-credit-card"
                      Color="blue"/>
        </button>

        <button class="@GetStatsCardClass("rental")"
                @onclick='() => ApplyStatsFilter("rental")'>
            <StatCard Title="Аренда"
                      Value="@_rentalCount.ToString()"
                      Icon="bi bi-calendar-check"
                      Color="green"/>
        </button>

        <button class="@GetStatsCardClass("deposit")"
                @onclick='() => ApplyStatsFilter("deposit")'>
            <StatCard Title="Залог"
                      Value="@_depositCount.ToString()"
                      Icon="bi bi-shield-check"
                      Color="orange"/>
        </button>

        <button class="@GetStatsCardClass("refund")"
                @onclick='() => ApplyStatsFilter("refund")'>
            <StatCard Title="Возврат залога"
                      Value="@_depositRefundCount.ToString()"
                      Icon="bi bi-arrow-counterclockwise"
                      Color="cyan"/>
        </button>

        <StatCard Title="Сумма оплат"
                  Value="@($"{_totalAmount:N2} ₽")"
                  Icon="bi bi-wallet2"
                  Color="purple"/>

    </div>
    
    <div class="payments-table-card">

        <div class="payments-filters">
            <div class="payments-filters-top">

                <div class="filter-group search-filter">
                    <label>Поиск по заказу, клиенту, типу, способу или комментарию</label>

                    <div class="search-box">
                        <i class="bi bi-search"></i>

                        <input placeholder="Номер заказа, клиент, комментарий..."
                               value="@_search"
                               @oninput="OnSearchChanged" />
                    </div>
                </div>

                <div class="filter-group export-filter">
                    <button class="secondary-button export-button"
                            @onclick="ExportPayments">
                        <i class="bi bi-download"></i>
                        Экспорт
                    </button>
                </div>

            </div>

            <div class="payments-filters-bottom">

                <div class="filter-group">
                    <label>Тип оплаты</label>

                    <select class="filter-select"
                            @bind="_paymentTypeId"
                            @bind:after="ApplyFilters">
                        <option value="">Все типы</option>

                        @foreach (var type in _paymentTypes)
                        {
                            <option value="@type.Id">@type.Name</option>
                        }
                    </select>
                </div>

                <div class="filter-group">
                    <label>Способ оплаты</label>

                    <select class="filter-select"
                            @bind="_paymentMethodId"
                            @bind:after="ApplyFilters">
                        <option value="">Все способы</option>

                        @foreach (var method in _paymentMethods)
                        {
                            <option value="@method.Id">@method.Name</option>
                        }
                    </select>
                </div>

                <div class="date-filter-group">
                    <label>Дата оплаты</label>

                    <div class="date-range-row">
                        <input type="date"
                               class="filter-select date-input"
                               @bind="_dateFrom"
                               @bind:after="ApplyFilters"/>

                        <span class="date-separator">—</span>

                        <input type="date"
                               class="filter-select date-input"
                               @bind="_dateTo"
                               @bind:after="ApplyFilters"/>
                    </div>
                </div>

                <div class="filter-group">
                    <button class="secondary-button filter-reset-button"
                            @onclick="ResetFilters">
                        <i class="bi bi-arrow-counterclockwise"></i>
                        Сбросить
                    </button>
                </div>

            </div>
        </div>

        @if (_isLoading)
        {
            <table class="payments-table">
                <thead>
                <tr>
                    <th>Заказ</th>
                    <th>Клиент</th>
                    <th>Тип оплаты</th>
                    <th>Способ</th>
                    <th>Дата</th>
                    <th>Сумма</th>
                    <th>Комментарий</th>
                </tr>
                </thead>

                <tbody>
                @for (var i = 0; i < PageSize; i++)
                {
                    <tr>
                        <td>
                            <div class="skeleton skeleton-line medium"></div>
                        </td>
                        <td>
                            <div class="skeleton skeleton-line wide"></div>
                        </td>
                        <td>
                            <div class="skeleton skeleton-badge"></div>
                        </td>
                        <td>
                            <div class="skeleton skeleton-line medium"></div>
                        </td>
                        <td>
                            <div class="skeleton skeleton-line medium"></div>
                        </td>
                        <td>
                            <div class="skeleton skeleton-line small"></div>
                        </td>
                        <td>
                            <div class="skeleton skeleton-line wide"></div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
        else if (_payments.Count == 0)
        {
            <div class="table-empty">Оплаты не найдены</div>
        }
        else
        {
            <table class="payments-table">
                <thead>
                <tr>
                    <th class="sortable-column" @onclick='() => ChangeSort("ordernumber")'>
                        Заказ <i class="bi bi-arrow-down-up"></i>
                    </th>

                    <th class="sortable-column" @onclick='() => ChangeSort("customer")'>
                        Клиент <i class="bi bi-arrow-down-up"></i>
                    </th>

                    <th class="sortable-column" @onclick='() => ChangeSort("paymenttype")'>
                        Тип оплаты <i class="bi bi-arrow-down-up"></i>
                    </th>

                    <th class="sortable-column" @onclick='() => ChangeSort("paymentmethod")'>
                        Способ <i class="bi bi-arrow-down-up"></i>
                    </th>

                    <th class="sortable-column" @onclick='() => ChangeSort("paymentdate")'>
                        Дата <i class="bi bi-arrow-down-up"></i>
                    </th>

                    <th class="sortable-column" @onclick='() => ChangeSort("amount")'>
                        Сумма <i class="bi bi-arrow-down-up"></i>
                    </th>

                    <th>Комментарий</th>
                </tr>
                </thead>

                <tbody>
                @foreach (var payment in _payments)
                {
                    <tr>
                        <td>
                            <div>
                                <strong>@payment.OrderNumber</strong>

                                <span class="table-secondary-text">
                                    @payment.OrderDate.ToString("dd.MM.yyyy")
                                </span>
                            </div>
                        </td>

                        <td>@payment.CustomerFullName</td>

                        <td>
                            <span class="@GetPaymentTypeClass(payment.PaymentTypeName)">
                                @payment.PaymentTypeName
                            </span>
                        </td>

                        <td>@payment.PaymentMethodName</td>

                        <td>@payment.PaymentDate.ToString("dd.MM.yyyy HH:mm")</td>

                        <td>
                            <strong>@payment.Amount.ToString("N2") ₽</strong>
                        </td>

                        <td>@(string.IsNullOrWhiteSpace(payment.Comment) ? "—" : payment.Comment)</td>
                    </tr>
                }
                </tbody>
            </table>
        }

        <Pagination CurrentPage="_currentPage"
                    TotalPages="_totalPages"
                    TotalItems="_totalCount"
                    StartItem="PageStart"
                    EndItem="PageEnd"
                    PageChanged="GoToPage"/>

    </div>
</div>

@code
{
    private CancellationTokenSource? _searchCts;

    private const int PageSize = 5;

    private List<PaymentDto> _payments = [];
    private List<PaymentTypeDto> _paymentTypes = [];
    private List<PaymentMethodDto> _paymentMethods = [];

    private int _currentPage = 1;
    private int _totalPages;
    private int _totalCount;

    private bool _isLoading = true;

    private string? _search;
    private string? _sortBy = "paymentdate";
    private bool _descending = true;

    private Guid? _paymentTypeId;
    private Guid? _paymentMethodId;

    private DateTime? _dateFrom;
    private DateTime? _dateTo;

    private int _rentalCount;
    private int _depositCount;
    private int _depositRefundCount;
    private decimal _totalAmount;
    private string _activeStatsFilter = "all";

    private int PageStart =>
        _totalCount == 0 ? 0 : ((_currentPage - 1) * PageSize) + 1;

    private int PageEnd =>
        Math.Min(_currentPage * PageSize, _totalCount);

    private async Task LoadDictionariesAsync()
    {
        var typesResult = await PaymentTypesService.GetPaymentTypesAsync();

        if (typesResult.IsFailure)
        {
            _paymentTypes = [];
            NotificationService.Error(typesResult.Error.Message);
        }
        else
        {
            _paymentTypes = typesResult.Value;
        }

        var methodsResult = await PaymentMethodsService.GetPaymentMethodsAsync();

        if (methodsResult.IsFailure)
        {
            _paymentMethods = [];
            NotificationService.Error(methodsResult.Error.Message);
        }
        else
        {
            _paymentMethods = methodsResult.Value;
        }
    }

    private async Task LoadPaymentsAsync()
    {
        _isLoading = true;

        var filter = new GetPaymentsRequest
        {
            Search = _search,
            PaymentTypeId = _paymentTypeId,
            PaymentMethodId = _paymentMethodId,
            DateFrom = _dateFrom,
            DateTo = _dateTo,
            SortBy = _sortBy,
            Descending = _descending,
            Page = _currentPage,
            PageSize = PageSize
        };

        var result = await PaymentsService.GetPaymentsAsync(filter);

        if (result.IsFailure)
        {
            _payments = [];
            _totalCount = 0;
            _totalPages = 0;
            _isLoading = false;

            NotificationService.Error(result.Error.Message);
            return;
        }

        _payments = result.Value.Items.ToList();
        _totalCount = result.Value.TotalCount;
        _totalPages = result.Value.TotalPages;

        _isLoading = false;
    }

    private async Task ApplyFilters()
    {
        _currentPage = 1;
        await LoadPaymentsAsync();
    }

    private async Task ResetFilters()
    {
        _search = string.Empty;
        _paymentTypeId = null;
        _paymentMethodId = null;
        _dateFrom = null;
        _dateTo = null;

        _sortBy = "paymentdate";
        _descending = true;

        _currentPage = 1;
        _activeStatsFilter = "all";

        await LoadPaymentsAsync();
    }

    private async Task ChangeSort(string sortBy)
    {
        if (_sortBy == sortBy)
        {
            _descending = !_descending;
        }
        else
        {
            _sortBy = sortBy;
            _descending = false;
        }

        _currentPage = 1;

        await LoadPaymentsAsync();
    }

    private async Task GoToPage(int page)
    {
        _currentPage = page;
        await LoadPaymentsAsync();
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        _search = e.Value?.ToString();

        _searchCts?.Cancel();
        _searchCts?.Dispose();

        _searchCts = new CancellationTokenSource();
        var token = _searchCts.Token;

        try
        {
            await Task.Delay(500, token);

            _currentPage = 1;
            await LoadPaymentsAsync();
        }
        catch (OperationCanceledException)
        {
            // ignored
        }
    }

    private static string GetPaymentTypeClass(string paymentTypeName)
    {
        return paymentTypeName switch
        {
            "Аренда" => "status-badge available",
            "Залог" => "status-badge neutral",
            "Возврат залога" => "status-badge info",
            _ => "status-badge"
        };
    }

    private async Task LoadStatsAsync()
    {
        var result = await PaymentsService.GetStatsAsync();

        if (result.IsFailure)
        {
            _totalCount = 0;
            _rentalCount = 0;
            _depositCount = 0;
            _depositRefundCount = 0;
            _totalAmount = 0;

            NotificationService.Error(result.Error.Message);
            return;
        }

        _totalCount = result.Value.TotalCount;
        _rentalCount = result.Value.RentalCount;
        _depositCount = result.Value.DepositCount;
        _depositRefundCount = result.Value.DepositRefundCount;
        _totalAmount = result.Value.TotalAmount;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDictionariesAsync();
        await LoadStatsAsync();
        await LoadPaymentsAsync();
    }
    
    private async Task ApplyStatsFilter(string filter)
    {
        _activeStatsFilter = filter;

        _paymentTypeId = filter switch
        {
            "rental" => GetPaymentTypeIdByName("Аренда"),
            "deposit" => GetPaymentTypeIdByName("Залог"),
            "refund" => GetPaymentTypeIdByName("Возврат залога"),
            _ => null
        };

        _currentPage = 1;

        await LoadPaymentsAsync();
    }

    private Guid? GetPaymentTypeIdByName(string name)
    {
        return _paymentTypes
            .FirstOrDefault(x => x.Name == name)
            ?.Id;
    }

    private string GetStatsCardClass(string filter)
    {
        return _activeStatsFilter == filter
            ? "stats-card-button active"
            : "stats-card-button";
    }
    
    private async Task ExportPayments()
    {
        var request = new ExportPaymentsRequest
        {
            Search = _search,
            PaymentTypeId = _paymentTypeId,
            PaymentMethodId = _paymentMethodId,
            DateFrom = _dateFrom,
            DateTo = _dateTo,
            SortBy = _sortBy,
            Descending = _descending
        };

        var result = await PaymentsService.ExportPaymentsAsync(request);

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        NotificationService.Success("Оплаты экспортированы");
    }
}