@page "/dashboard"
@using RentalPro.Contracts.Dashboard
@using RentalPro.Contracts.Orders
@using RentalPro.Presentation.Client.Services
@layout AdminLayout
@inject DashboardService DashboardService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@inject OrdersService OrdersService

<div class="dashboard">

    @if (_isLoading)
    {
        <DashboardSkeleton />
    }
    else if (_dashboard is not null)
    {
        <div class="stats-grid">

            <div class="stat-card">
                <div class="stat-icon stat-blue">
                    <i class="bi bi-briefcase"></i>
                </div>

                <div>
                    <div class="stat-title">Инструментов</div>
                    <div class="stat-value">@_dashboard.Stats.TotalTools</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon stat-green">
                    <i class="bi bi-calendar-check"></i>
                </div>

                <div>
                    <div class="stat-title">В аренде</div>
                    <div class="stat-value">@_dashboard.Stats.RentedTools</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon stat-orange">
                    <i class="bi bi-bookmark-check"></i>
                </div>

                <div>
                    <div class="stat-title">Забронировано</div>
                    <div class="stat-value">@_dashboard.Stats.BookedTools</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon stat-orange">
                    <i class="bi bi-wrench"></i>
                </div>

                <div>
                    <div class="stat-title">На ремонте</div>
                    <div class="stat-value">@_dashboard.Stats.ToolsInRepair</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon stat-purple">
                    <i class="bi bi-people"></i>
                </div>

                <div>
                    <div class="stat-title">Клиенты</div>
                    <div class="stat-value">@_dashboard.Stats.TotalCustomers</div>
                </div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon stat-blue">
                    <i class="bi bi-journal-check"></i>
                </div>

                <div>
                    <div class="stat-title">Активные заказы</div>
                    <div class="stat-value">
                        @_dashboard.Stats.ActiveOrders
                    </div>
                </div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon stat-green">
                    <i class="bi bi-plus-square"></i>
                </div>

                <div>
                    <div class="stat-title">Новых заказов</div>
                    <div class="stat-value">
                        @_dashboard.Stats.NewOrdersThisMonth
                    </div>
                </div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon stat-orange">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>

                <div>
                    <div class="stat-title">Просрочено</div>
                    <div class="stat-value">
                        @_dashboard.Stats.OverdueReturnsCount
                    </div>
                </div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon stat-purple">
                    <i class="bi bi-shield-lock"></i>
                </div>

                <div>
                    <div class="stat-title">Получено залогов</div>
                    <div class="stat-value">
                        @FormatMoney(_dashboard.Stats.DepositsReceived)
                    </div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon stat-cyan">
                    <i class="bi bi-wallet2"></i>
                </div>

                <div>
                    <div class="stat-title">Выручка за месяц</div>
                    <div class="stat-value">@FormatMoney(_dashboard.Stats.MonthlyRevenue)</div>
                </div>
            </div>

        </div>

        <div class="dashboard-row">

            <div class="dashboard-card dashboard-large">

                <div class="card-header">
                    <h3>Последние заказы</h3>

                    <button class="card-button" @onclick="GoToOrders">
                        Все заказы
                    </button>
                </div>

                <table class="orders-table">
                    <thead>
                    <tr>
                        <th>№ заказа</th>
                        <th>Клиент</th>
                        <th>Инстр.</th>
                        <th>Выдача</th>
                        <th>Статус</th>
                        <th>Аренда</th>
                        <th>Залог</th>
                    </tr>
                    </thead>

                    <tbody>
                    @if (_dashboard.RecentOrders.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="empty-cell">
                                Заказов пока нет
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var order in _dashboard.RecentOrders)
                        {
                            <tr class="clickable-row"
                                @onclick="() => OpenOrderItemsModal(order)">
                                <td>
                                    <strong>@order.Number</strong>
                                </td>

                                <td>@order.CustomerFullName</td>

                                <td>@order.ToolsCount</td>

                                <td>
                                    @(order.StartDate?.ToString("dd.MM.yyyy") ?? "-")
                                </td>

                                <td>
                                    <span class="@GetOrderStatusClass(order.StatusName)">
                                        @order.StatusName
                                    </span>
                                </td>

                                <td>
                                    @order.TotalCost.ToString("N0") ₽
                                </td>

                                <td>
                                    @order.DepositTotal.ToString("N0") ₽
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>

            </div>

            <div class="dashboard-card">

                <h3>Статусы инструментов</h3>

                <div class="status-chart">
                    <div class="chart-circle" style="@ChartStyle">
                        <div class="chart-center">
                            <div>@_dashboard.Stats.TotalTools</div>
                            <small>Всего</small>
                        </div>
                    </div>

                    <div class="chart-legend">
                        <div>
                            <span class="dot green"></span>
                            <span>Доступен</span>
                            <strong>@_dashboard.ToolStatuses.Available</strong>
                        </div>

                        <div>
                            <span class="dot blue"></span>
                            <span>В аренде</span>
                            <strong>@_dashboard.ToolStatuses.Rented</strong>
                        </div>

                        <div>
                            <span class="dot yellow"></span>
                            <span>Забронирован</span>
                            <strong>@_dashboard.ToolStatuses.Booked</strong>
                        </div>

                        <div>
                            <span class="dot orange"></span>
                            <span>На ремонте</span>
                            <strong>@_dashboard.ToolStatuses.InRepair</strong>
                        </div>
                    </div>
                </div>

            </div>

        </div>

        <div class="dashboard-row bottom-row">

            <div class="dashboard-card">

                <div class="card-header">
                    <h3>Ближайшие возвраты</h3>
                </div>

                <div class="returns-list">

                    @if (_dashboard.UpcomingReturns.Count == 0)
                    {
                        <div class="empty-list">
                            Ближайших возвратов нет
                        </div>
                    }
                    else
                    {
                        @foreach (var item in _dashboard.UpcomingReturns)
                        {
                            <div class="return-item clickable-row" @onclick="() => GoToOrder(item.OrderId)">
                                <div>
                                    <strong>@item.CustomerFullName</strong>
                                    <span>@item.ToolsNames</span>
                                </div>

                                <span class="@GetReturnDateClass(item.Days)">
                                    @GetReturnDateText(item)
                                </span>
                            </div>
                        }
                    }

                </div>

            </div>

            <div class="dashboard-card">

                <div class="card-header">
                    <h3>Просроченные возвраты</h3>
                </div>

                <div class="overdue-list">

                    @if (_dashboard.OverdueReturns.Count == 0)
                    {
                        <div class="empty-list">
                            Просроченных возвратов нет
                        </div>
                    }
                    else
                    {
                        @foreach (var item in _dashboard.OverdueReturns)
                        {
                            <div class="overdue-item clickable-row" @onclick="() => GoToOrder(item.OrderId)">
                                <div>
                                    <strong>@item.CustomerFullName</strong>
                                    <span>@item.ToolsNames</span>
                                </div>

                                <span class="overdue-days">
                                    @FormatDays(item.Days)
                                </span>
                            </div>
                        }
                    }

                </div>

            </div>

        </div>
    }
    
    @if (_isOrderItemsModalOpen)
{
    <div class="actions-backdrop" @onclick="CloseOrderItemsModal">
        <div class="order-items-modal" @onclick:stopPropagation="true">

            <div class="actions-modal-header">
                <div>
                    <h3>Состав заказа</h3>

                    @if (_selectedOrderDetails is not null)
                    {
                        <p>@_selectedOrderDetails.Number — @_selectedOrderDetails.CustomerFullName</p>
                    }
                    else
                    {
                        <p>Загрузка данных заказа</p>
                    }
                </div>

                <button type="button" @onclick="CloseOrderItemsModal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            @if (_isOrderItemsLoading)
            {
                <div class="table-empty">Загрузка состава заказа...</div>
            }
            else if (_selectedOrderDetails is null || _selectedOrderDetails.Items.Count == 0)
            {
                <div class="table-empty">Позиции заказа не найдены</div>
            }
            else
            {
                <div class="order-items-table-wrap">
                    <OrderItemsTable Items="_selectedOrderDetails.Items" />
                </div>
            }

            <div class="customer-view-footer">
                <button class="secondary-button"
                        type="button"
                        @onclick="CloseOrderItemsModal">
                    Закрыть
                </button>
            </div>

        </div>
    </div>
}

</div>

@code {
    private DashboardRecentOrderDto? _selectedRecentOrder;
    private bool _isOrderItemsModalOpen;
    private bool _isRecentOrderModalOpen;
    private DashboardDto? _dashboard;
    private bool _isLoading = true;
    private OrderDetailsDto? _selectedOrderDetails;
    private bool _isOrderItemsLoading;
    
    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        _isLoading = true;

        var result = await DashboardService.GetDashboardAsync();

        if (result.IsFailure)
        {
            NotificationService.Error("Не удалось загрузить данные дашборда");
            _isLoading = false;
            return;
        }

        _dashboard = result.Value;
        _isLoading = false;
    }

    private void GoToOrders()
    {
        NavigationManager.NavigateTo("/orders");
    }

    private void GoToOrder(Guid orderId)
    {
        NavigationManager.NavigateTo($"/orders/{orderId}");
    }

    private static string FormatDate(DateOnly? date)
    {
        return date?.ToString("dd.MM.yyyy") ?? "—";
    }

    private static string FormatDate(DateOnly date)
    {
        return date.ToString("dd.MM.yyyy");
    }

    private static string FormatMoney(decimal value)
    {
        return $"{value:N0} ₽";
    }

    private static string GetStatusBadgeClass(string statusName)
    {
        return statusName switch
        {
            "Завершён" => "badge-muted",
            "Ожидает возврата залога" => "badge-warning",
            "Забронирован" => "badge-info",
            "В аренде" => "badge-success",
            _ => "badge-success"
        };
    }

    private static string GetReturnDateClass(int days)
    {
        return days switch
        {
            0 => "return-date today",
            1 => "return-date tomorrow",
            _ => "return-date"
        };
    }

    private static string GetReturnDateText(DashboardReturnDto item)
    {
        return item.Days switch
        {
            0 => "Сегодня",
            1 => "Завтра",
            _ => FormatDate(item.PlannedReturnDate)
        };
    }

    private static string FormatDays(int days)
    {
        var abs = Math.Abs(days);

        var word = (abs % 10) switch
        {
            1 when abs % 100 != 11 => "день",
            >= 2 and <= 4 when (abs % 100 < 10 || abs % 100 >= 20) => "дня",
            _ => "дней"
        };

        return $"{abs} {word}";
    }
    
    private string ChartStyle
    {
        get
        {
            if (_dashboard is null)
                return string.Empty;

            var statuses = _dashboard.ToolStatuses;

            var total = statuses.Available +
                        statuses.Rented +
                        statuses.Booked +
                        statuses.InRepair;

            if (total == 0)
                return string.Empty;

            var available = statuses.Available * 100m / total;
            var rented = statuses.Rented * 100m / total;
            var booked = statuses.Booked * 100m / total;

            var availableEnd = available;
            var rentedEnd = available + rented;
            var bookedEnd = available + rented + booked;

            return
                $"background: conic-gradient(" +
                $"#5dbb46 0% {availableEnd:F2}%, " +
                $"#2f6fed {availableEnd:F2}% {rentedEnd:F2}%, " +
                $"#f0c419 {rentedEnd:F2}% {bookedEnd:F2}%, " +
                $"#d97a16 {bookedEnd:F2}% 100%);";
        }
    }
    
    private static string GetOrderStatusClass(string statusName)
    {
        return statusName.ToLowerInvariant() switch
        {
            "забронирован" => "status-badge reserved",
            "выполняется" => "status-badge rented",
            "ожидает возврата залога" => "status-badge warning",
            "завершен" => "status-badge available",
            "отменен" => "status-badge cancelled",

            _ => "status-badge"
        };
    }
    
    private async Task OpenOrderItemsModal(DashboardRecentOrderDto order)
    {
        _isOrderItemsModalOpen = true;
        _isOrderItemsLoading = true;
        _selectedOrderDetails = null;

        var result = await OrdersService.GetByIdAsync(order.Id);

        if (result.IsFailure)
        {
            _isOrderItemsLoading = false;
            _isOrderItemsModalOpen = false;

            NotificationService.Error(result.Error.Message);
            return;
        }

        _selectedOrderDetails = result.Value;
        _isOrderItemsLoading = false;
    }
    
    private void CloseOrderItemsModal()
    {
        _selectedOrderDetails = null;
        _isOrderItemsModalOpen = false;
        _isOrderItemsLoading = false;
    }
}