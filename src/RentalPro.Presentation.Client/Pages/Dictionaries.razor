@page "/dictionaries"
@layout AdminLayout

@using RentalPro.Contracts
@using RentalPro.Presentation.Client.Services

@inject NavigationManager NavigationManager
@inject DictionariesService DictionariesService
@inject NotificationService NotificationService

<div class="dictionaries-page">

    <div class="dictionary-grid">

        <div class="dictionary-card"
             @onclick='() => OpenDictionary("tool-categories")'>

            <div class="dictionary-icon blue">
                <i class="bi bi-grid"></i>
            </div>

            <div class="dictionary-content">
                <h3>Категории инструментов</h3>
                <p>Категории и группы инструментов</p>
            </div>

            <div class="dictionary-footer">
                <div class="dictionary-count">
                    <strong>@GetCount(_stats?.ToolCategories)</strong>
                    <span>@GetRecordWord(_stats?.ToolCategories)</span>
                </div>

                <i class="bi bi-arrow-right dictionary-arrow"></i>
            </div>
        </div>

        <div class="dictionary-card"
             @onclick='() => OpenDictionary("tool-statuses")'>

            <div class="dictionary-icon green">
                <i class="bi bi-tools"></i>
            </div>

            <div class="dictionary-content">
                <h3>Статусы инструментов</h3>
                <p>Статусы доступности инструментов</p>
            </div>

            <div class="dictionary-footer">
                <div class="dictionary-count">
                    <strong>@GetCount(_stats?.ToolStatuses)</strong>
                    <span>@GetRecordWord(_stats?.ToolStatuses)</span>
                </div>

                <i class="bi bi-arrow-right dictionary-arrow"></i>
            </div>
        </div>

        <div class="dictionary-card"
             @onclick='() => OpenDictionary("order-statuses")'>

            <div class="dictionary-icon orange">
                <i class="bi bi-card-checklist"></i>
            </div>

            <div class="dictionary-content">
                <h3>Статусы заказов</h3>
                <p>Статусы выполнения заказов</p>
            </div>

            <div class="dictionary-footer">
                <div class="dictionary-count">
                    <strong>@GetCount(_stats?.OrderStatuses)</strong>
                    <span>@GetRecordWord(_stats?.OrderStatuses)</span>
                </div>

                <i class="bi bi-arrow-right dictionary-arrow"></i>
            </div>
        </div>

        <div class="dictionary-card"
             @onclick='() => OpenDictionary("payment-methods")'>

            <div class="dictionary-icon cyan">
                <i class="bi bi-credit-card"></i>
            </div>

            <div class="dictionary-content">
                <h3>Способы оплаты</h3>
                <p>Доступные способы оплаты</p>
            </div>

            <div class="dictionary-footer">
                <div class="dictionary-count">
                    <strong>@GetCount(_stats?.PaymentMethods)</strong>
                    <span>@GetRecordWord(_stats?.PaymentMethods)</span>
                </div>

                <i class="bi bi-arrow-right dictionary-arrow"></i>
            </div>
        </div>

        <div class="dictionary-card"
             @onclick='() => OpenDictionary("payment-types")'>

            <div class="dictionary-icon mint">
                <i class="bi bi-percent"></i>
            </div>

            <div class="dictionary-content">
                <h3>Типы оплат</h3>
                <p>Типы оплат и наценок</p>
            </div>

            <div class="dictionary-footer">
                <div class="dictionary-count">
                    <strong>@GetCount(_stats?.PaymentTypes)</strong>
                    <span>@GetRecordWord(_stats?.PaymentTypes)</span>
                </div>

                <i class="bi bi-arrow-right dictionary-arrow"></i>
            </div>
        </div>

        <div class="dictionary-card"
             @onclick='() => OpenDictionary("roles")'>

            <div class="dictionary-icon violet">
                <i class="bi bi-person"></i>
            </div>

            <div class="dictionary-content">
                <h3>Роли пользователей</h3>
                <p>Роли и права доступа</p>
            </div>

            <div class="dictionary-footer">
                <div class="dictionary-count">
                    <strong>@GetCount(_stats?.Roles)</strong>
                    <span>@GetRecordWord(_stats?.Roles)</span>
                </div>

                <i class="bi bi-arrow-right dictionary-arrow"></i>
            </div>
        </div>

        <div class="dictionary-card"
             @onclick='() => OpenDictionary("manufacturers")'>

            <div class="dictionary-icon yellow">
                <i class="bi bi-building"></i>
            </div>

            <div class="dictionary-content">
                <h3>Производители</h3>
                <p>Производители инструментов</p>
            </div>

            <div class="dictionary-footer">
                <div class="dictionary-count">
                    <strong>@GetCount(_stats?.Manufacturers)</strong>
                    <span>@GetRecordWord(_stats?.Manufacturers)</span>
                </div>

                <i class="bi bi-arrow-right dictionary-arrow"></i>
            </div>
        </div>

    </div>

</div>

@code
{
    private DictionaryStatsDto? _stats;

    protected override async Task OnInitializedAsync()
    {
        await LoadStatsAsync();
    }

    private async Task LoadStatsAsync()
    {
        var result = await DictionariesService.GetStatsAsync();

        if (result.IsFailure)
        {
            NotificationService.Error(result.Error.Message);
            return;
        }

        _stats = result.Value;
    }

    private void OpenDictionary(string dictionaryCode)
    {
        NavigationManager.NavigateTo($"/dictionaries/{dictionaryCode}");
    }

    private static string GetCount(int? count)
    {
        return count?.ToString() ?? "0";
    }

    private static string GetRecordWord(int? count)
    {
        var value = count ?? 0;

        if (value % 100 is >= 11 and <= 14)
            return "записей";

        return (value % 10) switch
        {
            1 => "запись",
            2 or 3 or 4 => "записи",
            _ => "записей"
        };
    }
}