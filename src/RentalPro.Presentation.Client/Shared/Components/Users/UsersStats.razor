<div class="users-stats">

    <button class="stat-card-button @(ActiveFilter == "all" ? "active" : "")"
            type="button"
            @onclick='() => OnFilterSelected.InvokeAsync("all")'>
        <StatCard Title="Всего"
                  Value="@TotalCount.ToString()"
                  Icon="bi bi-people"
                  Color="blue" />
    </button>

    <button class="stat-card-button @(ActiveFilter == "active" ? "active" : "")"
            type="button"
            @onclick='() => OnFilterSelected.InvokeAsync("active")'>
        <StatCard Title="Активные"
                  Value="@ActiveCount.ToString()"
                  Icon="bi bi-person-check"
                  Color="green" />
    </button>

    <button class="stat-card-button @(ActiveFilter == "admin" ? "active" : "")"
            type="button"
            @onclick='() => OnFilterSelected.InvokeAsync("admin")'>
        <StatCard Title="Администраторы"
                  Value="@AdminCount.ToString()"
                  Icon="bi bi-person-gear"
                  Color="orange" />
    </button>

    <button class="stat-card-button @(ActiveFilter == "blocked" ? "active" : "")"
            type="button"
            @onclick='() => OnFilterSelected.InvokeAsync("blocked")'>
        <StatCard Title="Заблокированные"
                  Value="@BlockedCount.ToString()"
                  Icon="bi bi-person-x"
                  Color="red" />
    </button>

    <button class="users-add-card"
            type="button"
            @onclick="AddUserClicked">
        <i class="bi bi-plus-lg"></i>
        <span>Добавить пользователя</span>
    </button>

</div>

@code {
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public int ActiveCount { get; set; }
    [Parameter] public int AdminCount { get; set; }
    [Parameter] public int BlockedCount { get; set; }

    [Parameter] public EventCallback AddUserClicked { get; set; }

    [Parameter] public EventCallback<string> OnFilterSelected { get; set; }

    [Parameter] public string ActiveFilter { get; set; } = "all";
}